<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="Color.Primary">#F2D009</Color>
    <Color x:Key="Color.PrimaryHover">#E0BC00</Color>
    <Color x:Key="Color.OnPrimary">#362700</Color>
    <Color x:Key="Color.PrimarySurface">#FFF2A3</Color>
    <Color x:Key="Color.InputBorder">#E7D891</Color>
    <Color x:Key="Color.PageBackground">#6A5200</Color>

    <SolidColorBrush x:Key="Brush.Primary" Color="{StaticResource Color.Primary}"/>
    <SolidColorBrush x:Key="Brush.PrimaryHover" Color="{StaticResource Color.PrimaryHover}"/>
    <SolidColorBrush x:Key="Brush.OnPrimary" Color="{StaticResource Color.OnPrimary}"/>
    <SolidColorBrush x:Key="Brush.PrimarySurface" Color="{StaticResource Color.PrimarySurface}"/>
    <SolidColorBrush x:Key="Brush.InputBorder" Color="{StaticResource Color.InputBorder}"/>
    <SolidColorBrush x:Key="Brush.PageBackground" Color="{StaticResource Color.PageBackground}"/>

    <LinearGradientBrush x:Key="Brush.PageGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFF17D" Offset="0"/>
        <GradientStop Color="#D6A300" Offset="0.45"/>
        <GradientStop Color="#5B4300" Offset="1"/>
    </LinearGradientBrush>
</ResourceDictionary>
