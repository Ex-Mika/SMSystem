<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <Color x:Key="DashboardColor.PageBackground">#FFF9E6</Color>
    <Color x:Key="DashboardColor.Surface">#FFFFFF</Color>
    <Color x:Key="DashboardColor.Border">#E8DDA1</Color>
    <Color x:Key="DashboardColor.Primary">#F2D009</Color>
    <Color x:Key="DashboardColor.PrimaryHover">#E0BC00</Color>
    <Color x:Key="DashboardColor.PrimarySoft">#FFF2A3</Color>
    <Color x:Key="DashboardColor.OnPrimary">#362700</Color>
    <Color x:Key="DashboardColor.AccentText">#6A4E00</Color>
    <Color x:Key="DashboardColor.TextPrimary">#302500</Color>
    <Color x:Key="DashboardColor.TextMuted">#786A38</Color>
    <Color x:Key="DashboardColor.Track">#F1E7B5</Color>
    <Color x:Key="DashboardColor.Success">#2B8A52</Color>
    <Color x:Key="DashboardColor.Warning">#C97A00</Color>
    <Color x:Key="DashboardColor.Danger">#DC2626</Color>
    <Color x:Key="DashboardColor.Purple">#A06C00</Color>

    <SolidColorBrush x:Key="DashboardPageBackgroundBrush" Color="{StaticResource DashboardColor.PageBackground}"/>
    <SolidColorBrush x:Key="DashboardSurfaceBrush" Color="{StaticResource DashboardColor.Surface}"/>
    <SolidColorBrush x:Key="DashboardBorderBrush" Color="{StaticResource DashboardColor.Border}"/>
    <SolidColorBrush x:Key="DashboardPrimaryBrush" Color="{StaticResource DashboardColor.Primary}"/>
    <SolidColorBrush x:Key="DashboardPrimaryHoverBrush" Color="{StaticResource DashboardColor.PrimaryHover}"/>
    <SolidColorBrush x:Key="DashboardPrimarySoftBrush" Color="{StaticResource DashboardColor.PrimarySoft}"/>
    <SolidColorBrush x:Key="DashboardOnPrimaryBrush" Color="{StaticResource DashboardColor.OnPrimary}"/>
    <SolidColorBrush x:Key="DashboardAccentTextBrush" Color="{StaticResource DashboardColor.AccentText}"/>
    <SolidColorBrush x:Key="DashboardTextPrimaryBrush" Color="{StaticResource DashboardColor.TextPrimary}"/>
    <SolidColorBrush x:Key="DashboardTextMutedBrush" Color="{StaticResource DashboardColor.TextMuted}"/>
    <SolidColorBrush x:Key="DashboardTrackBrush" Color="{StaticResource DashboardColor.Track}"/>
    <SolidColorBrush x:Key="DashboardSuccessBrush" Color="{StaticResource DashboardColor.Success}"/>
    <SolidColorBrush x:Key="DashboardWarningBrush" Color="{StaticResource DashboardColor.Warning}"/>
    <SolidColorBrush x:Key="DashboardDangerBrush" Color="{StaticResource DashboardColor.Danger}"/>
    <SolidColorBrush x:Key="DashboardPurpleBrush" Color="{StaticResource DashboardColor.Purple}"/>
    <SolidColorBrush x:Key="DashboardSidebarIconBrush" Color="#9B8A4D"/>
    <SolidColorBrush x:Key="DashboardSidebarIconSurfaceBrush" Color="#FFF8D6"/>
    <SolidColorBrush x:Key="DashboardSidebarIconSelectedSurfaceBrush" Color="#FFE58A"/>
    <SolidColorBrush x:Key="DashboardSoftSurfaceBrush" Color="#FFFBEA"/>
    <SolidColorBrush x:Key="DashboardSoftSurfaceAltBrush" Color="#FFF7D1"/>
    <SolidColorBrush x:Key="DashboardSoftBorderBrush" Color="#E4D389"/>
    <SolidColorBrush x:Key="DashboardStrongSurfaceBrush" Color="#FFE58A"/>
    <SolidColorBrush x:Key="DashboardAvatarSurfaceBrush" Color="#FFEEA6"/>
    <SolidColorBrush x:Key="DashboardAvatarForegroundBrush" Color="#5A4300"/>
    <SolidColorBrush x:Key="DashboardDeepAccentBrush" Color="#5B4300"/>
    <SolidColorBrush x:Key="DashboardHelpTextBrush" Color="#FFF6CC"/>

    <sys:Double x:Key="DashboardCalendarHeaderFontSize">16</sys:Double>
    <sys:Double x:Key="DashboardCalendarDayFontSize">15</sys:Double>
    <sys:Double x:Key="DashboardCalendarDayWidth">40</sys:Double>
    <sys:Double x:Key="DashboardCalendarDayHeight">33</sys:Double>

    <LinearGradientBrush x:Key="DashboardHelpGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFE26B" Offset="0"/>
        <GradientStop Color="#C99800" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="DashboardStudentAreaBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FFE58A" Offset="0"/>
        <GradientStop Color="#00FFFFFF" Offset="1"/>
    </LinearGradientBrush>

    <Style x:Key="DashboardTitleBarBorderStyle" TargetType="Border">
        <Setter Property="Height" Value="44"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="BorderBrush" Value="#D9B108"/>
        <Setter Property="Background" Value="#8F6B00"/>
    </Style>

    <Style x:Key="DashboardCardBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource DashboardSurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource DashboardBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#3E2E00"
                                  BlurRadius="10"
                                  ShadowDepth="1"
                                  Opacity="0.18"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DashboardManagementDataGridStyle" TargetType="DataGrid">
        <Setter Property="AutoGenerateColumns" Value="False"/>
        <Setter Property="HeadersVisibility" Value="Column"/>
        <Setter Property="GridLinesVisibility" Value="All"/>
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource DashboardBorderBrush}"/>
        <Setter Property="VerticalGridLinesBrush" Value="{StaticResource DashboardBorderBrush}"/>
        <Setter Property="IsReadOnly" Value="True"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="RowHeaderWidth" Value="0"/>
        <Setter Property="CanUserAddRows" Value="False"/>
        <Setter Property="CanUserDeleteRows" Value="False"/>
        <Setter Property="CanUserResizeRows" Value="False"/>
        <Setter Property="CanUserResizeColumns" Value="False"/>
        <Setter Property="SelectionUnit" Value="FullRow"/>
        <Setter Property="SelectionMode" Value="Single"/>
        <Setter Property="MinColumnWidth" Value="90"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
    </Style>

    <Style x:Key="DashboardManagementDataGridHeaderStyle" TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{StaticResource DashboardSoftSurfaceBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource DashboardTextMutedBrush}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="BorderBrush" Value="{StaticResource DashboardBorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,1,1"/>
        <Setter Property="SeparatorVisibility" Value="Collapsed"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
    </Style>

    <Style x:Key="DashboardManagementDataGridCellStyle" TargetType="DataGridCell">
        <Setter Property="Padding" Value="10,11"/>
        <Setter Property="Foreground" Value="{StaticResource DashboardTextPrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style x:Key="DashboardManagementDataGridRowStyle" TargetType="DataGridRow">
        <Setter Property="Background" Value="White"/>
    </Style>

    <Style x:Key="DashboardWindowButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="44"/>
        <Setter Property="Height" Value="30"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="WindowButtonSurface" Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="WindowButtonSurface" Property="Background" Value="#16000000"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="WindowButtonSurface" Property="Background" Value="#22000000"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DashboardWindowCloseButtonStyle"
           TargetType="Button"
           BasedOn="{StaticResource DashboardWindowButtonStyle}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="CloseButtonSurface" Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="CloseButtonSurface" Property="Background" Value="#E53E3E"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="CloseButtonSurface" Property="Background" Value="#C53030"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DashboardSidebarNavButtonStyle" TargetType="Button">
        <Setter Property="Padding" Value="16,14"/>
        <Setter Property="MinHeight" Value="56"/>
        <Setter Property="Foreground" Value="{StaticResource DashboardTextMutedBrush}"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="NavButtonSurface"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="NavButtonSurface" Property="Background" Value="{StaticResource DashboardSoftSurfaceBrush}"/>
                            <Setter TargetName="NavButtonSurface" Property="BorderBrush" Value="{StaticResource DashboardSoftBorderBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="NavButtonSurface" Property="Opacity" Value="0.9"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DashboardSidebarNavSelectedButtonStyle"
           TargetType="Button"
           BasedOn="{StaticResource DashboardSidebarNavButtonStyle}">
        <Setter Property="Background" Value="{StaticResource DashboardPrimarySoftBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource DashboardSoftBorderBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource DashboardAccentTextBrush}"/>
    </Style>

    <Style x:Key="DashboardSidebarIconBadgeStyle" TargetType="Border">
        <Setter Property="Width" Value="28"/>
        <Setter Property="Height" Value="28"/>
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="DashboardSidebarIconSelectedBadgeStyle"
           TargetType="Border"
           BasedOn="{StaticResource DashboardSidebarIconBadgeStyle}">
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style x:Key="DashboardSidebarIconGlyphStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="Foreground" Value="{StaticResource DashboardSidebarIconBrush}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="DashboardSidebarIconGlyphSelectedStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource DashboardSidebarIconGlyphStyle}">
        <Setter Property="Foreground" Value="{StaticResource DashboardAccentTextBrush}"/>
    </Style>

    <Style x:Key="DashboardSidebarNavTextStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="14,0,0,0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource DashboardTextMutedBrush}"/>
    </Style>

    <Style x:Key="DashboardSidebarNavTextSelectedStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource DashboardSidebarNavTextStyle}">
        <Setter Property="Foreground" Value="{StaticResource DashboardAccentTextBrush}"/>
    </Style>

    <Style x:Key="DashboardProfileTabControlStyle" TargetType="TabControl">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabControl">
                    <Grid KeyboardNavigation.TabNavigation="Local">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TabPanel Grid.Row="0"
                                  Margin="0,0,0,12"
                                  IsItemsHost="True"
                                  ClipToBounds="False"
                                  Background="Transparent"
                                  KeyboardNavigation.TabIndex="1"/>

                        <Border Grid.Row="1"
                                Background="Transparent"
                                BorderThickness="0">
                            <ContentPresenter x:Name="PART_SelectedContentHost"
                                              ContentSource="SelectedContent"/>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DashboardProfileTabItemStyle" TargetType="TabItem">
        <Setter Property="Margin" Value="0,0,10,0"/>
        <Setter Property="Padding" Value="16,9"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Panel.ZIndex" Value="0"/>
        <Setter Property="Foreground" Value="{StaticResource DashboardTextMutedBrush}"/>
        <Setter Property="Background" Value="{StaticResource DashboardSoftSurfaceAltBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource DashboardSoftBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1,1,1,1"/>
        <Setter Property="SnapsToDevicePixels" Value="False"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Grid SnapsToDevicePixels="True">
                        <Rectangle x:Name="TabSurface"
                                   RadiusX="6"
                                   RadiusY="6"
                                   Fill="{TemplateBinding Background}"
                                   Stroke="{TemplateBinding BorderBrush}"
                                   StrokeThickness="1"/>
                        <ContentPresenter ContentSource="Header"
                                          Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="TabSurface" Property="Fill" Value="{StaticResource DashboardSoftSurfaceBrush}"/>
                            <Setter TargetName="TabSurface" Property="Stroke" Value="{StaticResource DashboardSoftBorderBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Panel.ZIndex" Value="10"/>
                            <Setter Property="Foreground" Value="{StaticResource DashboardAccentTextBrush}"/>
                            <Setter TargetName="TabSurface" Property="Fill" Value="{StaticResource DashboardPrimarySoftBrush}"/>
                            <Setter TargetName="TabSurface" Property="Stroke" Value="{StaticResource DashboardStrongSurfaceBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.55"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DashboardProfileSegmentButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="36"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#6D8097"/>
        <Setter Property="Background" Value="{StaticResource DashboardSoftSurfaceAltBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource DashboardSoftBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="SegmentSurface"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="7">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="SegmentSurface" Property="Background" Value="{StaticResource DashboardSoftSurfaceBrush}"/>
                            <Setter TargetName="SegmentSurface" Property="BorderBrush" Value="{StaticResource DashboardSoftBorderBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="SegmentSurface" Property="Opacity" Value="0.92"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DashboardProfileSegmentSelectedButtonStyle"
           TargetType="Button"
           BasedOn="{StaticResource DashboardProfileSegmentButtonStyle}">
        <Setter Property="Foreground" Value="{StaticResource DashboardAccentTextBrush}"/>
        <Setter Property="Background" Value="{StaticResource DashboardPrimarySoftBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource DashboardStrongSurfaceBrush}"/>
    </Style>

    <Style x:Key="DashboardProfileSectionCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource DashboardSoftSurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource DashboardBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="16"/>
    </Style>

    <Style x:Key="DashboardProfileSectionTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource DashboardTextPrimaryBrush}"/>
    </Style>

    <Style x:Key="DashboardProfileSectionSubtitleStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,4,0,0"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{StaticResource DashboardTextMutedBrush}"/>
    </Style>

    <Style x:Key="DashboardProfileFieldLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource DashboardTextMutedBrush}"/>
    </Style>

    <Style x:Key="DashboardProfileFieldValueContainerStyle" TargetType="Border">
        <Setter Property="Margin" Value="0,6,0,0"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource DashboardSoftBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
    </Style>

    <Style x:Key="DashboardProfileFieldValueStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource DashboardTextPrimaryBrush}"/>
    </Style>

    <Style x:Key="DashboardProfileInputTextBoxStyle" TargetType="TextBox">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource DashboardTextPrimaryBrush}"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource DashboardSoftBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="ProfileInputSurface"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                        <ScrollViewer x:Name="PART_ContentHost"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="ProfileInputSurface"
                                    Property="BorderBrush"
                                    Value="{StaticResource DashboardPrimaryBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ProfileInputSurface"
                                    Property="Background"
                                    Value="{StaticResource DashboardPageBackgroundBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DashboardProfileInputPasswordBoxStyle" TargetType="PasswordBox">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource DashboardTextPrimaryBrush}"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource DashboardSoftBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="PasswordBox">
                    <Border x:Name="ProfilePasswordSurface"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                        <ScrollViewer x:Name="PART_ContentHost"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="ProfilePasswordSurface"
                                    Property="BorderBrush"
                                    Value="{StaticResource DashboardPrimaryBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ProfilePasswordSurface"
                                    Property="Background"
                                    Value="{StaticResource DashboardPageBackgroundBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DashboardProfileStatCardStyle" TargetType="Border">
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="Background" Value="{StaticResource DashboardSoftSurfaceAltBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource DashboardSoftBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="10"/>
    </Style>

    <Style x:Key="DashboardProfileStatValueStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="22"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource DashboardTextPrimaryBrush}"/>
    </Style>

    <Style x:Key="DashboardProfileTagBorderStyle" TargetType="Border">
        <Setter Property="Padding" Value="10,4"/>
        <Setter Property="CornerRadius" Value="999"/>
        <Setter Property="Background" Value="{StaticResource DashboardPrimarySoftBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource DashboardSoftBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Margin" Value="0,0,8,0"/>
    </Style>

    <Style x:Key="DashboardHeaderIconButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="34"/>
        <Setter Property="Height" Value="34"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="HeaderIconSurface"
                            CornerRadius="8"
                            Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="HeaderIconSurface" Property="Background" Value="{StaticResource DashboardSoftSurfaceAltBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="HeaderIconSurface" Property="Background" Value="{StaticResource DashboardPrimarySoftBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DashboardSearchTextBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource DashboardSoftSurfaceAltBrush}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="{StaticResource DashboardTextPrimaryBrush}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="36,8,12,8"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="SearchSurface"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                        <ScrollViewer x:Name="PART_ContentHost"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="SearchSurface" Property="BorderBrush" Value="{StaticResource DashboardPrimaryBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DashboardFilterComboBoxItemStyle" TargetType="ComboBoxItem">
        <Setter Property="Padding" Value="10,7"/>
        <Setter Property="Foreground" Value="{StaticResource DashboardTextPrimaryBrush}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="ItemSurface"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="ItemSurface" Property="Background" Value="{StaticResource DashboardSoftSurfaceBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="ItemSurface" Property="Background" Value="{StaticResource DashboardPrimarySoftBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DashboardFilterComboToggleButtonStyle" TargetType="ToggleButton">
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border Background="Transparent">
                        <ContentPresenter/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DashboardFilterComboBoxStyle" TargetType="ComboBox">
        <Setter Property="Width" Value="148"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource DashboardTextPrimaryBrush}"/>
        <Setter Property="Background" Value="{StaticResource DashboardSoftSurfaceAltBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource DashboardSoftBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,0,28,0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="ItemContainerStyle" Value="{StaticResource DashboardFilterComboBoxItemStyle}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <Border x:Name="ComboSurface"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="24"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Margin="{TemplateBinding Padding}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"/>
                                <Path Grid.Column="1"
                                      Data="M 0 0 L 4 4 L 8 0"
                                      Stroke="{StaticResource DashboardTextMutedBrush}"
                                      StrokeThickness="1.6"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"/>
                            </Grid>
                        </Border>

                        <ToggleButton x:Name="ToggleButton"
                                      Style="{StaticResource DashboardFilterComboToggleButtonStyle}"
                                      IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                      ClickMode="Press"/>

                        <Popup x:Name="Popup"
                               Placement="Bottom"
                               AllowsTransparency="True"
                               Focusable="False"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               PopupAnimation="Fade">
                            <Border MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                    Margin="0,4,0,0"
                                    Background="White"
                                    BorderBrush="{StaticResource DashboardSoftBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <ScrollViewer Margin="0" SnapsToDevicePixels="True">
                                    <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ComboSurface" Property="BorderBrush" Value="{StaticResource DashboardStrongSurfaceBrush}"/>
                        </Trigger>
                        <Trigger SourceName="ToggleButton" Property="IsChecked" Value="True">
                            <Setter TargetName="ComboSurface" Property="BorderBrush" Value="{StaticResource DashboardPrimaryBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DashboardCalendarDayButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="32"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="Margin" Value="1"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{StaticResource DashboardTextPrimaryBrush}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="DayButtonSurface"
                            Background="{TemplateBinding Background}"
                            CornerRadius="7">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="DayButtonSurface" Property="Background" Value="{StaticResource DashboardSoftSurfaceBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DashboardCalendarSelectedDayButtonStyle"
           TargetType="Button"
           BasedOn="{StaticResource DashboardCalendarDayButtonStyle}">
        <Setter Property="Background" Value="{StaticResource DashboardPrimaryBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource DashboardOnPrimaryBrush}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="DashboardCalendarButtonLargeStyle" TargetType="{x:Type CalendarButton}">
        <Setter Property="FontSize" Value="{DynamicResource DashboardCalendarHeaderFontSize}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="DashboardCalendarDayButtonLargeStyle" TargetType="{x:Type CalendarDayButton}">
        <Setter Property="FontSize" Value="{DynamicResource DashboardCalendarDayFontSize}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Width" Value="{DynamicResource DashboardCalendarDayWidth}"/>
        <Setter Property="Height" Value="{DynamicResource DashboardCalendarDayHeight}"/>
    </Style>

    <Style x:Key="DashboardPrimaryActionButtonStyle" TargetType="Button">
        <Setter Property="Padding" Value="14,8"/>
        <Setter Property="Background" Value="{StaticResource DashboardPrimarySoftBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource DashboardOnPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource DashboardPrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="PrimaryActionSurface"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="PrimaryActionSurface" Property="Background" Value="{StaticResource DashboardPrimaryBrush}"/>
                            <Setter TargetName="PrimaryActionSurface" Property="BorderBrush" Value="{StaticResource DashboardPrimaryBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="PrimaryActionSurface" Property="Background" Value="{StaticResource DashboardPrimaryHoverBrush}"/>
                            <Setter TargetName="PrimaryActionSurface" Property="BorderBrush" Value="{StaticResource DashboardPrimaryHoverBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DashboardSecondaryActionButtonStyle"
           TargetType="Button"
           BasedOn="{StaticResource DashboardPrimaryActionButtonStyle}">
        <Setter Property="Background" Value="{StaticResource DashboardSoftSurfaceAltBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource DashboardSoftBorderBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource DashboardTextMutedBrush}"/>
    </Style>
</ResourceDictionary>
