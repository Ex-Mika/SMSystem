<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <Color x:Key="DashboardColor.PageBackground">#F5F7FB</Color>
    <Color x:Key="DashboardColor.Surface">#FFFFFF</Color>
    <Color x:Key="DashboardColor.Border">#E3E9F2</Color>
    <Color x:Key="DashboardColor.Primary">#137FEC</Color>
    <Color x:Key="DashboardColor.PrimarySoft">#EAF4FF</Color>
    <Color x:Key="DashboardColor.TextPrimary">#111827</Color>
    <Color x:Key="DashboardColor.TextMuted">#60758A</Color>
    <Color x:Key="DashboardColor.Track">#E8EEF5</Color>
    <Color x:Key="DashboardColor.Success">#16A34A</Color>
    <Color x:Key="DashboardColor.Warning">#F97316</Color>
    <Color x:Key="DashboardColor.Danger">#DC2626</Color>
    <Color x:Key="DashboardColor.Purple">#A78BFA</Color>

    <SolidColorBrush x:Key="DashboardPageBackgroundBrush" Color="{StaticResource DashboardColor.PageBackground}"/>
    <SolidColorBrush x:Key="DashboardSurfaceBrush" Color="{StaticResource DashboardColor.Surface}"/>
    <SolidColorBrush x:Key="DashboardBorderBrush" Color="{StaticResource DashboardColor.Border}"/>
    <SolidColorBrush x:Key="DashboardPrimaryBrush" Color="{StaticResource DashboardColor.Primary}"/>
    <SolidColorBrush x:Key="DashboardPrimarySoftBrush" Color="{StaticResource DashboardColor.PrimarySoft}"/>
    <SolidColorBrush x:Key="DashboardTextPrimaryBrush" Color="{StaticResource DashboardColor.TextPrimary}"/>
    <SolidColorBrush x:Key="DashboardTextMutedBrush" Color="{StaticResource DashboardColor.TextMuted}"/>
    <SolidColorBrush x:Key="DashboardTrackBrush" Color="{StaticResource DashboardColor.Track}"/>
    <SolidColorBrush x:Key="DashboardSuccessBrush" Color="{StaticResource DashboardColor.Success}"/>
    <SolidColorBrush x:Key="DashboardWarningBrush" Color="{StaticResource DashboardColor.Warning}"/>
    <SolidColorBrush x:Key="DashboardDangerBrush" Color="{StaticResource DashboardColor.Danger}"/>
    <SolidColorBrush x:Key="DashboardPurpleBrush" Color="{StaticResource DashboardColor.Purple}"/>
    <SolidColorBrush x:Key="DashboardSidebarIconBrush" Color="#8A9AAE"/>
    <SolidColorBrush x:Key="DashboardSidebarIconSurfaceBrush" Color="#F1F5FA"/>
    <SolidColorBrush x:Key="DashboardSidebarIconSelectedSurfaceBrush" Color="#DCEEFF"/>

    <sys:Double x:Key="DashboardCalendarHeaderFontSize">16</sys:Double>
    <sys:Double x:Key="DashboardCalendarDayFontSize">15</sys:Double>
    <sys:Double x:Key="DashboardCalendarDayWidth">40</sys:Double>
    <sys:Double x:Key="DashboardCalendarDayHeight">33</sys:Double>

    <LinearGradientBrush x:Key="DashboardHelpGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#127EEA" Offset="0"/>
        <GradientStop Color="#0D66D1" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="DashboardStudentAreaBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#4AA4FF" Offset="0"/>
        <GradientStop Color="#00FFFFFF" Offset="1"/>
    </LinearGradientBrush>

    <Style x:Key="DashboardTitleBarBorderStyle" TargetType="Border">
        <Setter Property="Height" Value="44"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="BorderBrush" Value="#2D7BEA"/>
        <Setter Property="Background" Value="#0F5FD7"/>
    </Style>

    <Style x:Key="DashboardCardBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource DashboardSurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource DashboardBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#160C304D"
                                  BlurRadius="10"
                                  ShadowDepth="1"
                                  Opacity="0.32"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DashboardManagementDataGridStyle" TargetType="DataGrid">
        <Setter Property="AutoGenerateColumns" Value="False"/>
        <Setter Property="HeadersVisibility" Value="Column"/>
        <Setter Property="GridLinesVisibility" Value="All"/>
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource DashboardBorderBrush}"/>
        <Setter Property="VerticalGridLinesBrush" Value="{StaticResource DashboardBorderBrush}"/>
        <Setter Property="IsReadOnly" Value="True"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="RowHeaderWidth" Value="0"/>
        <Setter Property="CanUserAddRows" Value="False"/>
        <Setter Property="CanUserDeleteRows" Value="False"/>
        <Setter Property="CanUserResizeRows" Value="False"/>
        <Setter Property="CanUserResizeColumns" Value="False"/>
        <Setter Property="SelectionUnit" Value="FullRow"/>
        <Setter Property="SelectionMode" Value="Single"/>
        <Setter Property="MinColumnWidth" Value="90"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
    </Style>

    <Style x:Key="DashboardManagementDataGridHeaderStyle" TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="#F8FBFF"/>
        <Setter Property="Foreground" Value="{StaticResource DashboardTextMutedBrush}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="BorderBrush" Value="{StaticResource DashboardBorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,1,1"/>
        <Setter Property="SeparatorVisibility" Value="Collapsed"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
    </Style>

    <Style x:Key="DashboardManagementDataGridCellStyle" TargetType="DataGridCell">
        <Setter Property="Padding" Value="10,11"/>
        <Setter Property="Foreground" Value="{StaticResource DashboardTextPrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style x:Key="DashboardManagementDataGridRowStyle" TargetType="DataGridRow">
        <Setter Property="Background" Value="White"/>
    </Style>

    <Style x:Key="DashboardWindowButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="44"/>
        <Setter Property="Height" Value="30"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="WindowButtonSurface" Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="WindowButtonSurface" Property="Background" Value="#16000000"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="WindowButtonSurface" Property="Background" Value="#22000000"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DashboardWindowCloseButtonStyle"
           TargetType="Button"
           BasedOn="{StaticResource DashboardWindowButtonStyle}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="CloseButtonSurface" Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="CloseButtonSurface" Property="Background" Value="#E53E3E"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="CloseButtonSurface" Property="Background" Value="#C53030"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DashboardSidebarNavButtonStyle" TargetType="Button">
        <Setter Property="Padding" Value="16,14"/>
        <Setter Property="MinHeight" Value="56"/>
        <Setter Property="Foreground" Value="{StaticResource DashboardTextMutedBrush}"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="NavButtonSurface"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="NavButtonSurface" Property="Background" Value="#F3F8FE"/>
                            <Setter TargetName="NavButtonSurface" Property="BorderBrush" Value="#E5EDF8"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="NavButtonSurface" Property="Opacity" Value="0.9"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DashboardSidebarNavSelectedButtonStyle"
           TargetType="Button"
           BasedOn="{StaticResource DashboardSidebarNavButtonStyle}">
        <Setter Property="Background" Value="#EAF4FF"/>
        <Setter Property="BorderBrush" Value="#D4E7FD"/>
        <Setter Property="Foreground" Value="{StaticResource DashboardPrimaryBrush}"/>
    </Style>

    <Style x:Key="DashboardSidebarIconBadgeStyle" TargetType="Border">
        <Setter Property="Width" Value="28"/>
        <Setter Property="Height" Value="28"/>
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="DashboardSidebarIconSelectedBadgeStyle"
           TargetType="Border"
           BasedOn="{StaticResource DashboardSidebarIconBadgeStyle}">
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style x:Key="DashboardSidebarIconGlyphStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="Foreground" Value="{StaticResource DashboardSidebarIconBrush}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="DashboardSidebarIconGlyphSelectedStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource DashboardSidebarIconGlyphStyle}">
        <Setter Property="Foreground" Value="{StaticResource DashboardPrimaryBrush}"/>
    </Style>

    <Style x:Key="DashboardSidebarNavTextStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="14,0,0,0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource DashboardTextMutedBrush}"/>
    </Style>

    <Style x:Key="DashboardSidebarNavTextSelectedStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource DashboardSidebarNavTextStyle}">
        <Setter Property="Foreground" Value="{StaticResource DashboardPrimaryBrush}"/>
    </Style>

    <Style x:Key="DashboardProfileTabControlStyle" TargetType="TabControl">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabControl">
                    <Grid KeyboardNavigation.TabNavigation="Local">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TabPanel Grid.Row="0"
                                  Margin="0,0,0,12"
                                  IsItemsHost="True"
                                  ClipToBounds="False"
                                  Background="Transparent"
                                  KeyboardNavigation.TabIndex="1"/>

                        <Border Grid.Row="1"
                                Background="Transparent"
                                BorderThickness="0">
                            <ContentPresenter x:Name="PART_SelectedContentHost"
                                              ContentSource="SelectedContent"/>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DashboardProfileTabItemStyle" TargetType="TabItem">
        <Setter Property="Margin" Value="0,0,10,0"/>
        <Setter Property="Padding" Value="16,9"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Panel.ZIndex" Value="0"/>
        <Setter Property="Foreground" Value="{StaticResource DashboardTextMutedBrush}"/>
        <Setter Property="Background" Value="#F5F8FC"/>
        <Setter Property="BorderBrush" Value="#BFD0E4"/>
        <Setter Property="BorderThickness" Value="1,1,1,1"/>
        <Setter Property="SnapsToDevicePixels" Value="False"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Grid SnapsToDevicePixels="True">
                        <Rectangle x:Name="TabSurface"
                                   RadiusX="6"
                                   RadiusY="6"
                                   Fill="{TemplateBinding Background}"
                                   Stroke="{TemplateBinding BorderBrush}"
                                   StrokeThickness="1"/>
                        <ContentPresenter ContentSource="Header"
                                          Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="TabSurface" Property="Fill" Value="#EDF4FC"/>
                            <Setter TargetName="TabSurface" Property="Stroke" Value="#AFC4DE"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Panel.ZIndex" Value="10"/>
                            <Setter Property="Foreground" Value="{StaticResource DashboardPrimaryBrush}"/>
                            <Setter TargetName="TabSurface" Property="Fill" Value="#E5F1FF"/>
                            <Setter TargetName="TabSurface" Property="Stroke" Value="#7CAAE0"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.55"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DashboardProfileSegmentButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="36"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#6D8097"/>
        <Setter Property="Background" Value="#F2F6FB"/>
        <Setter Property="BorderBrush" Value="#D7E1EE"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="SegmentSurface"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="7">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="SegmentSurface" Property="Background" Value="#ECF3FB"/>
                            <Setter TargetName="SegmentSurface" Property="BorderBrush" Value="#C8D8EB"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="SegmentSurface" Property="Opacity" Value="0.92"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DashboardProfileSegmentSelectedButtonStyle"
           TargetType="Button"
           BasedOn="{StaticResource DashboardProfileSegmentButtonStyle}">
        <Setter Property="Foreground" Value="{StaticResource DashboardPrimaryBrush}"/>
        <Setter Property="Background" Value="#E4F0FF"/>
        <Setter Property="BorderBrush" Value="#82AFE4"/>
    </Style>

    <Style x:Key="DashboardProfileSectionCardStyle" TargetType="Border">
        <Setter Property="Background" Value="#F8FBFF"/>
        <Setter Property="BorderBrush" Value="{StaticResource DashboardBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="16"/>
    </Style>

    <Style x:Key="DashboardProfileSectionTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource DashboardTextPrimaryBrush}"/>
    </Style>

    <Style x:Key="DashboardProfileSectionSubtitleStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,4,0,0"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{StaticResource DashboardTextMutedBrush}"/>
    </Style>

    <Style x:Key="DashboardProfileFieldLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource DashboardTextMutedBrush}"/>
    </Style>

    <Style x:Key="DashboardProfileFieldValueContainerStyle" TargetType="Border">
        <Setter Property="Margin" Value="0,6,0,0"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="#DEE7F3"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
    </Style>

    <Style x:Key="DashboardProfileFieldValueStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource DashboardTextPrimaryBrush}"/>
    </Style>

    <Style x:Key="DashboardProfileStatCardStyle" TargetType="Border">
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="Background" Value="#F2F8FF"/>
        <Setter Property="BorderBrush" Value="#D7E8FC"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="10"/>
    </Style>

    <Style x:Key="DashboardProfileStatValueStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="22"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource DashboardTextPrimaryBrush}"/>
    </Style>

    <Style x:Key="DashboardProfileTagBorderStyle" TargetType="Border">
        <Setter Property="Padding" Value="10,4"/>
        <Setter Property="CornerRadius" Value="999"/>
        <Setter Property="Background" Value="#EAF4FF"/>
        <Setter Property="BorderBrush" Value="#D4E7FD"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Margin" Value="0,0,8,0"/>
    </Style>

    <Style x:Key="DashboardHeaderIconButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="34"/>
        <Setter Property="Height" Value="34"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="HeaderIconSurface"
                            CornerRadius="8"
                            Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="HeaderIconSurface" Property="Background" Value="#EEF3F9"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="HeaderIconSurface" Property="Background" Value="#DFE8F2"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DashboardSearchTextBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="#F0F4F8"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="{StaticResource DashboardTextPrimaryBrush}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="36,8,12,8"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="SearchSurface"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                        <ScrollViewer x:Name="PART_ContentHost"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="SearchSurface" Property="BorderBrush" Value="{StaticResource DashboardPrimaryBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DashboardFilterComboBoxItemStyle" TargetType="ComboBoxItem">
        <Setter Property="Padding" Value="10,7"/>
        <Setter Property="Foreground" Value="{StaticResource DashboardTextPrimaryBrush}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="ItemSurface"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="ItemSurface" Property="Background" Value="#E8F1FC"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="ItemSurface" Property="Background" Value="#DCEBFD"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DashboardFilterComboToggleButtonStyle" TargetType="ToggleButton">
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border Background="Transparent">
                        <ContentPresenter/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DashboardFilterComboBoxStyle" TargetType="ComboBox">
        <Setter Property="Width" Value="148"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource DashboardTextPrimaryBrush}"/>
        <Setter Property="Background" Value="#F3F6FA"/>
        <Setter Property="BorderBrush" Value="#DFE7F1"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,0,28,0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="ItemContainerStyle" Value="{StaticResource DashboardFilterComboBoxItemStyle}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <Border x:Name="ComboSurface"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="24"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Margin="{TemplateBinding Padding}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"/>
                                <Path Grid.Column="1"
                                      Data="M 0 0 L 4 4 L 8 0"
                                      Stroke="#4F6176"
                                      StrokeThickness="1.6"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"/>
                            </Grid>
                        </Border>

                        <ToggleButton x:Name="ToggleButton"
                                      Style="{StaticResource DashboardFilterComboToggleButtonStyle}"
                                      IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                      ClickMode="Press"/>

                        <Popup x:Name="Popup"
                               Placement="Bottom"
                               AllowsTransparency="True"
                               Focusable="False"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               PopupAnimation="Fade">
                            <Border MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                    Margin="0,4,0,0"
                                    Background="White"
                                    BorderBrush="#DCE5F1"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <ScrollViewer Margin="0" SnapsToDevicePixels="True">
                                    <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ComboSurface" Property="BorderBrush" Value="#CFDAEA"/>
                        </Trigger>
                        <Trigger SourceName="ToggleButton" Property="IsChecked" Value="True">
                            <Setter TargetName="ComboSurface" Property="BorderBrush" Value="#BFD0E7"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DashboardCalendarDayButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="32"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="Margin" Value="1"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{StaticResource DashboardTextPrimaryBrush}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="DayButtonSurface"
                            Background="{TemplateBinding Background}"
                            CornerRadius="7">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="DayButtonSurface" Property="Background" Value="#EEF4FB"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DashboardCalendarSelectedDayButtonStyle"
           TargetType="Button"
           BasedOn="{StaticResource DashboardCalendarDayButtonStyle}">
        <Setter Property="Background" Value="{StaticResource DashboardPrimaryBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="DashboardCalendarButtonLargeStyle" TargetType="{x:Type CalendarButton}">
        <Setter Property="FontSize" Value="{DynamicResource DashboardCalendarHeaderFontSize}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="DashboardCalendarDayButtonLargeStyle" TargetType="{x:Type CalendarDayButton}">
        <Setter Property="FontSize" Value="{DynamicResource DashboardCalendarDayFontSize}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Width" Value="{DynamicResource DashboardCalendarDayWidth}"/>
        <Setter Property="Height" Value="{DynamicResource DashboardCalendarDayHeight}"/>
    </Style>

    <Style x:Key="DashboardPrimaryActionButtonStyle" TargetType="Button">
        <Setter Property="Padding" Value="14,8"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="Foreground" Value="{StaticResource DashboardPrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="PrimaryActionSurface"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="PrimaryActionSurface" Property="Background" Value="#F2F7FF"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="PrimaryActionSurface" Property="Background" Value="#E5EFFF"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
