<UserControl x:Class="StudentGradeBreakdownTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <StackPanel>
        <TextBlock Text="Assessment Breakdown"
                   Style="{StaticResource DashboardProfileSectionTitleStyle}"/>
        <TextBlock Text="Compare your component scores per subject before final grading."
                   Style="{StaticResource DashboardProfileSectionSubtitleStyle}"/>
        <TextBlock x:Name="GradeBreakdownStudentIdTextBlock"
                   Margin="0,8,0,0"
                   FontSize="12"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource DashboardTextMutedBrush}"/>

        <UniformGrid Margin="0,14,0,0"
                     Columns="3">
            <Border Style="{StaticResource DashboardProfileStatCardStyle}" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Quiz Avg"
                               Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                    <TextBlock x:Name="QuizAverageTextBlock"
                               Text="0.00"
                               Margin="0,4,0,0"
                               Style="{StaticResource DashboardProfileStatValueStyle}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DashboardProfileStatCardStyle}" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Project Avg"
                               Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                    <TextBlock x:Name="ProjectAverageTextBlock"
                               Text="0.00"
                               Margin="0,4,0,0"
                               Style="{StaticResource DashboardProfileStatValueStyle}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DashboardProfileStatCardStyle}">
                <StackPanel>
                    <TextBlock Text="Exam Avg"
                               Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                    <TextBlock x:Name="ExamAverageTextBlock"
                               Text="0.00"
                               Margin="0,4,0,0"
                               Style="{StaticResource DashboardProfileStatValueStyle}"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Margin="0,14,0,0"
                Style="{StaticResource DashboardProfileSectionCardStyle}">
            <StackPanel>
                <TextBlock Text="Component Scores"
                           Style="{StaticResource DashboardProfileSectionTitleStyle}"
                           FontSize="16"/>
                <TextBlock Text="Score distribution used to compute your term grade."
                           Style="{StaticResource DashboardProfileSectionSubtitleStyle}"/>
                <TextBlock x:Name="GradeBreakdownStatusTextBlock"
                           Margin="0,10,0,0"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource DashboardTextMutedBrush}"
                           TextWrapping="Wrap"/>

                <Grid Margin="0,14,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{StaticResource DashboardSoftSurfaceBrush}"
                            BorderBrush="{StaticResource DashboardSoftBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Subject"
                                       Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                            <TextBlock Grid.Column="1"
                                       Text="Quiz"
                                       Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                            <TextBlock Grid.Column="2"
                                       Text="Project"
                                       Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                            <TextBlock Grid.Column="3"
                                       Text="Midterm"
                                       Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                            <TextBlock Grid.Column="4"
                                       Text="Final"
                                       Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                        </Grid>
                    </Border>

                    <Border x:Name="GradeBreakdownEmptyStateBorder"
                            Grid.Row="1"
                            Margin="0,8,0,0"
                            Background="White"
                            BorderBrush="{StaticResource DashboardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12,11">
                        <TextBlock x:Name="GradeBreakdownEmptyTextBlock"
                                   Foreground="{StaticResource DashboardTextMutedBrush}"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <ItemsControl x:Name="GradeBreakdownItemsControl"
                                  Grid.Row="1"
                                  Margin="0,8,0,0"
                                  Visibility="Collapsed">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8"
                                        Background="White"
                                        BorderBrush="{StaticResource DashboardBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="12,11">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="1*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding SubjectName}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource DashboardTextPrimaryBrush}"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding QuizScore}"
                                                   Foreground="{StaticResource DashboardTextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding ProjectScore}"
                                                   Foreground="{StaticResource DashboardTextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding MidtermScore}"
                                                   Foreground="{StaticResource DashboardTextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="4"
                                                   Text="{Binding FinalExamScore}"
                                                   Foreground="{StaticResource DashboardTextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
