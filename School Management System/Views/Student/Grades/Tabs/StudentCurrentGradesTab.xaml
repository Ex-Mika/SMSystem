<UserControl x:Class="StudentCurrentGradesTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <StackPanel>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="Current Term Grades"
                           FontSize="22"
                           FontWeight="Bold"/>
                <TextBlock x:Name="CurrentGradesStudentIdTextBlock"
                           Margin="0,4,0,0"
                           FontSize="13"
                           Foreground="{StaticResource DashboardTextMutedBrush}"/>
            </StackPanel>

            <Border Grid.Column="1"
                    Padding="12,8"
                    CornerRadius="8"
                    Background="#F4F8FD"
                    BorderBrush="{StaticResource DashboardBorderBrush}"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Subjects"
                               FontSize="11"
                               Foreground="{StaticResource DashboardTextMutedBrush}"/>
                    <TextBlock Text="0"
                               FontSize="17"
                               FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Margin="0,14,0,0"
                BorderBrush="{StaticResource DashboardBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Subject"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource DashboardTextMutedBrush}"/>
                <TextBlock Grid.Column="1"
                           Text="Code"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource DashboardTextMutedBrush}"/>
                <TextBlock Grid.Column="2"
                           Text="Units"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource DashboardTextMutedBrush}"/>
                <TextBlock Grid.Column="3"
                           Text="Grade"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource DashboardTextMutedBrush}"/>

                <Rectangle Grid.Row="1"
                           Grid.ColumnSpan="4"
                           Height="1"
                           Fill="{StaticResource DashboardBorderBrush}"
                           Margin="0,10,0,10"/>

                <TextBlock Grid.Row="2" Text=" "/>
                <TextBlock Grid.Row="2" Grid.Column="1" Text=" "/>
                <TextBlock Grid.Row="2" Grid.Column="2" Text="0"/>
                <TextBlock Grid.Row="2" Grid.Column="3" Text="0"/>
            </Grid>
        </Border>
    </StackPanel>
</UserControl>
