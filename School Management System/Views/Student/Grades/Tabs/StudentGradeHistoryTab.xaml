<UserControl x:Class="StudentGradeHistoryTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <StackPanel>
        <TextBlock Text="Academic History"
                   Style="{StaticResource DashboardProfileSectionTitleStyle}"/>
        <TextBlock Text="Review your term-by-term performance and cumulative progress."
                   Style="{StaticResource DashboardProfileSectionSubtitleStyle}"/>
        <TextBlock x:Name="GradeHistoryStudentIdTextBlock"
                   Margin="0,8,0,0"
                   FontSize="12"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource DashboardTextMutedBrush}"/>

        <UniformGrid Margin="0,14,0,0"
                     Columns="3">
            <Border Style="{StaticResource DashboardProfileStatCardStyle}" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Terms Completed"
                               Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                    <TextBlock x:Name="TermsCompletedTextBlock"
                               Text="0"
                               Margin="0,4,0,0"
                               Style="{StaticResource DashboardProfileStatValueStyle}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DashboardProfileStatCardStyle}" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Cumulative GWA"
                               Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                    <TextBlock x:Name="CumulativeGwaTextBlock"
                               Text="0.00"
                               Margin="0,4,0,0"
                               Style="{StaticResource DashboardProfileStatValueStyle}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DashboardProfileStatCardStyle}">
                <StackPanel>
                    <TextBlock Text="Earned Units"
                               Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                    <TextBlock x:Name="EarnedUnitsTextBlock"
                               Text="0"
                               Margin="0,4,0,0"
                               Style="{StaticResource DashboardProfileStatValueStyle}"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Margin="0,14,0,0"
                Style="{StaticResource DashboardProfileSectionCardStyle}">
            <StackPanel>
                <TextBlock Text="Term Records"
                           Style="{StaticResource DashboardProfileSectionTitleStyle}"
                           FontSize="16"/>
                <TextBlock Text="Published term outcomes and scholastic standing."
                           Style="{StaticResource DashboardProfileSectionSubtitleStyle}"/>
                <TextBlock x:Name="GradeHistoryStatusTextBlock"
                           Margin="0,10,0,0"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource DashboardTextMutedBrush}"
                           TextWrapping="Wrap"/>

                <Grid Margin="0,14,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{StaticResource DashboardSoftSurfaceBrush}"
                            BorderBrush="{StaticResource DashboardSoftBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.8*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1.2*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Term"
                                       Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                            <TextBlock Grid.Column="1"
                                       Text="Units"
                                       Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                            <TextBlock Grid.Column="2"
                                       Text="GWA"
                                       Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                            <TextBlock Grid.Column="3"
                                       Text="Standing"
                                       Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                        </Grid>
                    </Border>

                    <Border x:Name="GradeHistoryEmptyStateBorder"
                            Grid.Row="1"
                            Margin="0,8,0,0"
                            Background="White"
                            BorderBrush="{StaticResource DashboardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12,11">
                        <TextBlock x:Name="GradeHistoryEmptyTextBlock"
                                   Foreground="{StaticResource DashboardTextMutedBrush}"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <ItemsControl x:Name="GradeHistoryItemsControl"
                                  Grid.Row="1"
                                  Margin="0,8,0,0"
                                  Visibility="Collapsed">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8"
                                        Background="White"
                                        BorderBrush="{StaticResource DashboardBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="12,11">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.8*"/>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="1.2*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding TermLabel}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource DashboardTextPrimaryBrush}"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Units}"
                                                   Foreground="{StaticResource DashboardTextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Gwa}"
                                                   Foreground="{StaticResource DashboardTextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                        <Border Grid.Column="3"
                                                HorizontalAlignment="Left"
                                                Padding="8,3"
                                                CornerRadius="999"
                                                Background="{StaticResource DashboardPrimarySoftBrush}"
                                                BorderBrush="{StaticResource DashboardSoftBorderBrush}"
                                                BorderThickness="1">
                                            <TextBlock Text="{Binding Standing}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource DashboardAccentTextBrush}"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
