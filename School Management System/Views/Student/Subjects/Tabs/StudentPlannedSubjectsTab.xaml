<UserControl x:Class="StudentPlannedSubjectsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <StackPanel>
        <TextBlock Text="Planned Subjects"
                   Style="{StaticResource DashboardProfileSectionTitleStyle}"/>
        <TextBlock Text="Queue subjects for your next enrollment cycle."
                   Style="{StaticResource DashboardProfileSectionSubtitleStyle}"/>

        <UniformGrid Margin="0,14,0,0"
                     Columns="2">
            <Border Style="{StaticResource DashboardProfileStatCardStyle}" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Planned Count"
                               Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                    <TextBlock Text="0"
                               Margin="0,4,0,0"
                               Style="{StaticResource DashboardProfileStatValueStyle}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DashboardProfileStatCardStyle}">
                <StackPanel>
                    <TextBlock Text="Planned Units"
                               Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                    <TextBlock Text="0"
                               Margin="0,4,0,0"
                               Style="{StaticResource DashboardProfileStatValueStyle}"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Margin="0,14,0,0"
                Style="{StaticResource DashboardProfileSectionCardStyle}">
            <StackPanel>
                <TextBlock Text="Next-Term Queue"
                           Style="{StaticResource DashboardProfileSectionTitleStyle}"
                           FontSize="16"/>
                <TextBlock Text="Subjects listed here can be finalized during enrollment."
                           Style="{StaticResource DashboardProfileSectionSubtitleStyle}"/>

                <Grid Margin="0,14,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="#F5F9FF"
                            BorderBrush="#DCE8F8"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="0.9*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Subject"
                                       Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                            <TextBlock Grid.Column="1"
                                       Text="Code"
                                       Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                            <TextBlock Grid.Column="2"
                                       Text="Units"
                                       Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Margin="0,8,0,0"
                            Background="White"
                            BorderBrush="{StaticResource DashboardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12,11">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="0.9*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="No planned subjects yet."
                                       Foreground="{StaticResource DashboardTextMutedBrush}"/>
                            <TextBlock Grid.Column="1"
                                       Text="--"
                                       Foreground="{StaticResource DashboardTextMutedBrush}"/>
                            <TextBlock Grid.Column="2"
                                       Text="0"
                                       Foreground="{StaticResource DashboardTextMutedBrush}"/>
                        </Grid>
                    </Border>
                </Grid>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
