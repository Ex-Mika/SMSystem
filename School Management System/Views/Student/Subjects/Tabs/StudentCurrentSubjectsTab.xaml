<UserControl x:Class="StudentCurrentSubjectsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <StackPanel>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="Current Enrollment"
                           Style="{StaticResource DashboardProfileSectionTitleStyle}"/>
                <TextBlock Text="Review your active subjects and unit distribution for this term."
                           Style="{StaticResource DashboardProfileSectionSubtitleStyle}"/>
                <TextBlock x:Name="CurrentStudentIdTextBlock"
                           Margin="0,8,0,0"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource DashboardTextMutedBrush}"/>
            </StackPanel>

             <WrapPanel Grid.Column="1"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="14,0,0,0">
                <Border Style="{StaticResource DashboardProfileStatCardStyle}" Margin="0,0,8,0">
                    <StackPanel MinWidth="118">
                        <TextBlock Text="Total Units"
                                   Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                        <TextBlock x:Name="CurrentTotalUnitsTextBlock"
                                   Text="0"
                                   Margin="0,4,0,0"
                                   Style="{StaticResource DashboardProfileStatValueStyle}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource DashboardProfileStatCardStyle}">
                    <StackPanel MinWidth="118">
                        <TextBlock Text="Section"
                                   Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                        <TextBlock x:Name="CurrentSectionTextBlock"
                                   Text="Not Selected"
                                   Margin="0,4,0,0"
                                   Style="{StaticResource DashboardProfileStatValueStyle}"/>
                    </StackPanel>
                </Border>
            </WrapPanel>
        </Grid>

        <Border Margin="0,14,0,0"
                Style="{StaticResource DashboardProfileSectionCardStyle}">
            <StackPanel>
                <TextBlock Text="Current Class List"
                           Style="{StaticResource DashboardProfileSectionTitleStyle}"
                           FontSize="16"/>
                <TextBlock Text="Subjects currently tagged to your active enrollment."
                           Style="{StaticResource DashboardProfileSectionSubtitleStyle}"/>
                <TextBlock x:Name="CurrentSubjectsStatusTextBlock"
                           Margin="0,10,0,0"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource DashboardTextMutedBrush}"
                           TextWrapping="Wrap"/>

                <Grid Margin="0,14,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{StaticResource DashboardSoftSurfaceBrush}"
                            BorderBrush="{StaticResource DashboardSoftBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="0.9*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Subject"
                                       Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                            <TextBlock Grid.Column="1"
                                       Text="Code"
                                       Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                            <TextBlock Grid.Column="2"
                                       Text="Units"
                                       Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                            <TextBlock Grid.Column="3"
                                       Text="Status"
                                       Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                        </Grid>
                    </Border>

                    <Border x:Name="CurrentSubjectsEmptyStateBorder"
                            Grid.Row="1"
                            Margin="0,8,0,0"
                            Background="White"
                            BorderBrush="{StaticResource DashboardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12,11">
                        <TextBlock x:Name="CurrentSubjectsEmptyTextBlock"
                                   Foreground="{StaticResource DashboardTextMutedBrush}"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <ItemsControl x:Name="CurrentSubjectsItemsControl"
                                  Grid.Row="1"
                                  Margin="0,8,0,0"
                                  Visibility="Collapsed">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8"
                                        Background="White"
                                        BorderBrush="{StaticResource DashboardBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="12,11">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="1.2*"/>
                                            <ColumnDefinition Width="0.9*"/>
                                            <ColumnDefinition Width="1*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="{Binding SubjectName}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource DashboardTextPrimaryBrush}"
                                                   TextWrapping="Wrap"/>

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding SubjectCode}"
                                                   Foreground="{StaticResource DashboardTextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Units}"
                                                   Foreground="{StaticResource DashboardTextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>

                                        <Border Grid.Column="3"
                                                HorizontalAlignment="Left"
                                                Padding="8,3"
                                                CornerRadius="999"
                                                Background="{StaticResource DashboardPrimarySoftBrush}"
                                                BorderBrush="{StaticResource DashboardSoftBorderBrush}"
                                                BorderThickness="1">
                                            <TextBlock Text="{Binding StatusText}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource DashboardAccentTextBrush}"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
