<UserControl x:Class="StudentProfileAccountTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0"
                Grid.Column="0"
                Margin="0,0,10,12"
                Style="{StaticResource DashboardProfileSectionCardStyle}">
            <StackPanel>
                <TextBlock Text="Contact &amp; Access"
                           Style="{StaticResource DashboardProfileSectionTitleStyle}"/>
                <TextBlock Text="Primary channels used for notifications and updates."
                           Style="{StaticResource DashboardProfileSectionSubtitleStyle}"/>

                <StackPanel Margin="0,14,0,0">
                    <TextBlock Text="Email"
                               Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                    <Border Style="{StaticResource DashboardProfileFieldValueContainerStyle}">
                        <TextBlock Style="{StaticResource DashboardProfileFieldValueStyle}"
                                   Text="Not set"/>
                    </Border>
                </StackPanel>

                <StackPanel Margin="0,10,0,0">
                    <TextBlock Text="Contact Number"
                               Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                    <Border Style="{StaticResource DashboardProfileFieldValueContainerStyle}">
                        <TextBlock Style="{StaticResource DashboardProfileFieldValueStyle}"
                                   Text="Not set"/>
                    </Border>
                </StackPanel>

                <StackPanel Margin="0,10,0,0">
                    <TextBlock Text="Last Login"
                               Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                    <Border Style="{StaticResource DashboardProfileFieldValueContainerStyle}">
                        <TextBlock Style="{StaticResource DashboardProfileFieldValueStyle}"
                                   Text="--"/>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="0"
                Grid.Column="1"
                Margin="10,0,0,12"
                Style="{StaticResource DashboardProfileSectionCardStyle}">
            <StackPanel>
                <TextBlock Text="Security"
                           Style="{StaticResource DashboardProfileSectionTitleStyle}"/>
                <TextBlock Text="Account protection and sign-in status."
                           Style="{StaticResource DashboardProfileSectionSubtitleStyle}"/>

                <StackPanel Margin="0,14,0,0">
                    <TextBlock Text="Password Last Updated"
                               Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                    <Border Style="{StaticResource DashboardProfileFieldValueContainerStyle}">
                        <TextBlock Style="{StaticResource DashboardProfileFieldValueStyle}"
                                   Text="--"/>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Grid.ColumnSpan="2"
                Style="{StaticResource DashboardProfileSectionCardStyle}">
            <StackPanel>
                <TextBlock Text="Quick Actions"
                           Style="{StaticResource DashboardProfileSectionTitleStyle}"/>
                <TextBlock Text="Frequently used account management options."
                           Style="{StaticResource DashboardProfileSectionSubtitleStyle}"/>

                <WrapPanel Margin="0,14,0,0">
                    <Button Width="170"
                            Height="34"
                            Margin="0,0,10,8"
                            Style="{StaticResource DashboardPrimaryActionButtonStyle}"
                            Content="Change Password"/>
                </WrapPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
