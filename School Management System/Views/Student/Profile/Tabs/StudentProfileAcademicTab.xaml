<UserControl x:Class="StudentProfileAcademicTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0"
                Grid.Column="0"
                Margin="0,0,10,12"
                Style="{StaticResource DashboardProfileSectionCardStyle}">
            <StackPanel>
                <TextBlock Text="Enrollment Snapshot"
                           Style="{StaticResource DashboardProfileSectionTitleStyle}"/>
                <TextBlock Text="Program and class placement for the current term."
                           Style="{StaticResource DashboardProfileSectionSubtitleStyle}"/>

                <StackPanel Margin="0,14,0,0">
                    <TextBlock Text="Program"
                               Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                    <Border Style="{StaticResource DashboardProfileFieldValueContainerStyle}">
                        <TextBlock x:Name="ProgramValueTextBlock"
                                   Style="{StaticResource DashboardProfileFieldValueStyle}"
                                    Text="Not set"/>
                    </Border>
                </StackPanel>

                <StackPanel Margin="0,10,0,0">
                    <TextBlock Text="Year Level"
                               Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                    <Border Style="{StaticResource DashboardProfileFieldValueContainerStyle}">
                        <TextBlock x:Name="YearLevelValueTextBlock"
                                   Style="{StaticResource DashboardProfileFieldValueStyle}"
                                    Text="Not set"/>
                    </Border>
                </StackPanel>

                <StackPanel Margin="0,10,0,0">
                    <TextBlock Text="Section"
                               Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                    <Border Style="{StaticResource DashboardProfileFieldValueContainerStyle}">
                        <TextBlock x:Name="SectionValueTextBlock"
                                   Style="{StaticResource DashboardProfileFieldValueStyle}"
                                    Text="Not set"/>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="0"
                Grid.Column="1"
                Margin="10,0,0,12"
                Style="{StaticResource DashboardProfileSectionCardStyle}">
            <StackPanel>
                <TextBlock Text="Performance"
                           Style="{StaticResource DashboardProfileSectionTitleStyle}"/>
                <TextBlock Text="Current academic standing and unit load."
                           Style="{StaticResource DashboardProfileSectionSubtitleStyle}"/>

                <UniformGrid Columns="2" Margin="0,14,0,0">
                    <Border Style="{StaticResource DashboardProfileStatCardStyle}" Margin="0,0,6,0">
                        <StackPanel>
                            <TextBlock Text="GPA" Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                            <TextBlock Text="--" Margin="0,4,0,0" Style="{StaticResource DashboardProfileStatValueStyle}"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource DashboardProfileStatCardStyle}" Margin="6,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Units" Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                            <TextBlock Text="--" Margin="0,4,0,0" Style="{StaticResource DashboardProfileStatValueStyle}"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <StackPanel Margin="0,10,0,0">
                    <TextBlock Text="Academic Adviser"
                               Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                    <Border Style="{StaticResource DashboardProfileFieldValueContainerStyle}">
                        <TextBlock Style="{StaticResource DashboardProfileFieldValueStyle}"
                                   Text="Not assigned"/>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>

        
    </Grid>
</UserControl>
