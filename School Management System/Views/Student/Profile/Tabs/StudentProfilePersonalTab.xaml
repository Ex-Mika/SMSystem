<UserControl x:Class="StudentProfilePersonalTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0"
                Grid.Column="0"
                Margin="0,0,10,12"
                Style="{StaticResource DashboardProfileSectionCardStyle}">
            <StackPanel>
                <TextBlock Text="Identity"
                           Style="{StaticResource DashboardProfileSectionTitleStyle}"/>
                <TextBlock Text="Primary personal details used in school records."
                           Style="{StaticResource DashboardProfileSectionSubtitleStyle}"/>

                <StackPanel Margin="0,14,0,0">
                    <TextBlock Text="Student ID"
                               Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                    <Border Style="{StaticResource DashboardProfileFieldValueContainerStyle}">
                        <TextBlock x:Name="StudentIdValueTextBlock"
                                   Style="{StaticResource DashboardProfileFieldValueStyle}"
                                   Text=""/>
                    </Border>
                </StackPanel>

                <StackPanel Margin="0,10,0,0">
                    <TextBlock Text="Full Name"
                               Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                    <Border Style="{StaticResource DashboardProfileFieldValueContainerStyle}">
                        <TextBlock x:Name="StudentNameValueTextBlock"
                                   Style="{StaticResource DashboardProfileFieldValueStyle}"
                                   Text=""/>
                    </Border>
                </StackPanel>

                <StackPanel Margin="0,10,0,0">
                    <TextBlock Text="Date of Birth"
                               Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                    <Border Style="{StaticResource DashboardProfileFieldValueContainerStyle}">
                        <TextBlock Style="{StaticResource DashboardProfileFieldValueStyle}"
                                   Text="Not set"/>
                    </Border>
                </StackPanel>

                <StackPanel Margin="0,10,0,0">
                    <TextBlock Text="Sex"
                               Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                    <Border Style="{StaticResource DashboardProfileFieldValueContainerStyle}">
                        <TextBlock Style="{StaticResource DashboardProfileFieldValueStyle}"
                                   Text="Not set"/>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="0"
                Grid.Column="1"
                Margin="10,0,0,12"
                Style="{StaticResource DashboardProfileSectionCardStyle}">
            <StackPanel>
                <TextBlock Text="Contact &amp; Residence"
                           Style="{StaticResource DashboardProfileSectionTitleStyle}"/>
                <TextBlock Text="Current communication and home address information."
                           Style="{StaticResource DashboardProfileSectionSubtitleStyle}"/>

                <StackPanel Margin="0,14,0,0">
                    <TextBlock Text="Address"
                               Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                    <Border Style="{StaticResource DashboardProfileFieldValueContainerStyle}">
                        <TextBlock Style="{StaticResource DashboardProfileFieldValueStyle}"
                                   Text="No address on file"
                                   TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>

                <StackPanel Margin="0,10,0,0">
                    <TextBlock Text="City / Province"
                               Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                    <Border Style="{StaticResource DashboardProfileFieldValueContainerStyle}">
                        <TextBlock Style="{StaticResource DashboardProfileFieldValueStyle}"
                                   Text="Not set"/>
                    </Border>
                </StackPanel>

                <StackPanel Margin="0,10,0,0">
                    <TextBlock Text="Emergency Contact"
                               Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                    <Border Style="{StaticResource DashboardProfileFieldValueContainerStyle}">
                        <TextBlock Style="{StaticResource DashboardProfileFieldValueStyle}"
                                   Text="Not set"/>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Grid.ColumnSpan="2"
                Style="{StaticResource DashboardProfileSectionCardStyle}">
            <StackPanel>
                <TextBlock Text="Notes"
                           Style="{StaticResource DashboardProfileSectionTitleStyle}"/>
                <TextBlock Text="Complete your personal details to improve identity verification and communication."
                           Margin="0,8,0,0"
                           FontSize="13"
                           Foreground="{StaticResource DashboardTextMutedBrush}"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
