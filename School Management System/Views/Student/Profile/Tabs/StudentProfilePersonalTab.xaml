<UserControl x:Class="StudentProfilePersonalTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0"
                Grid.Column="0"
                Margin="0,0,10,12"
                Style="{StaticResource DashboardProfileSectionCardStyle}">
            <StackPanel>
                <TextBlock Text="Identity"
                           Style="{StaticResource DashboardProfileSectionTitleStyle}"/>
                <TextBlock Text="Update the name details attached to your student record."
                           Style="{StaticResource DashboardProfileSectionSubtitleStyle}"/>

                <StackPanel Margin="0,14,0,0">
                    <TextBlock Text="Student ID"
                               Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                    <Border Style="{StaticResource DashboardProfileFieldValueContainerStyle}">
                        <TextBlock x:Name="StudentIdValueTextBlock"
                                   Style="{StaticResource DashboardProfileFieldValueStyle}"
                                   Text=""/>
                    </Border>
                </StackPanel>

                <StackPanel Margin="0,10,0,0">
                    <TextBlock Text="First Name"
                               Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                    <Border x:Name="FirstNameValueBorder"
                            Style="{StaticResource DashboardProfileFieldValueContainerStyle}">
                        <TextBlock x:Name="FirstNameValueTextBlock"
                                   Style="{StaticResource DashboardProfileFieldValueStyle}"
                                   Text=""/>
                    </Border>
                    <TextBox x:Name="FirstNameEditTextBox"
                             Margin="0,6,0,0"
                             Style="{StaticResource DashboardProfileInputTextBoxStyle}"
                             TextChanged="EditableNameTextBox_TextChanged"
                             Visibility="Collapsed"/>
                </StackPanel>

                <StackPanel Margin="0,10,0,0">
                    <TextBlock Text="Middle Name"
                               Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                    <Border x:Name="MiddleNameValueBorder"
                            Style="{StaticResource DashboardProfileFieldValueContainerStyle}">
                        <TextBlock x:Name="MiddleNameValueTextBlock"
                                   Style="{StaticResource DashboardProfileFieldValueStyle}"
                                   Text=""/>
                    </Border>
                    <TextBox x:Name="MiddleNameEditTextBox"
                             Margin="0,6,0,0"
                             Style="{StaticResource DashboardProfileInputTextBoxStyle}"
                             TextChanged="EditableNameTextBox_TextChanged"
                             Visibility="Collapsed"/>
                </StackPanel>

                <StackPanel Margin="0,10,0,0">
                    <TextBlock Text="Last Name"
                               Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                    <Border x:Name="LastNameValueBorder"
                            Style="{StaticResource DashboardProfileFieldValueContainerStyle}">
                        <TextBlock x:Name="LastNameValueTextBlock"
                                   Style="{StaticResource DashboardProfileFieldValueStyle}"
                                   Text=""/>
                    </Border>
                    <TextBox x:Name="LastNameEditTextBox"
                             Margin="0,6,0,0"
                             Style="{StaticResource DashboardProfileInputTextBoxStyle}"
                             TextChanged="EditableNameTextBox_TextChanged"
                             Visibility="Collapsed"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="0"
                Grid.Column="1"
                Margin="10,0,0,12"
                Style="{StaticResource DashboardProfileSectionCardStyle}">
            <StackPanel>
                <TextBlock Text="Profile Photo"
                           Style="{StaticResource DashboardProfileSectionTitleStyle}"/>
                <TextBlock Text="Choose the photo shown across your student dashboard."
                           Style="{StaticResource DashboardProfileSectionSubtitleStyle}"/>

                <Border x:Name="StudentPhotoAvatarBorder"
                        Width="118"
                        Height="118"
                        Margin="0,16,0,0"
                        HorizontalAlignment="Left"
                        CornerRadius="59"
                        Background="{StaticResource DashboardAvatarSurfaceBrush}"
                        BorderBrush="{StaticResource DashboardBorderBrush}"
                        BorderThickness="1">
                    <TextBlock x:Name="StudentPhotoInitialTextBlock"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="42"
                               FontWeight="Bold"
                               Foreground="{StaticResource DashboardAvatarForegroundBrush}"
                               Text="S"/>
                </Border>

                <TextBlock x:Name="StudentPhotoStatusTextBlock"
                           Margin="0,12,0,0"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource DashboardTextMutedBrush}"
                           TextWrapping="Wrap"/>

                <WrapPanel Margin="0,14,0,0">
                    <Button x:Name="BrowseStudentPhotoButton"
                            Width="120"
                            Height="34"
                            Margin="0,0,10,8"
                            Style="{StaticResource DashboardPrimaryActionButtonStyle}"
                            Click="BrowseStudentPhotoButton_Click"
                            Content="Browse Photo"
                            Visibility="Collapsed"/>
                    <Button x:Name="ClearStudentPhotoButton"
                            Width="100"
                            Height="34"
                            Margin="0,0,0,8"
                            Style="{StaticResource DashboardSecondaryActionButtonStyle}"
                            Click="ClearStudentPhotoButton_Click"
                            Content="Clear Photo"
                            Visibility="Collapsed"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Grid.ColumnSpan="2"
                Style="{StaticResource DashboardProfileSectionCardStyle}">
            <StackPanel>
                <TextBlock Text="Editing Notes"
                           Style="{StaticResource DashboardProfileSectionTitleStyle}"/>
                <TextBlock x:Name="ProfilePersonalNotesTextBlock"
                           Margin="0,8,0,0"
                           FontSize="13"
                           Foreground="{StaticResource DashboardTextMutedBrush}"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
