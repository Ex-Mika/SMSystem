<UserControl x:Class="StudentConsultationScheduleTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <StackPanel>
        <TextBlock Text="Submission"
                   Style="{StaticResource DashboardProfileSectionTitleStyle}"/>
        <TextBlock Text="Finalize your enrollment details and send your request for approval."
                   Style="{StaticResource DashboardProfileSectionSubtitleStyle}"/>

        <UniformGrid Margin="0,14,0,0"
                     Columns="2">
            <Border Style="{StaticResource DashboardProfileStatCardStyle}" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Requirements Complete"
                               Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                    <TextBlock Text="0%"
                               Margin="0,4,0,0"
                               Style="{StaticResource DashboardProfileStatValueStyle}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DashboardProfileStatCardStyle}">
                <StackPanel>
                    <TextBlock Text="Adviser Approval"
                               Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                    <TextBlock Text="Pending"
                               Margin="0,4,0,0"
                               Style="{StaticResource DashboardProfileStatValueStyle}"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Margin="0,14,0,0"
                Style="{StaticResource DashboardProfileSectionCardStyle}">
            <StackPanel>
                <TextBlock Text="Enrollment Checklist"
                           Style="{StaticResource DashboardProfileSectionTitleStyle}"
                           FontSize="16"/>
                <TextBlock Text="Complete all required steps before submitting your load."
                           Style="{StaticResource DashboardProfileSectionSubtitleStyle}"/>

                <Grid Margin="0,14,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="#F5F9FF"
                            BorderBrush="#DCE8F8"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.8*"/>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="1.2*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Requirement"
                                       Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                            <TextBlock Grid.Column="1"
                                       Text="Status"
                                       Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                            <TextBlock Grid.Column="2"
                                       Text="Updated"
                                       Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                            <TextBlock Grid.Column="3"
                                       Text="Notes"
                                       Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Margin="0,8,0,0"
                            Background="White"
                            BorderBrush="{StaticResource DashboardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12,11">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.8*"/>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="1.2*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="No checklist generated."
                                       Foreground="{StaticResource DashboardTextMutedBrush}"/>
                            <TextBlock Grid.Column="1"
                                       Text="--"
                                       Foreground="{StaticResource DashboardTextMutedBrush}"/>
                            <TextBlock Grid.Column="2"
                                       Text="--"
                                       Foreground="{StaticResource DashboardTextMutedBrush}"/>
                            <Border Grid.Column="3"
                                    HorizontalAlignment="Left"
                                    Padding="8,3"
                                    CornerRadius="999"
                                    Background="#EFF4FB"
                                    BorderBrush="#D4DFED"
                                    BorderThickness="1">
                                <TextBlock Text="Pending"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource DashboardTextMutedBrush}"/>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Width="124"
                            Height="36"
                            Style="{StaticResource DashboardPrimaryActionButtonStyle}"
                            Background="#EFF4FB"
                            Foreground="{StaticResource DashboardTextMutedBrush}"
                            Content="Save Draft"/>

                    <Button Grid.Column="1"
                            Margin="10,0,0,0"
                            Width="172"
                            Height="36"
                            Style="{StaticResource DashboardPrimaryActionButtonStyle}"
                            Content="Submit Enrollment"/>
                </Grid>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
