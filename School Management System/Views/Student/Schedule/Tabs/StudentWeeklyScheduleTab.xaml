<UserControl x:Class="StudentWeeklyScheduleTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:School_Management_System"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="Weekly Schedule"
                           Style="{StaticResource DashboardProfileSectionTitleStyle}"/>
                <TextBlock Text="Review your Monday to Friday class timetable for the active term."
                           Style="{StaticResource DashboardProfileSectionSubtitleStyle}"/>
                <TextBlock x:Name="WeeklyScheduleStudentIdTextBlock"
                           Margin="0,8,0,0"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource DashboardTextMutedBrush}"/>
                <TextBlock x:Name="WeeklyScheduleStatusTextBlock"
                           Margin="0,6,0,0"
                           FontSize="12"
                           Foreground="{StaticResource DashboardTextMutedBrush}"
                           Text="No student schedule loaded."
                           TextWrapping="Wrap"/>
            </StackPanel>

            <WrapPanel Grid.Column="1"
                       Margin="14,0,0,0"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Top">
                <Border Margin="0,0,8,0"
                        Style="{StaticResource DashboardProfileStatCardStyle}">
                    <StackPanel MinWidth="118">
                        <TextBlock Text="Assigned Slots"
                                   Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                        <TextBlock x:Name="WeeklyScheduleSlotCountTextBlock"
                                   Margin="0,4,0,0"
                                   Text="0"
                                   Style="{StaticResource DashboardProfileStatValueStyle}"/>
                    </StackPanel>
                </Border>
                <Border Margin="0,0,8,0"
                        Style="{StaticResource DashboardProfileStatCardStyle}">
                    <StackPanel MinWidth="118">
                        <TextBlock Text="Active Days"
                                   Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                        <TextBlock x:Name="WeeklyScheduleDayCountTextBlock"
                                   Margin="0,4,0,0"
                                   Text="0"
                                   Style="{StaticResource DashboardProfileStatValueStyle}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource DashboardProfileStatCardStyle}">
                    <StackPanel MinWidth="140">
                        <TextBlock Text="Section"
                                   Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                        <TextBlock x:Name="WeeklyScheduleSectionTextBlock"
                                    Margin="0,4,0,0"
                                    Text="--"
                                    Style="{StaticResource DashboardProfileStatValueStyle}"/>
                    </StackPanel>
                </Border>
            </WrapPanel>
        </Grid>

        <Border Grid.Row="1"
                Margin="0,14,0,0"
                Style="{StaticResource DashboardProfileSectionCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="Class Timetable"
                               FontSize="16"
                               Style="{StaticResource DashboardProfileSectionTitleStyle}"/>
                    <TextBlock Text="Monday to Friday schedule sorted by time, using the same timetable layout as scheduling."
                               Style="{StaticResource DashboardProfileSectionSubtitleStyle}"/>
                </StackPanel>

                <Border Grid.Row="1"
                        Margin="0,14,0,0"
                        BorderBrush="{StaticResource DashboardBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        local:RoundedClipHelper.CornerRadius="8"
                        ClipToBounds="True">
                    <DataGrid x:Name="StudentTimetableDataGrid"
                              Style="{StaticResource DashboardManagementDataGridStyle}"
                              ColumnHeaderStyle="{StaticResource DashboardManagementDataGridHeaderStyle}"
                              CellStyle="{StaticResource DashboardManagementDataGridCellStyle}"
                              RowStyle="{StaticResource DashboardManagementDataGridRowStyle}"
                              BorderThickness="0"
                              ColumnWidth="*"
                              HeadersVisibility="Column"
                              RowHeaderWidth="0"
                              CanUserSortColumns="False"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              SelectionUnit="Cell"
                              SelectionMode="Single"
                              MinHeight="280"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
