<UserControl x:Class="StudentWeeklyScheduleTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <StackPanel>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="Weekly Timetable"
                           Style="{StaticResource DashboardProfileSectionTitleStyle}"/>
                <TextBlock Text="Your regular classes organized by day and room."
                           Style="{StaticResource DashboardProfileSectionSubtitleStyle}"/>
                <TextBlock x:Name="WeeklyScheduleStudentIdTextBlock"
                           Margin="0,8,0,0"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource DashboardTextMutedBrush}"/>
            </StackPanel>

            <WrapPanel Grid.Column="1"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Top"
                       Margin="14,0,0,0">
                <Border Style="{StaticResource DashboardProfileStatCardStyle}" Margin="0,0,8,0">
                    <StackPanel MinWidth="118">
                        <TextBlock Text="This Week"
                                   Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                        <TextBlock Text="0"
                                   Margin="0,4,0,0"
                                   Style="{StaticResource DashboardProfileStatValueStyle}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource DashboardProfileStatCardStyle}">
                    <StackPanel MinWidth="118">
                        <TextBlock Text="Active Rooms"
                                   Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                        <TextBlock Text="0"
                                   Margin="0,4,0,0"
                                   Style="{StaticResource DashboardProfileStatValueStyle}"/>
                    </StackPanel>
                </Border>
            </WrapPanel>
        </Grid>

        <Border Margin="0,14,0,0"
                Style="{StaticResource DashboardProfileSectionCardStyle}">
            <StackPanel>
                <TextBlock Text="Weekly Class List"
                           Style="{StaticResource DashboardProfileSectionTitleStyle}"
                           FontSize="16"/>
                <TextBlock Text="Chronological view of your regular class meetings."
                           Style="{StaticResource DashboardProfileSectionSubtitleStyle}"/>

                <Grid Margin="0,14,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="#F5F9FF"
                            BorderBrush="#DCE8F8"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="1.3*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Day"
                                       Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                            <TextBlock Grid.Column="1"
                                       Text="Subject"
                                       Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                            <TextBlock Grid.Column="2"
                                       Text="Time"
                                       Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                            <TextBlock Grid.Column="3"
                                       Text="Room"
                                       Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Margin="0,8,0,0"
                            Background="White"
                            BorderBrush="{StaticResource DashboardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12,11">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="1.3*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="No weekly sessions loaded."
                                       Foreground="{StaticResource DashboardTextMutedBrush}"/>
                            <TextBlock Grid.Column="1"
                                       Text="--"
                                       Foreground="{StaticResource DashboardTextMutedBrush}"/>
                            <TextBlock Grid.Column="2"
                                       Text="--"
                                       Foreground="{StaticResource DashboardTextMutedBrush}"/>
                            <TextBlock Grid.Column="3"
                                       Text="--"
                                       Foreground="{StaticResource DashboardTextMutedBrush}"/>
                        </Grid>
                    </Border>
                </Grid>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
