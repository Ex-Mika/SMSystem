<UserControl x:Class="StudentExamScheduleTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <StackPanel>
        <TextBlock Text="Selected Load"
                   Style="{StaticResource DashboardProfileSectionTitleStyle}"/>
        <TextBlock Text="Review the subjects currently added to your enrollment draft."
                   Style="{StaticResource DashboardProfileSectionSubtitleStyle}"/>

        <UniformGrid Margin="0,14,0,0"
                     Columns="3">
            <Border Style="{StaticResource DashboardProfileStatCardStyle}" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Selected Subjects"
                               Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                    <TextBlock Text="0"
                               Margin="0,4,0,0"
                               Style="{StaticResource DashboardProfileStatValueStyle}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DashboardProfileStatCardStyle}" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Total Units"
                               Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                    <TextBlock Text="0"
                               Margin="0,4,0,0"
                               Style="{StaticResource DashboardProfileStatValueStyle}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DashboardProfileStatCardStyle}">
                <StackPanel>
                    <TextBlock Text="Conflicts"
                               Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                    <TextBlock Text="0"
                               Margin="0,4,0,0"
                               Style="{StaticResource DashboardProfileStatValueStyle}"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Margin="0,14,0,0"
                Style="{StaticResource DashboardProfileSectionCardStyle}">
            <StackPanel>
                <TextBlock Text="Chosen Subjects"
                           Style="{StaticResource DashboardProfileSectionTitleStyle}"
                           FontSize="16"/>
                <TextBlock Text="Edit your selected sections before final submission."
                           Style="{StaticResource DashboardProfileSectionSubtitleStyle}"/>

                <Grid Margin="0,14,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="#F5F9FF"
                            BorderBrush="#DCE8F8"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1.4*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1.1*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Subject"
                                       Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                            <TextBlock Grid.Column="1"
                                       Text="Section"
                                       Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                            <TextBlock Grid.Column="2"
                                       Text="Units"
                                       Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                            <TextBlock Grid.Column="3"
                                       Text="Action"
                                       Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Margin="0,8,0,0"
                            Background="White"
                            BorderBrush="{StaticResource DashboardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12,11">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1.4*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1.1*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="No subjects selected yet."
                                       Foreground="{StaticResource DashboardTextMutedBrush}"/>
                            <TextBlock Grid.Column="1"
                                       Text="--"
                                       Foreground="{StaticResource DashboardTextMutedBrush}"/>
                            <TextBlock Grid.Column="2"
                                       Text="0"
                                       Foreground="{StaticResource DashboardTextMutedBrush}"/>
                            <Border Grid.Column="3"
                                    HorizontalAlignment="Left"
                                    Padding="8,3"
                                    CornerRadius="999"
                                    Background="#EFF4FB"
                                    BorderBrush="#D4DFED"
                                    BorderThickness="1">
                                <TextBlock Text="Remove"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource DashboardTextMutedBrush}"/>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
