<UserControl x:Class="StudentScheduleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:School_Management_System"
             mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="20,18,20,22">
            <Border Style="{StaticResource DashboardCardBorderStyle}">
                <Grid Margin="22">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0"
                                Grid.Column="0"
                                Margin="0,0,18,0">
                        <TextBlock Text="Class Schedule"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource DashboardTextMutedBrush}"/>
                        <TextBlock Text="Student Timetable"
                                   Margin="0,4,0,0"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource DashboardTextPrimaryBrush}"/>
                        <TextBlock Text="Review your timetable, enroll in eligible subjects, and prepare your load for submission."
                                   Margin="0,6,0,0"
                                   FontSize="13"
                                   Foreground="{StaticResource DashboardTextMutedBrush}"
                                   TextWrapping="Wrap"/>
                        <TextBlock x:Name="ScheduleStudentIdTextBlock"
                                   Text=""
                                   Margin="0,8,0,0"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource DashboardTextMutedBrush}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="0"
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top">
                        <Border Width="76"
                                Height="76"
                                CornerRadius="38"
                                Background="{StaticResource DashboardPrimarySoftBrush}"
                                BorderBrush="{StaticResource DashboardSoftBorderBrush}"
                                BorderThickness="1">
                            <TextBlock Text="&#xE823;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="28"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource DashboardAccentTextBrush}"/>
                        </Border>
                    </StackPanel>

                    <UniformGrid Grid.Row="1"
                                 Grid.ColumnSpan="2"
                                 Margin="0,20,0,0"
                                 Columns="3">
                        <Border Style="{StaticResource DashboardProfileStatCardStyle}" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="Selected Subjects"
                                           Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                                <TextBlock x:Name="ScheduleSelectedSubjectsTextBlock"
                                           Text="0"
                                           Margin="0,4,0,0"
                                           Style="{StaticResource DashboardProfileStatValueStyle}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource DashboardProfileStatCardStyle}" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="Total Units"
                                           Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                                <TextBlock x:Name="ScheduleTotalUnitsTextBlock"
                                           Text="0"
                                           Margin="0,4,0,0"
                                           Style="{StaticResource DashboardProfileStatValueStyle}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource DashboardProfileStatCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Enrollment Status"
                                           Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                                <TextBlock x:Name="ScheduleEnrollmentStatusTextBlock"
                                           Text="Open"
                                           Margin="0,4,0,0"
                                           Style="{StaticResource DashboardProfileStatValueStyle}"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </Grid>
            </Border>

            <Border Style="{StaticResource DashboardCardBorderStyle}" Margin="0,18,0,0">
                <Grid Margin="18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="Schedule Workspace"
                                   Style="{StaticResource DashboardProfileSectionTitleStyle}"/>
                        <TextBlock Text="Review your timetable, manage your self-enrollment, and check submission readiness."
                                   Style="{StaticResource DashboardProfileSectionSubtitleStyle}"/>
                    </StackPanel>

                    <Grid Grid.Row="1" Margin="0,16,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button x:Name="AvailableSubjectsSectionButton"
                                    Grid.Column="0"
                                    Width="132"
                                    Style="{StaticResource DashboardProfileSegmentSelectedButtonStyle}"
                                    Click="AvailableSubjectsSectionButton_Click"
                                    Content="Weekly Schedule"/>

                            <Button x:Name="SelectedLoadSectionButton"
                                    Grid.Column="1"
                                    Width="104"
                                    Margin="8,0,0,0"
                                    Style="{StaticResource DashboardProfileSegmentButtonStyle}"
                                    Click="SelectedLoadSectionButton_Click"
                                    Content="Enrollment"/>

                            <Button x:Name="SubmissionSectionButton"
                                    Grid.Column="2"
                                    Width="98"
                                    Margin="8,0,0,0"
                                    Style="{StaticResource DashboardProfileSegmentButtonStyle}"
                                    Click="SubmissionSectionButton_Click"
                                    Content="Submission"/>
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,14,0,0">
                            <local:StudentWeeklyScheduleTab x:Name="WeeklyScheduleTabView"/>

                            <local:StudentExamScheduleTab x:Name="SelectedLoadTabView"
                                                          Visibility="Collapsed"/>

                            <local:StudentConsultationScheduleTab x:Name="SubmissionTabView"
                                                                  Visibility="Collapsed"/>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
