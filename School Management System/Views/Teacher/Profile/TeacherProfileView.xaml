<UserControl x:Class="TeacherProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="20,18,20,22">
            <Border Style="{StaticResource DashboardCardBorderStyle}">
                <Grid Margin="22">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0"
                                Grid.Column="0"
                                Margin="0,0,16,0">
                        <TextBlock Text="Teacher Profile"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource DashboardTextMutedBrush}"/>
                        <TextBlock x:Name="ProfileTeacherNameTextBlock"
                                   Text="Teacher"
                                   Margin="0,4,0,0"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource DashboardTextPrimaryBrush}"/>
                        <TextBlock Text="Keep your faculty profile and assignment details up to date."
                                   Margin="0,6,0,0"
                                   FontSize="13"
                                   Foreground="{StaticResource DashboardTextMutedBrush}"
                                   TextWrapping="Wrap"/>
                        <TextBlock x:Name="ProfileTeacherIdTextBlock"
                                   Margin="0,8,0,0"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource DashboardTextMutedBrush}"
                                   Text=""/>
                    </StackPanel>

                    <StackPanel Grid.Row="0"
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top">
                        <Border Width="78"
                                Height="78"
                                CornerRadius="39"
                                Background="#DCE8F8"
                                BorderBrush="{StaticResource DashboardBorderBrush}"
                                BorderThickness="1">
                            <TextBlock x:Name="ProfileTeacherInitialTextBlock"
                                       Text="T"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="30"
                                       FontWeight="Bold"
                                       Foreground="#1F3E6F"/>
                        </Border>
                    </StackPanel>

                    <UniformGrid Grid.Row="1"
                                 Grid.ColumnSpan="2"
                                 Columns="3"
                                 Margin="0,20,0,0">
                        <Border Style="{StaticResource DashboardProfileStatCardStyle}" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="Department"
                                           Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                                <TextBlock Text="Not Set"
                                           Margin="0,4,0,0"
                                           Style="{StaticResource DashboardProfileStatValueStyle}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource DashboardProfileStatCardStyle}" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="Advisory Section"
                                           Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                                <TextBlock Text="None"
                                           Margin="0,4,0,0"
                                           Style="{StaticResource DashboardProfileStatValueStyle}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource DashboardProfileStatCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Office Hours"
                                           Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                                <TextBlock Text="--"
                                           Margin="0,4,0,0"
                                           Style="{StaticResource DashboardProfileStatValueStyle}"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </Grid>
            </Border>

            <Grid Margin="0,18,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Row="0"
                        Grid.Column="0"
                        Margin="0,0,10,12"
                        Style="{StaticResource DashboardProfileSectionCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Identity"
                                   Style="{StaticResource DashboardProfileSectionTitleStyle}"/>
                        <TextBlock Text="Primary information used for faculty records."
                                   Style="{StaticResource DashboardProfileSectionSubtitleStyle}"/>

                        <StackPanel Margin="0,14,0,0">
                            <TextBlock Text="Employee ID"
                                       Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                            <Border Style="{StaticResource DashboardProfileFieldValueContainerStyle}">
                                <TextBlock x:Name="ProfileTeacherEmployeeIdValueTextBlock"
                                           Style="{StaticResource DashboardProfileFieldValueStyle}"
                                           Text=""/>
                            </Border>
                        </StackPanel>

                        <StackPanel Margin="0,10,0,0">
                            <TextBlock Text="Full Name"
                                       Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                            <Border Style="{StaticResource DashboardProfileFieldValueContainerStyle}">
                                <TextBlock x:Name="ProfileTeacherNameValueTextBlock"
                                           Style="{StaticResource DashboardProfileFieldValueStyle}"
                                           Text=""/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Row="0"
                        Grid.Column="1"
                        Margin="10,0,0,12"
                        Style="{StaticResource DashboardProfileSectionCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Assignment"
                                   Style="{StaticResource DashboardProfileSectionTitleStyle}"/>
                        <TextBlock Text="Teaching assignment and advisory allocation summary."
                                   Style="{StaticResource DashboardProfileSectionSubtitleStyle}"/>

                        <StackPanel Margin="0,14,0,0">
                            <TextBlock Text="Primary Campus"
                                       Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                            <Border Style="{StaticResource DashboardProfileFieldValueContainerStyle}">
                                <TextBlock Style="{StaticResource DashboardProfileFieldValueStyle}"
                                           Text="Main Campus"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Margin="0,10,0,0">
                            <TextBlock Text="Role"
                                       Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                            <Border Style="{StaticResource DashboardProfileFieldValueContainerStyle}">
                                <TextBlock Style="{StaticResource DashboardProfileFieldValueStyle}"
                                           Text="Faculty Member"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1"
                        Grid.ColumnSpan="2"
                        Style="{StaticResource DashboardProfileSectionCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Notes"
                                   Style="{StaticResource DashboardProfileSectionTitleStyle}"/>
                        <TextBlock Text="Coordinate with academic administration for profile and assignment updates."
                                   Margin="0,8,0,0"
                                   FontSize="13"
                                   Foreground="{StaticResource DashboardTextMutedBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
