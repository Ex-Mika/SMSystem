<UserControl x:Class="TeacherScheduleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:School_Management_System"
             mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="20,18,20,22">
            <Border Style="{StaticResource DashboardCardBorderStyle}">
                <Grid Margin="22">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0"
                                Grid.Column="0"
                                Margin="0,0,18,0">
                        <TextBlock Text="Schedule"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource DashboardTextMutedBrush}"/>
                        <TextBlock Text="Teaching Calendar"
                                   Margin="0,4,0,0"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource DashboardTextPrimaryBrush}"/>
                        <TextBlock Text="Review the weekly class timetable assigned by the admin."
                                    Margin="0,6,0,0"
                                    FontSize="13"
                                    Foreground="{StaticResource DashboardTextMutedBrush}"
                                    TextWrapping="Wrap"/>
                        <TextBlock x:Name="ScheduleTeacherIdTextBlock"
                                   Margin="0,8,0,0"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource DashboardTextMutedBrush}"/>
                        <TextBlock x:Name="TeacherScheduleStatusTextBlock"
                                   Margin="0,6,0,0"
                                   FontSize="12"
                                   Foreground="{StaticResource DashboardTextMutedBrush}"
                                   Text="No teacher schedule loaded."
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel Grid.Row="0"
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top">
                        <Border Width="76"
                                Height="76"
                                CornerRadius="38"
                                Background="{StaticResource DashboardPrimarySoftBrush}"
                                BorderBrush="{StaticResource DashboardSoftBorderBrush}"
                                BorderThickness="1">
                            <TextBlock Text="&#xE823;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="28"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource DashboardAccentTextBrush}"/>
                        </Border>
                        <WrapPanel Margin="0,12,0,0"
                                   HorizontalAlignment="Right">
                            <Border Style="{StaticResource DashboardProfileTagBorderStyle}">
                                <TextBlock Text="Week View"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource DashboardAccentTextBrush}"/>
                            </Border>
                            <Border Style="{StaticResource DashboardProfileTagBorderStyle}">
                                <TextBlock Text="Live Updates"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource DashboardAccentTextBrush}"/>
                            </Border>
                        </WrapPanel>
                    </StackPanel>

                    <UniformGrid Grid.Row="1"
                                 Grid.ColumnSpan="2"
                                 Margin="0,20,0,0"
                                 Columns="3">
                        <Border Style="{StaticResource DashboardProfileStatCardStyle}" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="Assigned Slots"
                                           Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                                <TextBlock x:Name="AssignedSlotsTextBlock"
                                           Text="0"
                                           Margin="0,4,0,0"
                                           Style="{StaticResource DashboardProfileStatValueStyle}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource DashboardProfileStatCardStyle}" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="Active Days"
                                           Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                                <TextBlock x:Name="ActiveDaysTextBlock"
                                           Text="0"
                                           Margin="0,4,0,0"
                                           Style="{StaticResource DashboardProfileStatValueStyle}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource DashboardProfileStatCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Handled Sections"
                                           Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                                <TextBlock x:Name="HandledSectionsTextBlock"
                                           Text="0"
                                           Margin="0,4,0,0"
                                           Style="{StaticResource DashboardProfileStatValueStyle}"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </Grid>
            </Border>

            <Border Style="{StaticResource DashboardCardBorderStyle}" Margin="0,18,0,0">
                <Grid Margin="18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Weekly Schedule"
                                   Style="{StaticResource DashboardProfileSectionTitleStyle}"/>
                        <TextBlock Text="Monday to Friday schedule sorted by time, using the same timetable layout as scheduling."
                                   Style="{StaticResource DashboardProfileSectionSubtitleStyle}"/>
                    </StackPanel>

                    <Border Grid.Row="1"
                            Margin="0,14,0,0"
                            BorderBrush="{StaticResource DashboardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            local:RoundedClipHelper.CornerRadius="8"
                            ClipToBounds="True">
                        <DataGrid x:Name="TeacherTimetableDataGrid"
                                  Style="{StaticResource DashboardManagementDataGridStyle}"
                                  ColumnHeaderStyle="{StaticResource DashboardManagementDataGridHeaderStyle}"
                                  CellStyle="{StaticResource DashboardManagementDataGridCellStyle}"
                                  RowStyle="{StaticResource DashboardManagementDataGridRowStyle}"
                                  BorderThickness="0"
                                  ColumnWidth="*"
                                  HeadersVisibility="Column"
                                  RowHeaderWidth="0"
                                  CanUserSortColumns="False"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  SelectionUnit="Cell"
                                  SelectionMode="Single"
                                  MinHeight="320"/>
                    </Border>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
