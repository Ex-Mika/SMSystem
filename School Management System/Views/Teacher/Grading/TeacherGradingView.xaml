<UserControl x:Class="TeacherGradingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="20,18,20,22">
            <Border Style="{StaticResource DashboardCardBorderStyle}">
                <Grid Margin="22">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0"
                                Grid.Column="0"
                                Margin="0,0,18,0">
                        <TextBlock Text="Grading"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource DashboardTextMutedBrush}"/>
                        <TextBlock Text="Grading Center"
                                   Margin="0,4,0,0"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource DashboardTextPrimaryBrush}"/>
                        <TextBlock Text="Grade the students currently enrolled in your handled subjects and release results to their dashboards."
                                   Margin="0,6,0,0"
                                   FontSize="13"
                                   Foreground="{StaticResource DashboardTextMutedBrush}"
                                   TextWrapping="Wrap"/>
                        <TextBlock x:Name="GradingTeacherIdTextBlock"
                                   Margin="0,8,0,0"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource DashboardTextMutedBrush}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="0"
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top">
                        <Border Width="76"
                                Height="76"
                                CornerRadius="38"
                                Background="{StaticResource DashboardPrimarySoftBrush}"
                                BorderBrush="{StaticResource DashboardSoftBorderBrush}"
                                BorderThickness="1">
                            <TextBlock Text="&#xE9D9;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="28"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource DashboardAccentTextBrush}"/>
                        </Border>
                        <WrapPanel Margin="0,12,0,0"
                                   HorizontalAlignment="Right">
                            <Border Style="{StaticResource DashboardProfileTagBorderStyle}">
                                <TextBlock Text="Current Roster"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource DashboardAccentTextBrush}"/>
                            </Border>
                            <Border Style="{StaticResource DashboardProfileTagBorderStyle}">
                                <TextBlock Text="Student Dashboard Sync"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource DashboardAccentTextBrush}"/>
                            </Border>
                        </WrapPanel>
                        <TextBlock Margin="0,12,0,0"
                                   HorizontalAlignment="Right"
                                   Text="Student List Scope"
                                   Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                        <ComboBox x:Name="ExportStudentListTargetComboBox"
                                  Width="260"
                                  Height="36"
                                  Margin="0,6,0,0"
                                  HorizontalAlignment="Right"
                                  Style="{StaticResource DashboardFilterComboBoxStyle}"
                                  TextSearch.TextPath="DisplayLabel"
                                  SelectionChanged="ExportStudentListTargetComboBox_SelectionChanged">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayLabel}"
                                               TextTrimming="CharacterEllipsis"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Button x:Name="ExportStudentListPdfButton"
                                Width="170"
                                Height="36"
                                Margin="0,10,0,0"
                                HorizontalAlignment="Right"
                                Style="{StaticResource DashboardSecondaryActionButtonStyle}"
                                Click="ExportStudentListPdfButton_Click"
                                Content="Export Student List"/>
                        <TextBlock x:Name="StudentListExportStatusTextBlock"
                                   Width="260"
                                   Margin="0,8,0,0"
                                   HorizontalAlignment="Right"
                                   TextAlignment="Right"
                                   FontSize="11"
                                   Foreground="{StaticResource DashboardTextMutedBrush}"
                                   Text="Choose a handled subject and section to export."
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <UniformGrid Grid.Row="1"
                                 Grid.ColumnSpan="2"
                                 Margin="0,20,0,0"
                                 Columns="3">
                        <Border Style="{StaticResource DashboardProfileStatCardStyle}" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="Pending Checks"
                                           Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                                <TextBlock x:Name="PendingChecksTextBlock"
                                           Text="0"
                                           Margin="0,4,0,0"
                                           Style="{StaticResource DashboardProfileStatValueStyle}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource DashboardProfileStatCardStyle}" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="Published Grades"
                                           Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                                <TextBlock x:Name="PublishedGradesTextBlock"
                                           Text="0"
                                           Margin="0,4,0,0"
                                           Style="{StaticResource DashboardProfileStatValueStyle}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource DashboardProfileStatCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Class Average"
                                           Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                                <TextBlock x:Name="ClassAverageTextBlock"
                                           Text="0.00"
                                           Margin="0,4,0,0"
                                           Style="{StaticResource DashboardProfileStatValueStyle}"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </Grid>
            </Border>

            <Border Style="{StaticResource DashboardCardBorderStyle}" Margin="0,18,0,0">
                <Grid Margin="18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Grading Workflow"
                                   Style="{StaticResource DashboardProfileSectionTitleStyle}"/>
                        <TextBlock Text="Switch between pending roster entries, published grades, and recent grading history."
                                   Style="{StaticResource DashboardProfileSectionSubtitleStyle}"/>
                    </StackPanel>

                    <Grid Grid.Row="1" Margin="0,16,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button x:Name="PendingSectionButton"
                                    Grid.Column="0"
                                    Width="102"
                                    Style="{StaticResource DashboardProfileSegmentSelectedButtonStyle}"
                                    Click="PendingSectionButton_Click"
                                    Content="Pending"/>

                            <Button x:Name="PublishedSectionButton"
                                    Grid.Column="1"
                                    Width="112"
                                    Margin="8,0,0,0"
                                    Style="{StaticResource DashboardProfileSegmentButtonStyle}"
                                    Click="PublishedSectionButton_Click"
                                    Content="Published"/>

                            <Button x:Name="HistorySectionButton"
                                    Grid.Column="2"
                                    Width="94"
                                    Margin="8,0,0,0"
                                    Style="{StaticResource DashboardProfileSegmentButtonStyle}"
                                    Click="HistorySectionButton_Click"
                                    Content="History"/>
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,14,0,0">
                            <Grid x:Name="RosterContentPanel">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.7*"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Margin="0,0,10,0"
                                        Style="{StaticResource DashboardProfileSectionCardStyle}">
                                    <StackPanel>
                                        <TextBlock x:Name="RosterPanelTitleTextBlock"
                                                   Text="Students Ready for Grading"
                                                   Style="{StaticResource DashboardProfileSectionTitleStyle}"/>
                                        <TextBlock x:Name="RosterPanelSubtitleTextBlock"
                                                   Text="Current enrolled students in your handled subjects."
                                                   Style="{StaticResource DashboardProfileSectionSubtitleStyle}"/>
                                        <TextBlock x:Name="TeacherGradingStatusTextBlock"
                                                   Margin="0,10,0,0"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource DashboardTextMutedBrush}"
                                                   TextWrapping="Wrap"/>

                                        <Border Margin="0,14,0,0"
                                                BorderBrush="{StaticResource DashboardBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8">
                                            <DataGrid x:Name="GradingRosterDataGrid"
                                                      Style="{StaticResource DashboardManagementDataGridStyle}"
                                                      ColumnHeaderStyle="{StaticResource DashboardManagementDataGridHeaderStyle}"
                                                      CellStyle="{StaticResource DashboardManagementDataGridCellStyle}"
                                                      RowStyle="{StaticResource DashboardManagementDataGridRowStyle}"
                                                      AutoGenerateColumns="False"
                                                      BorderThickness="0"
                                                      CanUserAddRows="False"
                                                      CanUserDeleteRows="False"
                                                      CanUserResizeRows="False"
                                                      CanUserSortColumns="True"
                                                      IsReadOnly="True"
                                                      SelectionMode="Single"
                                                      SelectionUnit="FullRow"
                                                      RowHeaderWidth="0"
                                                      MinHeight="380"
                                                      SelectionChanged="GradingRosterDataGrid_SelectionChanged">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="Subject"
                                                                        Binding="{Binding SubjectDisplayLabel}"
                                                                        Width="2*"/>
                                                    <DataGridTextColumn Header="Student"
                                                                        Binding="{Binding StudentName}"
                                                                        Width="1.6*"/>
                                                    <DataGridTextColumn Header="Section"
                                                                        Binding="{Binding SectionDisplayLabel}"
                                                                        Width="1*"/>
                                                    <DataGridTextColumn Header="Final Grade"
                                                                        Binding="{Binding FinalGradeLabel}"
                                                                        Width="0.9*"/>
                                                    <DataGridTextColumn Header="Remarks"
                                                                        Binding="{Binding RemarksLabel}"
                                                                        Width="1*"/>
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1"
                                        Margin="10,0,0,0"
                                        Style="{StaticResource DashboardProfileSectionCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Grade Editor"
                                                   Style="{StaticResource DashboardProfileSectionTitleStyle}"/>
                                        <TextBlock Text="Select a student row, enter scores from 0 to 100, then save the grade."
                                                   Style="{StaticResource DashboardProfileSectionSubtitleStyle}"/>

                                        <StackPanel Margin="0,14,0,0">
                                            <TextBlock Text="Student"
                                                       Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                                            <Border Style="{StaticResource DashboardProfileFieldValueContainerStyle}">
                                                <TextBlock x:Name="SelectedStudentTextBlock"
                                                           Style="{StaticResource DashboardProfileFieldValueStyle}"
                                                           Text="Select a student from the roster."/>
                                            </Border>
                                        </StackPanel>

                                        <StackPanel Margin="0,10,0,0">
                                            <TextBlock Text="Subject"
                                                       Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                                            <Border Style="{StaticResource DashboardProfileFieldValueContainerStyle}">
                                                <TextBlock x:Name="SelectedSubjectTextBlock"
                                                           Style="{StaticResource DashboardProfileFieldValueStyle}"
                                                           Text="--"/>
                                            </Border>
                                        </StackPanel>

                                        <StackPanel Margin="0,10,0,0">
                                            <TextBlock Text="Section"
                                                       Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                                            <Border Style="{StaticResource DashboardProfileFieldValueContainerStyle}">
                                                <TextBlock x:Name="SelectedSectionTextBlock"
                                                           Style="{StaticResource DashboardProfileFieldValueStyle}"
                                                           Text="--"/>
                                            </Border>
                                        </StackPanel>

                                        <Grid Margin="0,14,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                                <TextBlock Text="Quiz Score"
                                                           Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                                                <TextBox x:Name="QuizScoreTextBox"
                                                         Margin="0,6,0,0"
                                                         Style="{StaticResource DashboardProfileInputTextBoxStyle}"
                                                         TextChanged="ScoreInputTextBox_TextChanged"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                <TextBlock Text="Project Score"
                                                           Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                                                <TextBox x:Name="ProjectScoreTextBox"
                                                         Margin="0,6,0,0"
                                                         Style="{StaticResource DashboardProfileInputTextBoxStyle}"
                                                         TextChanged="ScoreInputTextBox_TextChanged"/>
                                            </StackPanel>
                                        </Grid>

                                        <Grid Margin="0,10,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                                <TextBlock Text="Midterm Score"
                                                           Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                                                <TextBox x:Name="MidtermScoreTextBox"
                                                         Margin="0,6,0,0"
                                                         Style="{StaticResource DashboardProfileInputTextBoxStyle}"
                                                         TextChanged="ScoreInputTextBox_TextChanged"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                <TextBlock Text="Final Exam Score"
                                                           Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                                                <TextBox x:Name="FinalExamScoreTextBox"
                                                         Margin="0,6,0,0"
                                                         Style="{StaticResource DashboardProfileInputTextBoxStyle}"
                                                         TextChanged="ScoreInputTextBox_TextChanged"/>
                                            </StackPanel>
                                        </Grid>

                                        <Grid Margin="0,14,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                                <TextBlock Text="Computed Final Grade"
                                                           Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                                                <Border Style="{StaticResource DashboardProfileFieldValueContainerStyle}">
                                                    <TextBlock x:Name="ComputedFinalGradeTextBlock"
                                                               Style="{StaticResource DashboardProfileFieldValueStyle}"
                                                               Text="--"/>
                                                </Border>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                <TextBlock Text="Remarks"
                                                           Style="{StaticResource DashboardProfileFieldLabelStyle}"/>
                                                <Border Style="{StaticResource DashboardProfileFieldValueContainerStyle}">
                                                    <TextBlock x:Name="ComputedRemarksTextBlock"
                                                               Style="{StaticResource DashboardProfileFieldValueStyle}"
                                                               Text="Pending"/>
                                                </Border>
                                            </StackPanel>
                                        </Grid>

                                        <TextBlock x:Name="GradeEditorStatusTextBlock"
                                                   Margin="0,12,0,0"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource DashboardTextMutedBrush}"
                                                   Text="Choose a student record to begin grading."
                                                   TextWrapping="Wrap"/>

                                        <WrapPanel Margin="0,14,0,0">
                                            <Button x:Name="SaveGradeButton"
                                                    Width="120"
                                                    Height="36"
                                                    Margin="0,0,10,8"
                                                    Style="{StaticResource DashboardPrimaryActionButtonStyle}"
                                                    Click="SaveGradeButton_Click"
                                                    Content="Save Grade"/>
                                            <Button x:Name="ResetGradeEditorButton"
                                                    Width="100"
                                                    Height="36"
                                                    Margin="0,0,0,8"
                                                    Style="{StaticResource DashboardSecondaryActionButtonStyle}"
                                                    Click="ResetGradeEditorButton_Click"
                                                    Content="Reset"/>
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <StackPanel x:Name="HistoryPanel"
                                        Visibility="Collapsed">
                                <TextBlock Text="Recent Grading Activity"
                                           Style="{StaticResource DashboardProfileSectionTitleStyle}"/>
                                <TextBlock Text="Saved grades that are already visible to students in the dashboard."
                                           Style="{StaticResource DashboardProfileSectionSubtitleStyle}"/>
                                <TextBlock x:Name="HistoryStatusTextBlock"
                                           Margin="0,10,0,0"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource DashboardTextMutedBrush}"
                                           TextWrapping="Wrap"/>

                                <Border Margin="0,14,0,0"
                                        BorderBrush="{StaticResource DashboardBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <DataGrid x:Name="GradingHistoryDataGrid"
                                              Style="{StaticResource DashboardManagementDataGridStyle}"
                                              ColumnHeaderStyle="{StaticResource DashboardManagementDataGridHeaderStyle}"
                                              CellStyle="{StaticResource DashboardManagementDataGridCellStyle}"
                                              RowStyle="{StaticResource DashboardManagementDataGridRowStyle}"
                                              AutoGenerateColumns="False"
                                              BorderThickness="0"
                                              CanUserAddRows="False"
                                              CanUserDeleteRows="False"
                                              CanUserResizeRows="False"
                                              CanUserSortColumns="True"
                                              IsReadOnly="True"
                                              RowHeaderWidth="0"
                                              MinHeight="380">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Student"
                                                                Binding="{Binding StudentName}"
                                                                Width="1.8*"/>
                                            <DataGridTextColumn Header="Subject"
                                                                Binding="{Binding SubjectDisplayLabel}"
                                                                Width="2*"/>
                                            <DataGridTextColumn Header="Section"
                                                                Binding="{Binding SectionDisplayLabel}"
                                                                Width="1*"/>
                                            <DataGridTextColumn Header="Final Grade"
                                                                Binding="{Binding FinalGradeLabel}"
                                                                Width="0.9*"/>
                                            <DataGridTextColumn Header="Remarks"
                                                                Binding="{Binding RemarksLabel}"
                                                                Width="1*"/>
                                            <DataGridTextColumn Header="Updated"
                                                                Binding="{Binding UpdatedAtLabel}"
                                                                Width="1.2*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
