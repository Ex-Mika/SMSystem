<Window x:Class="LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="School Management System - Login"
        Width="1366"
        Height="820"
        MinWidth="1080"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        StateChanged="LoginWindow_StateChanged"
        Background="{StaticResource Brush.PageBackground}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Grid.RowSpan="2" IsHitTestVisible="False">
            <Image Source="/Resources/Images/prmsu-campus-bg.png"
                   Stretch="UniformToFill"
                   Opacity="0.95">
                <Image.Effect>
                    <BlurEffect Radius="16"/>
                </Image.Effect>
            </Image>
            <Rectangle Fill="{StaticResource Brush.PageGradient}" Opacity="0.72"/>
            <Rectangle Fill="#26180F00"/>
        </Grid>
        <Border Grid.Row="0"
                Style="{StaticResource LoginTitleBarBorderStyle}"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="10,0,0,0">
                    <Border Width="26"
                            Height="26"
                            CornerRadius="6"
                            Background="#FFF6BF">
                        <Image Source="/Resources/Images/prmsu-logo.png" Stretch="Uniform"/>
                    </Border>
                    <TextBlock Text="President Ramon Magsaysay State University"
                               Style="{StaticResource LoginTitleBarBrandTextStyle}"/>
                </StackPanel>
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0">
                    <Button Style="{StaticResource TitleBarButtonStyle}"
                            Click="MinimizeButton_Click"
                            ToolTip="Minimize">
                        <TextBlock Text="&#xE921;"
                                   FontSize="15"
                                   Style="{StaticResource LoginTitleBarGlyphStyle}"/>
                    </Button>
                    <Button Style="{StaticResource TitleBarButtonStyle}"
                            Click="MaximizeRestoreButton_Click"
                            ToolTip="Maximize/Restore">
                        <TextBlock x:Name="MaximizeRestoreIcon"
                                   Text="&#xE922;"
                                   FontSize="12"
                                   Style="{StaticResource LoginTitleBarGlyphStyle}"/>
                    </Button>
                    <Button Style="{StaticResource TitleBarCloseButtonStyle}"
                            Click="CloseButton_Click"
                            ToolTip="Close">
                        <TextBlock Text="&#xE8BB;"
                                   FontSize="11"
                                   Style="{StaticResource LoginTitleBarGlyphStyle}"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
        <Grid Grid.Row="1" Margin="24,16,24,24">
            <Border Style="{StaticResource LoginCardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Margin="30,28,30,10">
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center">
                            <Border Width="88"
                                    Height="88"
                                    CornerRadius="14"
                                    Background="#FFF6BF"
                                    Margin="0,0,14,0">
                                <Image Source="/Resources/Images/prmsu-logo.png"
                                       Width="88"
                                       Height="88"
                                       Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="Fant"/>
                            </Border>
                            <TextBlock Text="PRMSU Portal"
                                       Style="{StaticResource LoginHeaderTitleStyle}"/>
                        </StackPanel>
                        <TextBlock Text="Sign in to your account to continue"
                                   Style="{StaticResource LoginHeaderSubtitleStyle}"/>
                    </StackPanel>
                    <Border Grid.Row="1"
                            Margin="30,0,30,0"
                            Height="44"
                            CornerRadius="8"
                            BorderBrush="#E6D897"
                            BorderThickness="1"
                            Background="#FDF9DB">
                        <UniformGrid Columns="3">
                            <RadioButton x:Name="StudentRoleRadioButton"
                                         Content="Student"
                                         Style="{StaticResource RoleOptionButtonStyle}"
                                         Checked="RoleSelector_Checked"
                                         IsChecked="True"/>
                            <RadioButton x:Name="TeacherRoleRadioButton"
                                         Content="Teacher"
                                         Checked="RoleSelector_Checked"
                                         Style="{StaticResource RoleOptionButtonStyle}"/>
                            <RadioButton x:Name="AdminRoleRadioButton"
                                         Content="Administrator"
                                         Checked="RoleSelector_Checked"
                                         Style="{StaticResource RoleOptionButtonStyle}"/>
                        </UniformGrid>
                    </Border>
                    <StackPanel Grid.Row="2" Margin="30,16,30,26">
                        <TextBlock x:Name="IdentifierLabelTextBlock"
                                   Text="Student ID"
                                   Margin="0,0,0,8"
                                   Style="{StaticResource LoginFieldLabelStyle}"/>
                        <Border Style="{StaticResource InputCardBorderStyle}" Height="50">
                            <Grid>
                                <TextBlock Text="&#xE77B;"
                                           Margin="14,0,0,0"
                                           Style="{StaticResource LoginFieldIconStyle}"/>
                                <TextBox x:Name="UsernameTextBox"
                                          Padding="38,0,14,0"
                                          TextChanged="UsernameTextBox_TextChanged"
                                          Style="{StaticResource LoginTextInputStyle}"/>
                                <TextBlock x:Name="IdentifierPlaceholderTextBlock"
                                           Text="Enter your ID"
                                           Margin="38,0,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource LoginPlaceholderTextStyle}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding Text, ElementName=UsernameTextBox}" Value=""/>
                                                        <Condition Binding="{Binding IsKeyboardFocused, ElementName=UsernameTextBox}" Value="False"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>
                        <TextBlock Text="Password"
                                   Margin="0,14,0,8"
                                   Style="{StaticResource LoginFieldLabelStyle}"/>
                        <Border Style="{StaticResource InputCardBorderStyle}" Height="50">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="&#xE72E;"
                                           Margin="14,0,10,0"
                                           Style="{StaticResource LoginFieldIconStyle}"/>
                                <Grid Grid.Column="1">
                                    <PasswordBox x:Name="PasswordInput"
                                                 Padding="0,0,6,0"
                                                 Style="{StaticResource LoginPasswordInputStyle}"
                                                 PasswordChanged="PasswordInput_PasswordChanged"
                                                 GotKeyboardFocus="PasswordControl_GotKeyboardFocus"
                                                 LostKeyboardFocus="PasswordControl_LostKeyboardFocus"/>
                                    <TextBox x:Name="PasswordVisibleTextBox"
                                             Visibility="Collapsed"
                                             Padding="0,0,6,0"
                                             Style="{StaticResource LoginTextInputStyle}"
                                             TextChanged="PasswordVisibleTextBox_TextChanged"
                                             GotKeyboardFocus="PasswordControl_GotKeyboardFocus"
                                             LostKeyboardFocus="PasswordControl_LostKeyboardFocus"/>
                                    <TextBlock x:Name="PasswordPlaceholder"
                                               Text="Enter your password"
                                               Style="{StaticResource LoginPlaceholderTextStyle}"/>
                                </Grid>
                                <Button Grid.Column="2"
                                        Style="{StaticResource PasswordIconButtonStyle}"
                                        Width="40"
                                        Margin="0,1,1,1"
                                        Click="TogglePasswordVisibility_Click">
                                    <Grid Width="18"
                                          Height="18"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center">
                                        <Rectangle x:Name="PasswordEyeOpenIcon"
                                                   Width="18"
                                                   Height="18"
                                                   Fill="#AF9541">
                                            <Rectangle.OpacityMask>
                                                <ImageBrush ImageSource="/Resources/Images/Icons/eye-open.png"
                                                            Stretch="Uniform"/>
                                            </Rectangle.OpacityMask>
                                        </Rectangle>
                                        <Rectangle x:Name="PasswordEyeClosedIcon"
                                                   Width="18"
                                                   Height="18"
                                                   Fill="#AF9541"
                                                   Visibility="Collapsed">
                                            <Rectangle.OpacityMask>
                                                <ImageBrush ImageSource="/Resources/Images/Icons/eye-closed.png"
                                                            Stretch="Uniform"/>
                                            </Rectangle.OpacityMask>
                                        </Rectangle>
                                    </Grid>
                                </Button>
                            </Grid>
                        </Border>
                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0"
                                      Content="Remember me"
                                      FontSize="14"
                                      VerticalAlignment="Center"
                                      Foreground="#7A6A33"/>
                       
                        </Grid>
                        <TextBlock x:Name="LoginStatusTextBlock"
                                   Margin="0,14,0,0"
                                   Visibility="Collapsed"
                                   TextWrapping="Wrap"
                                   Foreground="#C94A56"
                                   FontSize="13"
                                   FontWeight="SemiBold"/>
                        <Button x:Name="LoginButton"
                                Height="48"
                                Margin="0,20,0,0"
                                FontSize="16"
                                FontWeight="SemiBold"
                                Style="{StaticResource PrimaryActionButtonStyle}"
                                IsDefault="True"
                                Click="LoginButton_Click">
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <TextBlock Text="Log In" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="&#xE72A;"
                                           FontFamily="Segoe MDL2 Assets"
                                           VerticalAlignment="Center"
                                           Margin="8,0,0,0"
                                           FontSize="14"
                                           FontWeight="Bold"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    <Border Grid.Row="3" Style="{StaticResource LoginFooterBorderStyle}">
                        <TextBlock Style="{StaticResource LoginFooterTextStyle}">
                            <Run Text="(c) 2026 Appsenso. "/>
                            <Hyperlink Foreground="#8C6A00">Contact Support</Hyperlink>
                        </TextBlock>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
