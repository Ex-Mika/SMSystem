<UserControl x:Class="AdminSchedulingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:School_Management_System"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="SchedulingFormLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,12,0,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource DashboardTextMutedBrush}"/>
        </Style>

        <Style x:Key="SchedulingFormTextInputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="{StaticResource DashboardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#F8FBFF"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="SchedulingComboBoxStyle"
               TargetType="ComboBox"
               BasedOn="{StaticResource DashboardFilterComboBoxStyle}">
            <Setter Property="Width" Value="380"/>
            <Setter Property="Height" Value="36"/>
        </Style>

        <Style x:Key="SchedulingDetailsValueBorderStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,6,0,0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Background" Value="#F8FBFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource DashboardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>

        <Style x:Key="SchedulingDetailsValueTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource DashboardTextPrimaryBrush}"/>
            <Setter Property="Text" Value="--"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20,18,20,22">
                <Border Style="{StaticResource DashboardCardBorderStyle}">
                    <StackPanel Margin="18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Scheduling"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource DashboardTextPrimaryBrush}"/>
                            <TextBlock x:Name="SchedulingCountTextBlock"
                                       Grid.Column="1"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource DashboardTextMutedBrush}"
                                       Text="0 professors"/>
                        </Grid>

                         <TextBlock Margin="0,6,0,0"
                                    FontSize="12"
                                    Foreground="{StaticResource DashboardTextMutedBrush}"
                                    Text="Filter professors and subjects, then assign day, session, section, and room slots."/>

                         <Grid Margin="0,14,0,0">
                             <Grid.ColumnDefinitions>
                                 <ColumnDefinition Width="470"/>
                                 <ColumnDefinition Width="14"/>
                                 <ColumnDefinition Width="*"/>
                             </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    BorderBrush="{StaticResource DashboardBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Background="White">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0"
                                            Padding="18,14"
                                            BorderBrush="{StaticResource DashboardBorderBrush}"
                                            BorderThickness="0,0,0,1"
                                            Background="#FCFDFE">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Schedule Builder"
                                                           FontSize="20"
                                                           FontWeight="Bold"
                                                           Foreground="{StaticResource DashboardTextPrimaryBrush}"/>
                                                <TextBlock x:Name="ScheduleBuilderSubtitleTextBlock"
                                                           Margin="0,3,0,0"
                                                           Text="Choose a professor and assign subjects to timetable slots."
                                                           FontSize="12"
                                                           Foreground="{StaticResource DashboardTextMutedBrush}"/>
                                            </StackPanel>
                                            <Button Grid.Column="1"
                                                    Width="84"
                                                    Height="34"
                                                    Margin="10,0,0,0"
                                                    Style="{StaticResource DashboardPrimaryActionButtonStyle}"
                                                    Background="#EAF4FF"
                                                    Foreground="{StaticResource DashboardPrimaryBrush}"
                                                    Click="RefreshSchedulingDataButton_Click"
                                                    Content="Refresh"/>
                                        </Grid>
                                    </Border>

                                     <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                         <StackPanel Margin="18,12,18,14">
                                             <Border Margin="0,0,0,12"
                                                     Padding="12"
                                                     Background="#F8FBFF"
                                                     BorderBrush="{StaticResource DashboardBorderBrush}"
                                                     BorderThickness="1"
                                                     CornerRadius="8">
                                                 <StackPanel>
                                                     <TextBlock Text="Filters"
                                                                FontSize="13"
                                                                FontWeight="SemiBold"
                                                                Foreground="{StaticResource DashboardTextPrimaryBrush}"/>
 
                                                     <Grid Margin="0,8,0,0">
                                                         <Grid.ColumnDefinitions>
                                                             <ColumnDefinition Width="*"/>
                                                             <ColumnDefinition Width="10"/>
                                                             <ColumnDefinition Width="*"/>
                                                         </Grid.ColumnDefinitions>
 
                                                         <StackPanel Grid.Column="0">
                                                             <TextBlock Style="{StaticResource SchedulingFormLabelStyle}" Margin="0" Text="Department"/>
                                                             <ComboBox x:Name="ProfessorDepartmentFilterComboBox"
                                                                       Style="{StaticResource SchedulingComboBoxStyle}"
                                                                       Width="200"
                                                                       SelectionChanged="ProfessorDepartmentFilterComboBox_SelectionChanged"/>
                                                         </StackPanel>
 
                                                         <StackPanel Grid.Column="2">
                                                             <TextBlock Style="{StaticResource SchedulingFormLabelStyle}" Margin="0" Text="Schedule View"/>
                                                             <ComboBox x:Name="ProfessorScheduleFilterComboBox"
                                                                       Style="{StaticResource SchedulingComboBoxStyle}"
                                                                       Width="200"
                                                                       SelectionChanged="ProfessorScheduleFilterComboBox_SelectionChanged"/>
                                                         </StackPanel>
                                                     </Grid>
 
                                                     <Grid Margin="0,10,0,0">
                                                         <Grid.ColumnDefinitions>
                                                             <ColumnDefinition Width="*"/>
                                                             <ColumnDefinition Width="10"/>
                                                             <ColumnDefinition Width="*"/>
                                                         </Grid.ColumnDefinitions>
 
                                                         <StackPanel Grid.Column="0">
                                                             <TextBlock Style="{StaticResource SchedulingFormLabelStyle}" Margin="0" Text="Professor Filter"/>
                                                             <TextBox x:Name="ProfessorFilterTextBox"
                                                                      Style="{StaticResource SchedulingFormTextInputStyle}"
                                                                      TextChanged="ProfessorFilterTextBox_TextChanged"/>
                                                         </StackPanel>
 
                                                         <StackPanel Grid.Column="2">
                                                             <TextBlock Style="{StaticResource SchedulingFormLabelStyle}" Margin="0" Text="Subject Filter"/>
                                                             <TextBox x:Name="SubjectFilterTextBox"
                                                                      Style="{StaticResource SchedulingFormTextInputStyle}"
                                                                      TextChanged="SubjectFilterTextBox_TextChanged"/>
                                                         </StackPanel>
                                                     </Grid>
 
                                                     <TextBlock x:Name="ProfessorScheduleBreakdownTextBlock"
                                                                Margin="0,10,0,0"
                                                                FontSize="11"
                                                                Foreground="{StaticResource DashboardTextMutedBrush}"
                                                                TextWrapping="Wrap"
                                                                Text="0 with schedules | 0 without schedules"/>
                                                 </StackPanel>
                                             </Border>

                                             <TextBlock Style="{StaticResource SchedulingFormLabelStyle}"
                                                        Margin="0,0,0,0"
                                                        Text="Professor"/>
                                            <ComboBox x:Name="ProfessorComboBox"
                                                      Style="{StaticResource SchedulingComboBoxStyle}"
                                                      DisplayMemberPath="DisplayName"
                                                      SelectionChanged="ProfessorComboBox_SelectionChanged"/>

                                             <TextBlock Style="{StaticResource SchedulingFormLabelStyle}" Text="Selected Professor"/>
                                             <Border Style="{StaticResource SchedulingDetailsValueBorderStyle}">
                                                 <TextBlock x:Name="SelectedProfessorTextBlock" Style="{StaticResource SchedulingDetailsValueTextStyle}"/>
                                             </Border>

                                             <TextBlock Style="{StaticResource SchedulingFormLabelStyle}" Text="Subject"/>
                                             <ComboBox x:Name="SubjectComboBox"
                                                       Style="{StaticResource SchedulingComboBoxStyle}"
                                                       DisplayMemberPath="DisplayName"/>

                                            <Grid Margin="0,12,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="12"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Style="{StaticResource SchedulingFormLabelStyle}" Margin="0" Text="Day"/>
                                                    <ComboBox x:Name="DayComboBox"
                                                              Style="{StaticResource SchedulingComboBoxStyle}"
                                                              Width="184"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Style="{StaticResource SchedulingFormLabelStyle}" Margin="0" Text="Room"/>
                                                    <TextBox x:Name="RoomTextBox" Style="{StaticResource SchedulingFormTextInputStyle}"/>
                                                </StackPanel>
                                            </Grid>

                                             <TextBlock Style="{StaticResource SchedulingFormLabelStyle}" Text="Session (24-hour clock)"/>
                                             <Grid Margin="0,6,0,0">
                                                 <Grid.ColumnDefinitions>
                                                     <ColumnDefinition Width="*"/>
                                                     <ColumnDefinition Width="36"/>
                                                     <ColumnDefinition Width="*"/>
                                                 </Grid.ColumnDefinitions>
 
                                                 <ComboBox x:Name="SessionStartComboBox"
                                                           Grid.Column="0"
                                                           Style="{StaticResource SchedulingComboBoxStyle}"
                                                           Width="184"/>
 
                                                 <TextBlock Grid.Column="1"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            FontSize="13"
                                                            FontWeight="SemiBold"
                                                            Foreground="{StaticResource DashboardTextMutedBrush}"
                                                            Text="to"/>
 
                                                 <ComboBox x:Name="SessionEndComboBox"
                                                           Grid.Column="2"
                                                           Style="{StaticResource SchedulingComboBoxStyle}"
                                                           Width="184"/>
                                             </Grid>

                                             <TextBlock Style="{StaticResource SchedulingFormLabelStyle}" Text="Section"/>
                                             <TextBox x:Name="SectionTextBox" Style="{StaticResource SchedulingFormTextInputStyle}"/>

                                             <TextBlock Margin="0,10,0,0"
                                                        FontSize="11"
                                                        Foreground="{StaticResource DashboardTextMutedBrush}"
                                                        TextWrapping="Wrap"
                                                        Text="Tip: click a timetable cell on the right to auto-fill Day, Session, and Section for quick updates."/>
                                         </StackPanel>
                                     </ScrollViewer>

                                    <Border Grid.Row="2"
                                            Padding="18,14"
                                            BorderBrush="{StaticResource DashboardBorderBrush}"
                                            BorderThickness="0,1,0,0"
                                            Background="#FCFDFE">
                                        <StackPanel>
                                            <UniformGrid Columns="3">
                                                <Button x:Name="SaveScheduleSlotButton"
                                                        Height="38"
                                                        Margin="0,0,6,0"
                                                        Style="{StaticResource DashboardPrimaryActionButtonStyle}"
                                                        Background="#137FEC"
                                                        Foreground="White"
                                                        Click="SaveScheduleSlotButton_Click"
                                                        Content="Save Slot"/>
                                                <Button x:Name="RemoveScheduleSlotButton"
                                                        Height="38"
                                                        Margin="6,0,6,0"
                                                        Style="{StaticResource DashboardPrimaryActionButtonStyle}"
                                                        Background="#FFECEE"
                                                        Foreground="#D64545"
                                                        Click="RemoveScheduleSlotButton_Click"
                                                        Content="Remove Slot"/>
                                                <Button Height="38"
                                                        Margin="6,0,0,0"
                                                        Style="{StaticResource DashboardPrimaryActionButtonStyle}"
                                                        Background="#F3F6FA"
                                                        Foreground="{StaticResource DashboardTextMutedBrush}"
                                                        Click="ClearScheduleFormButton_Click"
                                                        Content="Clear Form"/>
                                            </UniformGrid>
                                            <TextBlock x:Name="SchedulingActionStatusTextBlock"
                                                       Margin="0,10,0,0"
                                                       FontSize="11"
                                                       Foreground="{StaticResource DashboardTextMutedBrush}"
                                                       TextWrapping="Wrap"
                                                       Text="Ready."/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>

                            <Border Grid.Column="2"
                                    BorderBrush="{StaticResource DashboardBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Background="White"
                                    local:RoundedClipHelper.CornerRadius="10"
                                    ClipToBounds="True"
                                    SnapsToDevicePixels="True">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0"
                                            Padding="16,12"
                                            BorderBrush="{StaticResource DashboardBorderBrush}"
                                            BorderThickness="0,0,0,1"
                                            Background="#FCFDFE">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="Professor Timetable"
                                                           FontSize="20"
                                                           FontWeight="Bold"
                                                           Foreground="{StaticResource DashboardTextPrimaryBrush}"/>
                                                <TextBlock x:Name="TimetableSubtitleTextBlock"
                                                           Margin="0,3,0,0"
                                                           Text="Select a professor to load timetable."
                                                           FontSize="12"
                                                           Foreground="{StaticResource DashboardTextMutedBrush}"/>
                                            </StackPanel>
                                            <TextBlock x:Name="TimetableEntriesCountTextBlock"
                                                       Grid.Column="1"
                                                       Margin="12,0,0,0"
                                                       VerticalAlignment="Center"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource DashboardTextMutedBrush}"
                                                       Text="0 slots"/>
                                        </Grid>
                                    </Border>

                                    <DataGrid x:Name="SchedulingTimetableDataGrid"
                                              Grid.Row="1"
                                              Style="{StaticResource DashboardManagementDataGridStyle}"
                                              ColumnHeaderStyle="{StaticResource DashboardManagementDataGridHeaderStyle}"
                                              CellStyle="{StaticResource DashboardManagementDataGridCellStyle}"
                                              RowStyle="{StaticResource DashboardManagementDataGridRowStyle}"
                                              BorderThickness="0"
                                              ColumnWidth="*"
                                              local:RoundedClipHelper.CornerRadius="10"
                                              ClipToBounds="True"
                                              CanUserSortColumns="False"
                                              SelectionUnit="Cell"
                                              SelectionMode="Single"
                                              SelectedCellsChanged="SchedulingTimetableDataGrid_SelectedCellsChanged"
                                              MinHeight="640"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
