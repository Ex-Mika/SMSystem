<UserControl x:Class="AdminOverviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             Loaded="AdminOverviewView_Loaded"
             mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20,18,20,22">
            <UniformGrid Columns="3">
                <Border Style="{StaticResource DashboardCardBorderStyle}" Margin="0,0,8,0">
                    <StackPanel Margin="16,14,16,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Total Students"
                                           FontSize="13"
                                           Foreground="{StaticResource DashboardTextMutedBrush}"/>
                                <TextBlock x:Name="TotalStudentsValueTextBlock"
                                           Text="--"
                                           FontSize="34"
                                           FontWeight="Bold"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock x:Name="TotalStudentsStatusTextBlock"
                                   Margin="0,12,0,0"
                                   FontSize="12"
                                   Foreground="{StaticResource DashboardTextMutedBrush}"
                                   Text="Loading student data..."/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource DashboardCardBorderStyle}" Margin="8,0">
                    <StackPanel Margin="16,14,16,12">
                        <TextBlock Text="Total Teachers"
                                   FontSize="13"
                                   Foreground="{StaticResource DashboardTextMutedBrush}"/>
                        <TextBlock x:Name="TotalTeachersValueTextBlock"
                                   Text="--"
                                   FontSize="34"
                                   FontWeight="Bold"/>
                        <TextBlock x:Name="TotalTeachersStatusTextBlock"
                                   Margin="0,12,0,0"
                                   FontSize="12"
                                   Foreground="{StaticResource DashboardTextMutedBrush}"
                                   Text="Loading teacher data..."/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource DashboardCardBorderStyle}" Margin="8,0,0,0">
                    <StackPanel Margin="16,14,16,12">
                        <TextBlock Text="New Applications"
                                   FontSize="13"
                                   Foreground="{StaticResource DashboardTextMutedBrush}"/>
                        <TextBlock x:Name="NewApplicationsValueTextBlock"
                                   Text="--"
                                   FontSize="34"
                                   FontWeight="Bold"/>
                        <TextBlock x:Name="NewApplicationsStatusTextBlock"
                                   Margin="0,12,0,0"
                                   FontSize="12"
                                   Foreground="{StaticResource DashboardTextMutedBrush}"
                                   Text="Loading recent account activity..."/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Grid Margin="0,18,0,0">
                <StackPanel>
                    <Border Style="{StaticResource DashboardCardBorderStyle}">
                        <StackPanel Margin="18">
                            <TextBlock Text="Recent Activity"
                                       FontSize="18"
                                       FontWeight="Bold"/>
                            <TextBlock x:Name="RecentActivityEmptyTextBlock"
                                       Margin="0,10,0,0"
                                       FontSize="13"
                                       Foreground="{StaticResource DashboardTextMutedBrush}"
                                       Text="Loading recent activity..."/>
                            <ItemsControl x:Name="RecentActivityItemsControl"
                                          Margin="0,10,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,10"
                                                Padding="12"
                                                CornerRadius="10"
                                                Background="{StaticResource DashboardSoftSurfaceBrush}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource DashboardTextPrimaryBrush}"/>
                                                <TextBlock Margin="0,4,0,0"
                                                           Text="{Binding TimestampText}"
                                                           FontSize="12"
                                                           Foreground="{StaticResource DashboardTextMutedBrush}"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <Grid Margin="0,18,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0"
                        Style="{StaticResource DashboardCardBorderStyle}"
                        Margin="0,0,10,0">
                    <StackPanel Margin="18">
                        <TextBlock Text="Department Performance"
                                   FontSize="22"
                                   FontWeight="Bold"/>
                        <TextBlock x:Name="DepartmentPerformanceEmptyTextBlock"
                                   Margin="0,12,0,0"
                                   Text="Loading department data..."
                                   Foreground="{StaticResource DashboardTextMutedBrush}"/>
                        <ItemsControl x:Name="DepartmentPerformanceItemsControl"
                                      Margin="0,12,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,10"
                                            Padding="12"
                                            CornerRadius="10"
                                            Background="{StaticResource DashboardSoftSurfaceBrush}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource DashboardTextPrimaryBrush}"/>
                                            <TextBlock Margin="0,4,0,0"
                                                       Text="{Binding Summary}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource DashboardTextMutedBrush}"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1"
                        Margin="10,0,0,0"
                        Background="{StaticResource DashboardHelpGradientBrush}"
                        CornerRadius="12">
                    <Grid Margin="20">
                        <StackPanel>
                            <TextBlock Text="Need Help?"
                                       FontSize="30"
                                       FontWeight="Bold"
                                       Foreground="White"/>
                            <TextBlock Margin="0,8,0,0"
                                       MaxWidth="360"
                                       FontSize="14"
                                       Foreground="{StaticResource DashboardHelpTextBrush}"
                                       TextWrapping="Wrap"
                                       Text="Check our documentation for guides on how to manage students, set up exams, and organize departments effectively."/>
                            <Button Margin="0,20,0,0"
                                    Width="152"
                                    Height="36"
                                    HorizontalAlignment="Left"
                                    Style="{StaticResource DashboardPrimaryActionButtonStyle}"
                                    Content="View Documentation"/>
                        </StackPanel>
                        <TextBlock Text="&#xE8A5;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="156"
                                   Opacity="0.18"
                                   Foreground="White"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Bottom"
                                   Margin="0,0,-12,-34"/>
                    </Grid>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
