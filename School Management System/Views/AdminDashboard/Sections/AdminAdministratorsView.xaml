<UserControl x:Class="AdminAdministratorsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20,18,20,22">
            <Border Style="{StaticResource DashboardCardBorderStyle}">
                <StackPanel Margin="18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Administrators"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource DashboardTextPrimaryBrush}"/>
                        <TextBlock x:Name="AdministratorsCountTextBlock"
                                   Grid.Column="1"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource DashboardTextMutedBrush}"
                                   Text="0 administrators"/>
                    </Grid>

                    <TextBlock Margin="0,6,0,0"
                               FontSize="12"
                               Foreground="{StaticResource DashboardTextMutedBrush}"
                               Text="Review and manage system administrator accounts."/>

                    <Border Margin="0,14,0,0"
                            BorderBrush="{StaticResource DashboardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <DataGrid x:Name="AdministratorsDataGrid"
                                  Style="{StaticResource DashboardManagementDataGridStyle}"
                                  ColumnHeaderStyle="{StaticResource DashboardManagementDataGridHeaderStyle}"
                                  CellStyle="{StaticResource DashboardManagementDataGridCellStyle}"
                                  RowStyle="{StaticResource DashboardManagementDataGridRowStyle}"
                                  MinHeight="560"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Administrator ID" Binding="{Binding [Administrator ID]}" Width="1.1*"/>
                                <DataGridTextColumn Header="Full Name" Binding="{Binding [Full Name]}" Width="1.4*"/>
                                <DataGridTextColumn Header="Role" Binding="{Binding [Role]}" Width="1*"/>
                                <DataGridTextColumn Header="Email" Binding="{Binding [Email]}" Width="1.6*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
