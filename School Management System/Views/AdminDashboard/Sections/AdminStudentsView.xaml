<UserControl x:Class="AdminStudentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:School_Management_System"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="StudentFormLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,12,0,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource DashboardTextMutedBrush}"/>
        </Style>

        <Style x:Key="StudentFormTextInputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="{StaticResource DashboardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#F8FBFF"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="StudentDetailsValueBorderStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,6,0,0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Background" Value="#F8FBFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource DashboardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>

        <Style x:Key="StudentDetailsValueTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource DashboardTextPrimaryBrush}"/>
            <Setter Property="Text" Value="--"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="StudentFormComboInputStyle"
               TargetType="ComboBox"
               BasedOn="{StaticResource DashboardFilterComboBoxStyle}">
            <Setter Property="Width" Value="Auto"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
            <Setter Property="Padding" Value="10,0,30,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="BorderBrush" Value="{StaticResource DashboardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#F8FBFF"/>
        </Style>

        <Style x:Key="StudentDataGridHeaderStyle"
               TargetType="DataGridColumnHeader"
               BasedOn="{StaticResource DashboardManagementDataGridHeaderStyle}">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="StudentDataGridCellStyle"
               TargetType="DataGridCell"
               BasedOn="{StaticResource DashboardManagementDataGridCellStyle}">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="StudentDataGridRowStyle"
               TargetType="DataGridRow"
               BasedOn="{StaticResource DashboardManagementDataGridRowStyle}">
            <Setter Property="Height" Value="56"/>
        </Style>

        <Style x:Key="StudentDataGridTextStyle" TargetType="TextBlock">
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer x:Name="StudentsRootScrollViewer"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20,18,20,22">
                <Border Style="{StaticResource DashboardCardBorderStyle}">
                    <StackPanel Margin="18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="460"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0"
                                    BorderBrush="{StaticResource DashboardBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Background="White">
                                <Grid>
                                    <Grid x:Name="StudentDetailsPanel">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Border Grid.Row="0"
                                                Padding="18,14"
                                                BorderBrush="{StaticResource DashboardBorderBrush}"
                                                BorderThickness="0,0,0,1"
                                                Background="#FCFDFE">
                                            <StackPanel>
                                                <TextBlock Text="Student Profile"
                                                           FontSize="20"
                                                           FontWeight="Bold"
                                                           Foreground="{StaticResource DashboardTextPrimaryBrush}"/>
                                                <TextBlock Margin="0,3,0,0"
                                                           FontSize="12"
                                                           Foreground="{StaticResource DashboardTextMutedBrush}"
                                                           Text="Preview the selected record before editing or deleting it."/>
                                            </StackPanel>
                                        </Border>

                                        <ScrollViewer x:Name="StudentDetailsScrollViewer"
                                                      Grid.Row="1"
                                                      VerticalScrollBarVisibility="Auto"
                                                      PreviewMouseWheel="NestedPanelScrollViewer_PreviewMouseWheel">
                                            <StackPanel Margin="18,12,18,14">
                                                <Border Padding="16"
                                                        CornerRadius="14"
                                                        Background="#F4F9FF"
                                                        BorderBrush="#D8E7F8"
                                                        BorderThickness="1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="88"/>
                                                            <ColumnDefinition Width="12"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Width="88"
                                                                Height="88"
                                                                CornerRadius="12"
                                                                BorderBrush="#D6E6F7"
                                                                BorderThickness="1"
                                                                Background="White">
                                                            <Image x:Name="StudentDetailsPhotoImage" Stretch="UniformToFill"/>
                                                        </Border>
                                                        <StackPanel Grid.Column="2">
                                                            <TextBlock FontSize="11"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{StaticResource DashboardPrimaryBrush}"
                                                                       Text="SELECTED PROFILE"/>
                                                            <TextBlock x:Name="StudentDetailsHeroNameTextBlock"
                                                                       Margin="0,6,0,0"
                                                                       FontSize="20"
                                                                       FontWeight="Bold"
                                                                       Foreground="{StaticResource DashboardTextPrimaryBrush}"
                                                                       Text="No student selected"
                                                                       TextWrapping="Wrap"/>
                                                            <TextBlock x:Name="StudentDetailsSubtitleTextBlock"
                                                                       Margin="0,4,0,0"
                                                                       FontSize="12"
                                                                       Foreground="{StaticResource DashboardTextMutedBrush}"
                                                                       Text="Choose a student from the roster to preview details."
                                                                       TextWrapping="Wrap"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>

                                                <TextBlock Style="{StaticResource StudentFormLabelStyle}" Margin="0,14,0,0" Text="Student ID"/>
                                                <Border Style="{StaticResource StudentDetailsValueBorderStyle}">
                                                    <TextBlock x:Name="StudentDetailsStudentIdTextBlock" Style="{StaticResource StudentDetailsValueTextStyle}"/>
                                                </Border>

                                                <TextBlock Style="{StaticResource StudentFormLabelStyle}" Text="Email"/>
                                                <Border Style="{StaticResource StudentDetailsValueBorderStyle}">
                                                    <TextBlock x:Name="StudentDetailsEmailTextBlock" Style="{StaticResource StudentDetailsValueTextStyle}"/>
                                                </Border>

                                                <TextBlock Style="{StaticResource StudentFormLabelStyle}" Text="Full Name"/>
                                                <Border Style="{StaticResource StudentDetailsValueBorderStyle}">
                                                    <TextBlock x:Name="StudentDetailsFullNameTextBlock" Style="{StaticResource StudentDetailsValueTextStyle}"/>
                                                </Border>

                                                <TextBlock Style="{StaticResource StudentFormLabelStyle}" Text="Year Level"/>
                                                <Border Style="{StaticResource StudentDetailsValueBorderStyle}">
                                                    <TextBlock x:Name="StudentDetailsYearLevelTextBlock" Style="{StaticResource StudentDetailsValueTextStyle}"/>
                                                </Border>

                                                <TextBlock Style="{StaticResource StudentFormLabelStyle}" Text="Section"/>
                                                <Border Style="{StaticResource StudentDetailsValueBorderStyle}">
                                                    <TextBlock x:Name="StudentDetailsSectionTextBlock" Style="{StaticResource StudentDetailsValueTextStyle}"/>
                                                </Border>

                                                <TextBlock Style="{StaticResource StudentFormLabelStyle}" Text="Course"/>
                                                <Border Style="{StaticResource StudentDetailsValueBorderStyle}">
                                                    <TextBlock x:Name="StudentDetailsCourseTextBlock" Style="{StaticResource StudentDetailsValueTextStyle}"/>
                                                </Border>
                                            </StackPanel>
                                        </ScrollViewer>

                                        <Border Grid.Row="2"
                                                Padding="18,14"
                                                BorderBrush="{StaticResource DashboardBorderBrush}"
                                                BorderThickness="0,1,0,0"
                                                Background="#FCFDFE">
                                            <UniformGrid Columns="3">
                                                <Button x:Name="OpenAddStudentButton" Height="38" Margin="0,0,6,0"
                                                        Style="{StaticResource DashboardPrimaryActionButtonStyle}"
                                                        Background="{StaticResource DashboardPrimaryBrush}"
                                                        Foreground="White"
                                                        Click="OpenAddStudentButton_Click" Content="New"/>
                                                <Button x:Name="EditSelectedStudentButton" Height="38" Margin="6,0"
                                                        Style="{StaticResource DashboardPrimaryActionButtonStyle}"
                                                        Background="#EAF4FF"
                                                        Foreground="{StaticResource DashboardPrimaryBrush}"
                                                        Click="EditSelectedStudentButton_Click" Content="Edit"/>
                                                <Button x:Name="DeleteSelectedStudentButton" Height="38" Margin="6,0,0,0"
                                                        Style="{StaticResource DashboardPrimaryActionButtonStyle}"
                                                        Background="#FFECEE"
                                                        Foreground="#D64545"
                                                        Click="DeleteSelectedStudentButton_Click" Content="Delete"/>
                                            </UniformGrid>
                                        </Border>
                                    </Grid>

                                    <Grid x:Name="StudentFormPanel" Visibility="Collapsed">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Border Grid.Row="0"
                                                Padding="18,14"
                                                BorderBrush="{StaticResource DashboardBorderBrush}"
                                                BorderThickness="0,0,0,1"
                                                Background="#FCFDFE">
                                            <StackPanel>
                                                <TextBlock x:Name="StudentFormTitleTextBlock" Text="Add Student"
                                                           FontSize="20" FontWeight="Bold"
                                                           Foreground="{StaticResource DashboardTextPrimaryBrush}"/>
                                                <TextBlock x:Name="StudentFormSubtitleTextBlock" Margin="0,3,0,0"
                                                           Text="Create a new student record."
                                                           FontSize="12"
                                                           Foreground="{StaticResource DashboardTextMutedBrush}"/>
                                            </StackPanel>
                                        </Border>

                                        <ScrollViewer x:Name="StudentFormScrollViewer"
                                                      Grid.Row="1"
                                                      VerticalScrollBarVisibility="Auto"
                                                      PreviewMouseWheel="NestedPanelScrollViewer_PreviewMouseWheel">
                                            <StackPanel Margin="18,12,18,14">
                                                <Border Padding="12"
                                                        CornerRadius="10"
                                                        Background="#F5F9FF"
                                                        BorderBrush="#D8E8FA"
                                                        BorderThickness="1">
                                                    <TextBlock FontSize="12"
                                                               Foreground="{StaticResource DashboardTextMutedBrush}"
                                                               Text="Student accounts use the student ID to generate the default PRMSU local email."
                                                               TextWrapping="Wrap"/>
                                                </Border>
                                                <Grid Margin="0,14,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="16"/>
                                                        <ColumnDefinition Width="140"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Style="{StaticResource StudentFormLabelStyle}" Margin="0" Text="Student ID"/>
                                                        <TextBox x:Name="StudentFormStudentIdTextBox" Style="{StaticResource StudentFormTextInputStyle}"/>

                                                        <TextBlock Style="{StaticResource StudentFormLabelStyle}" Text="Year Level"/>
                                                        <ComboBox x:Name="StudentFormYearLevelComboBox" Style="{StaticResource StudentFormComboInputStyle}">
                                                            <ComboBoxItem Content="1st Year"/>
                                                            <ComboBoxItem Content="2nd Year"/>
                                                            <ComboBoxItem Content="3rd Year"/>
                                                            <ComboBoxItem Content="4th Year"/>
                                                        </ComboBox>

                                                        <TextBlock Style="{StaticResource StudentFormLabelStyle}" Text="First Name"/>
                                                        <TextBox x:Name="StudentFormFirstNameTextBox" Style="{StaticResource StudentFormTextInputStyle}"/>

                                                        <TextBlock Style="{StaticResource StudentFormLabelStyle}" Text="Last Name"/>
                                                        <TextBox x:Name="StudentFormLastNameTextBox" Style="{StaticResource StudentFormTextInputStyle}"/>

                                                        <TextBlock Style="{StaticResource StudentFormLabelStyle}" Text="Middle Name"/>
                                                        <TextBox x:Name="StudentFormMiddleNameTextBox" Style="{StaticResource StudentFormTextInputStyle}"/>

                                                        <TextBlock Style="{StaticResource StudentFormLabelStyle}" Text="Course"/>
                                                        <TextBox x:Name="StudentFormCourseTextBox" Style="{StaticResource StudentFormTextInputStyle}"/>

                                                         <TextBlock Style="{StaticResource StudentFormLabelStyle}" Text="Section"/>
                                                         <TextBox x:Name="StudentFormSectionTextBox" Style="{StaticResource StudentFormTextInputStyle}"/>

                                                        <TextBlock Style="{StaticResource StudentFormLabelStyle}" Text="Password"/>
                                                        <TextBox x:Name="StudentFormPasswordTextBox" Style="{StaticResource StudentFormTextInputStyle}"/>
                                                        <TextBlock Margin="0,4,0,0"
                                                                   FontSize="11"
                                                                   Foreground="{StaticResource DashboardTextMutedBrush}"
                                                                   Text="Leave blank to use the default password when creating, or keep the current password while editing."
                                                                   TextWrapping="Wrap"/>
                                                     </StackPanel>

                                                     <Border Grid.Column="2"
                                                             Padding="12"
                                                             VerticalAlignment="Top"
                                                             CornerRadius="12"
                                                             Background="#FBFDFF"
                                                             BorderBrush="{StaticResource DashboardBorderBrush}"
                                                             BorderThickness="1">
                                                        <StackPanel>
                                                            <TextBlock FontSize="12"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{StaticResource DashboardTextMutedBrush}"
                                                                       Text="PHOTO PREVIEW"/>
                                                            <Border Margin="0,10,0,0"
                                                                    Width="116"
                                                                    Height="116"
                                                                    HorizontalAlignment="Center"
                                                                    BorderBrush="{StaticResource DashboardBorderBrush}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="10"
                                                                    Background="#F8FBFF">
                                                                <Image x:Name="StudentFormPhotoPreviewImage" Stretch="UniformToFill"/>
                                                            </Border>
                                                            <Button Width="116"
                                                                    Height="36"
                                                                    Margin="0,10,0,0"
                                                                    HorizontalAlignment="Center"
                                                                    Style="{StaticResource DashboardPrimaryActionButtonStyle}"
                                                                    Background="#EAF4FF"
                                                                    Foreground="{StaticResource DashboardPrimaryBrush}"
                                                                    Click="BrowseStudentPhotoButton_Click"
                                                                    Content="Browse"/>
                                                            <Button Width="116"
                                                                    Height="36"
                                                                    Margin="0,8,0,0"
                                                                    HorizontalAlignment="Center"
                                                                    Style="{StaticResource DashboardPrimaryActionButtonStyle}"
                                                                    Background="#F3F6FA"
                                                                    Foreground="{StaticResource DashboardTextMutedBrush}"
                                                                    Click="ClearStudentPhotoButton_Click"
                                                                    Content="Clear"/>
                                                        </StackPanel>
                                                    </Border>
                                                </Grid>
                                            </StackPanel>
                                        </ScrollViewer>

                                        <Border Grid.Row="2"
                                                Padding="18,14"
                                                BorderBrush="{StaticResource DashboardBorderBrush}"
                                                BorderThickness="0,1,0,0"
                                                Background="#FCFDFE">
                                            <UniformGrid Columns="2">
                                                <Button x:Name="SaveStudentFormButton" Height="38" Margin="0,0,6,0"
                                                        Style="{StaticResource DashboardPrimaryActionButtonStyle}"
                                                        Background="#137FEC" Foreground="White"
                                                        Click="SaveStudentFormButton_Click" Content="Add Student"/>
                                                <Button Height="38" Margin="6,0,0,0"
                                                        Style="{StaticResource DashboardPrimaryActionButtonStyle}"
                                                        Background="#F3F6FA"
                                                        Foreground="{StaticResource DashboardTextMutedBrush}"
                                                        Click="CancelStudentFormButton_Click" Content="Cancel"/>
                                            </UniformGrid>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Border>
                            <Border Grid.Column="2"
                                    BorderBrush="{StaticResource DashboardBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Background="White"
                                    local:RoundedClipHelper.CornerRadius="10"
                                    ClipToBounds="True"
                                    SnapsToDevicePixels="True">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0"
                                            Padding="16,14"
                                            BorderBrush="{StaticResource DashboardBorderBrush}"
                                            BorderThickness="0,0,0,1"
                                            Background="#FCFDFE">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="Student Roster"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource DashboardTextPrimaryBrush}"/>
                                                <TextBlock Margin="0,4,0,0"
                                                           FontSize="12"
                                                           Foreground="{StaticResource DashboardTextMutedBrush}"
                                                           Text="Select a row to sync the profile card. Use the dashboard search and header action to manage this list."
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <Border Padding="10,5"
                                                        CornerRadius="999"
                                                        Background="#F6F8FB"
                                                        BorderBrush="{StaticResource DashboardBorderBrush}"
                                                        BorderThickness="1">
                                                    <TextBlock x:Name="StudentsCountTextBlock"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource DashboardTextPrimaryBrush}"
                                                               Text="0"/>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <DataGrid x:Name="StudentsDataGrid"
                                              Grid.Row="1"
                                              Style="{StaticResource DashboardManagementDataGridStyle}"
                                              ColumnHeaderStyle="{StaticResource StudentDataGridHeaderStyle}"
                                              CellStyle="{StaticResource StudentDataGridCellStyle}"
                                              RowStyle="{StaticResource StudentDataGridRowStyle}"
                                              BorderThickness="0"
                                              ColumnWidth="*"
                                              local:RoundedClipHelper.CornerRadius="10"
                                              ClipToBounds="True"
                                              CanUserSortColumns="True"
                                              PreviewMouseWheel="StudentsDataGrid_PreviewMouseWheel"
                                              SelectionChanged="StudentsDataGrid_SelectionChanged"
                                              MinHeight="640">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Student ID" Binding="{Binding [Student ID]}" SortMemberPath="Student ID" Width="*" ElementStyle="{StaticResource StudentDataGridTextStyle}"/>
                                            <DataGridTextColumn Header="Full Name" Binding="{Binding [Full Name]}" SortMemberPath="Full Name" Width="*" ElementStyle="{StaticResource StudentDataGridTextStyle}"/>
                                            <DataGridTextColumn Header="Year Level" Binding="{Binding [Year Level]}" SortMemberPath="Year Level" Width="*" ElementStyle="{StaticResource StudentDataGridTextStyle}"/>
                                            <DataGridTextColumn Header="Course" Binding="{Binding [Course]}" SortMemberPath="Course" Width="*" ElementStyle="{StaticResource StudentDataGridTextStyle}"/>
                                            <DataGridTextColumn Header="Section" Binding="{Binding [Section]}" SortMemberPath="Section" Width="*" ElementStyle="{StaticResource StudentDataGridTextStyle}"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
