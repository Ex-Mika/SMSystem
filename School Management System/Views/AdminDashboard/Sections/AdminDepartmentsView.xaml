<UserControl x:Class="AdminDepartmentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:School_Management_System"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="DepartmentFormLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,12,0,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource DashboardTextMutedBrush}"/>
        </Style>

        <Style x:Key="DepartmentFormTextInputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="{StaticResource DashboardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{StaticResource DashboardSoftSurfaceBrush}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="DepartmentDetailsValueBorderStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,6,0,0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Background" Value="{StaticResource DashboardSoftSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DashboardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>

        <Style x:Key="DepartmentDetailsValueTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource DashboardTextPrimaryBrush}"/>
            <Setter Property="Text" Value="--"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="DepartmentDataGridHeaderStyle"
               TargetType="DataGridColumnHeader"
               BasedOn="{StaticResource DashboardManagementDataGridHeaderStyle}">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="DepartmentDataGridCellStyle"
               TargetType="DataGridCell"
               BasedOn="{StaticResource DashboardManagementDataGridCellStyle}">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="DepartmentDataGridRowStyle"
               TargetType="DataGridRow"
               BasedOn="{StaticResource DashboardManagementDataGridRowStyle}">
            <Setter Property="Height" Value="56"/>
        </Style>

        <Style x:Key="DepartmentDataGridTextStyle" TargetType="TextBlock">
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20,18,20,22">
                <Border Style="{StaticResource DashboardCardBorderStyle}">
                    <StackPanel Margin="18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Departments"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource DashboardTextPrimaryBrush}"/>
                            <TextBlock x:Name="DepartmentsCountTextBlock"
                                       Grid.Column="1"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource DashboardTextMutedBrush}"
                                       Text="0 departments"/>
                        </Grid>

                        <TextBlock Margin="0,6,0,0"
                                   FontSize="12"
                                   Foreground="{StaticResource DashboardTextMutedBrush}"
                                   Text="Select a row to view department details on the left. Use New, Edit, or Delete to manage records."/>

                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="460"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    BorderBrush="{StaticResource DashboardBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Background="White">
                                <Grid>
                                    <Grid x:Name="DepartmentDetailsPanel">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Border Grid.Row="0"
                                                Padding="18,14"
                                                BorderBrush="{StaticResource DashboardBorderBrush}"
                                                BorderThickness="0,0,0,1"
                                                Background="{StaticResource DashboardSoftSurfaceBrush}">
                                            <StackPanel>
                                                <TextBlock Text="Department Details"
                                                           FontSize="20"
                                                           FontWeight="Bold"
                                                           Foreground="{StaticResource DashboardTextPrimaryBrush}"/>
                                                <TextBlock x:Name="DepartmentDetailsSubtitleTextBlock"
                                                           Margin="0,3,0,0"
                                                           Text="Select a department from the table."
                                                           FontSize="12"
                                                           Foreground="{StaticResource DashboardTextMutedBrush}"/>
                                            </StackPanel>
                                        </Border>

                                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                            <StackPanel Margin="18,12,18,14">
                                                <TextBlock Style="{StaticResource DepartmentFormLabelStyle}"
                                                           Margin="0,0,0,0"
                                                           Text="Department ID"/>
                                                <Border Style="{StaticResource DepartmentDetailsValueBorderStyle}">
                                                    <TextBlock x:Name="DepartmentDetailsIdTextBlock"
                                                               Style="{StaticResource DepartmentDetailsValueTextStyle}"/>
                                                </Border>

                                                <TextBlock Style="{StaticResource DepartmentFormLabelStyle}" Text="Department Name"/>
                                                <Border Style="{StaticResource DepartmentDetailsValueBorderStyle}">
                                                    <TextBlock x:Name="DepartmentDetailsNameTextBlock"
                                                               Style="{StaticResource DepartmentDetailsValueTextStyle}"/>
                                                </Border>

                                                <TextBlock Style="{StaticResource DepartmentFormLabelStyle}" Text="Head"/>
                                                <Border Style="{StaticResource DepartmentDetailsValueBorderStyle}">
                                                    <TextBlock x:Name="DepartmentDetailsHeadTextBlock"
                                                               Style="{StaticResource DepartmentDetailsValueTextStyle}"/>
                                                </Border>
                                            </StackPanel>
                                        </ScrollViewer>

                                        <Border Grid.Row="2"
                                                Padding="18,14"
                                                BorderBrush="{StaticResource DashboardBorderBrush}"
                                                BorderThickness="0,1,0,0"
                                                Background="{StaticResource DashboardSoftSurfaceBrush}">
                                            <UniformGrid Columns="3">
                                                <Button Height="38"
                                                        Margin="0,0,6,0"
                                                        Style="{StaticResource DashboardPrimaryActionButtonStyle}"
                                                        Background="{StaticResource DashboardPrimaryBrush}" Foreground="{StaticResource DashboardOnPrimaryBrush}"
                                                        Click="OpenAddDepartmentButton_Click"
                                                        Content="New"/>
                                                <Button x:Name="EditSelectedDepartmentButton"
                                                        Height="38"
                                                        Margin="6,0,6,0"
                                                        Style="{StaticResource DashboardPrimaryActionButtonStyle}"
                                                        Background="{StaticResource DashboardPrimarySoftBrush}"
                                                        Foreground="{StaticResource DashboardAccentTextBrush}"
                                                        Click="EditSelectedDepartmentButton_Click"
                                                        Content="Edit"/>
                                                <Button x:Name="DeleteSelectedDepartmentButton"
                                                        Height="38"
                                                        Margin="6,0,0,0"
                                                        Style="{StaticResource DashboardPrimaryActionButtonStyle}"
                                                        Background="#FFECEE"
                                                        Foreground="#D64545"
                                                        Click="DeleteSelectedDepartmentButton_Click"
                                                        Content="Delete"/>
                                            </UniformGrid>
                                        </Border>
                                    </Grid>

                                    <Grid x:Name="DepartmentFormPanel" Visibility="Collapsed">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Border Grid.Row="0"
                                                Padding="18,14"
                                                BorderBrush="{StaticResource DashboardBorderBrush}"
                                                BorderThickness="0,0,0,1"
                                                Background="{StaticResource DashboardSoftSurfaceBrush}">
                                            <StackPanel>
                                                <TextBlock x:Name="DepartmentFormTitleTextBlock"
                                                           Text="Add Department"
                                                           FontSize="20"
                                                           FontWeight="Bold"
                                                           Foreground="{StaticResource DashboardTextPrimaryBrush}"/>
                                                <TextBlock x:Name="DepartmentFormSubtitleTextBlock"
                                                           Margin="0,3,0,0"
                                                           Text="Create a new department record."
                                                           FontSize="12"
                                                           Foreground="{StaticResource DashboardTextMutedBrush}"/>
                                            </StackPanel>
                                        </Border>

                                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                            <StackPanel Margin="18,12,18,14">
                                                <TextBlock Style="{StaticResource DepartmentFormLabelStyle}"
                                                           Margin="0,0,0,0"
                                                           Text="Department ID"/>
                                                <TextBox x:Name="DepartmentFormIdTextBox"
                                                         Style="{StaticResource DepartmentFormTextInputStyle}"/>

                                                <TextBlock Style="{StaticResource DepartmentFormLabelStyle}" Text="Department Name"/>
                                                <TextBox x:Name="DepartmentFormNameTextBox"
                                                         Style="{StaticResource DepartmentFormTextInputStyle}"/>

                                                <TextBlock Style="{StaticResource DepartmentFormLabelStyle}" Text="Head"/>
                                                <TextBox x:Name="DepartmentFormHeadTextBox"
                                                         Style="{StaticResource DepartmentFormTextInputStyle}"/>
                                            </StackPanel>
                                        </ScrollViewer>

                                        <Border Grid.Row="2"
                                                Padding="18,14"
                                                BorderBrush="{StaticResource DashboardBorderBrush}"
                                                BorderThickness="0,1,0,0"
                                                Background="{StaticResource DashboardSoftSurfaceBrush}">
                                            <UniformGrid Columns="2">
                                                <Button x:Name="SaveDepartmentFormButton"
                                                        Height="38"
                                                        Margin="0,0,6,0"
                                                        Style="{StaticResource DashboardPrimaryActionButtonStyle}"
                                                        Background="{StaticResource DashboardPrimaryBrush}" Foreground="{StaticResource DashboardOnPrimaryBrush}"
                                                        Click="SaveDepartmentFormButton_Click"
                                                        Content="Add Department"/>
                                                <Button Height="38"
                                                        Margin="6,0,0,0"
                                                        Style="{StaticResource DashboardPrimaryActionButtonStyle}"
                                                        Background="{StaticResource DashboardSoftSurfaceAltBrush}"
                                                        Foreground="{StaticResource DashboardTextMutedBrush}"
                                                        Click="CancelDepartmentFormButton_Click"
                                                        Content="Cancel"/>
                                            </UniformGrid>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Border>

                            <Border Grid.Column="2"
                                    BorderBrush="{StaticResource DashboardBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Background="White"
                                    local:RoundedClipHelper.CornerRadius="10"
                                    ClipToBounds="True"
                                    SnapsToDevicePixels="True">
                                <DataGrid x:Name="DepartmentsDataGrid"
                                          Style="{StaticResource DashboardManagementDataGridStyle}"
                                          ColumnHeaderStyle="{StaticResource DepartmentDataGridHeaderStyle}"
                                          CellStyle="{StaticResource DepartmentDataGridCellStyle}"
                                          RowStyle="{StaticResource DepartmentDataGridRowStyle}"
                                          BorderThickness="0"
                                          ColumnWidth="*"
                                          local:RoundedClipHelper.CornerRadius="10"
                                          ClipToBounds="True"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          IsReadOnly="True"
                                          CanUserSortColumns="True"
                                          SelectionChanged="DepartmentsDataGrid_SelectionChanged"
                                          MinHeight="640">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Department ID"
                                                            Binding="{Binding [Department ID]}"
                                                            SortMemberPath="Department ID"
                                                            Width="*"
                                                            ElementStyle="{StaticResource DepartmentDataGridTextStyle}"/>
                                        <DataGridTextColumn Header="Department Name"
                                                            Binding="{Binding [Department Name]}"
                                                            SortMemberPath="Department Name"
                                                            Width="*"
                                                            ElementStyle="{StaticResource DepartmentDataGridTextStyle}"/>
                                        <DataGridTextColumn Header="Head"
                                                            Binding="{Binding [Head]}"
                                                            SortMemberPath="Head"
                                                            Width="*"
                                                            ElementStyle="{StaticResource DepartmentDataGridTextStyle}"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
