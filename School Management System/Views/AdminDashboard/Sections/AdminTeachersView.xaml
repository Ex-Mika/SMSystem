<UserControl x:Class="AdminTeachersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:School_Management_System"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="TeacherFormLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,12,0,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource DashboardTextMutedBrush}"/>
        </Style>

        <Style x:Key="TeacherFormTextInputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="{StaticResource DashboardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#F8FBFF"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="TeacherDetailsValueBorderStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,6,0,0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Background" Value="#F8FBFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource DashboardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>

        <Style x:Key="TeacherDetailsValueTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource DashboardTextPrimaryBrush}"/>
            <Setter Property="Text" Value="--"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="TeacherDataGridHeaderStyle"
               TargetType="DataGridColumnHeader"
               BasedOn="{StaticResource DashboardManagementDataGridHeaderStyle}">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="TeacherDataGridCellStyle"
               TargetType="DataGridCell"
               BasedOn="{StaticResource DashboardManagementDataGridCellStyle}">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="TeacherDataGridRowStyle"
               TargetType="DataGridRow"
               BasedOn="{StaticResource DashboardManagementDataGridRowStyle}">
            <Setter Property="Height" Value="56"/>
        </Style>

        <Style x:Key="TeacherDataGridTextStyle" TargetType="TextBlock">
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer x:Name="TeachersRootScrollViewer"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20,18,20,22">
                <Border Style="{StaticResource DashboardCardBorderStyle}">
                    <StackPanel Margin="18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Teachers"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource DashboardTextPrimaryBrush}"/>
                            <TextBlock x:Name="TeachersCountTextBlock"
                                       Grid.Column="1"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource DashboardTextMutedBrush}"
                                       Text="0 teachers"/>
                        </Grid>

                        <TextBlock Margin="0,6,0,0"
                                   FontSize="12"
                                   Foreground="{StaticResource DashboardTextMutedBrush}"
                                   Text="Select a row to view teacher details on the left. Use New, Edit, or Delete to manage records."/>

                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="460"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    BorderBrush="{StaticResource DashboardBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Background="White">
                                <Grid>
                                    <Grid x:Name="TeacherDetailsPanel">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Border Grid.Row="0"
                                                Padding="18,14"
                                                BorderBrush="{StaticResource DashboardBorderBrush}"
                                                BorderThickness="0,0,0,1"
                                                Background="#FCFDFE">
                                            <StackPanel>
                                                <TextBlock Text="Teacher Details"
                                                           FontSize="20"
                                                           FontWeight="Bold"
                                                           Foreground="{StaticResource DashboardTextPrimaryBrush}"/>
                                                <TextBlock x:Name="TeacherDetailsSubtitleTextBlock"
                                                           Margin="0,3,0,0"
                                                           Text="Select a teacher from the table."
                                                           FontSize="12"
                                                           Foreground="{StaticResource DashboardTextMutedBrush}"/>
                                            </StackPanel>
                                        </Border>

                                        <ScrollViewer x:Name="TeacherDetailsScrollViewer"
                                                      Grid.Row="1"
                                                      VerticalScrollBarVisibility="Auto"
                                                      PreviewMouseWheel="NestedPanelScrollViewer_PreviewMouseWheel">
                                            <StackPanel Margin="18,12,18,14">
                                                <TextBlock Style="{StaticResource TeacherFormLabelStyle}"
                                                           Margin="0,0,0,0"
                                                           Text="Photo"/>
                                                <Border Style="{StaticResource TeacherDetailsValueBorderStyle}"
                                                        Padding="0"
                                                        Width="160"
                                                        Height="160"
                                                        HorizontalAlignment="Left">
                                                    <Image x:Name="TeacherDetailsPhotoImage"
                                                           Stretch="UniformToFill"/>
                                                </Border>

                                                <TextBlock Style="{StaticResource TeacherFormLabelStyle}"
                                                           Text="Teacher ID"/>
                                                <Border Style="{StaticResource TeacherDetailsValueBorderStyle}">
                                                    <TextBlock x:Name="TeacherDetailsTeacherIdTextBlock" Style="{StaticResource TeacherDetailsValueTextStyle}"/>
                                                </Border>

                                                <TextBlock Style="{StaticResource TeacherFormLabelStyle}" Text="Full Name"/>
                                                <Border Style="{StaticResource TeacherDetailsValueBorderStyle}">
                                                    <TextBlock x:Name="TeacherDetailsFullNameTextBlock" Style="{StaticResource TeacherDetailsValueTextStyle}"/>
                                                </Border>

                                                <TextBlock Style="{StaticResource TeacherFormLabelStyle}" Text="Department"/>
                                                <Border Style="{StaticResource TeacherDetailsValueBorderStyle}">
                                                    <TextBlock x:Name="TeacherDetailsDepartmentTextBlock" Style="{StaticResource TeacherDetailsValueTextStyle}"/>
                                                </Border>

                                                <TextBlock Style="{StaticResource TeacherFormLabelStyle}" Text="Position"/>
                                                <Border Style="{StaticResource TeacherDetailsValueBorderStyle}">
                                                    <TextBlock x:Name="TeacherDetailsPositionTextBlock" Style="{StaticResource TeacherDetailsValueTextStyle}"/>
                                                </Border>

                                                <TextBlock Style="{StaticResource TeacherFormLabelStyle}" Text="Advisory"/>
                                                <Border Style="{StaticResource TeacherDetailsValueBorderStyle}">
                                                    <TextBlock x:Name="TeacherDetailsAdvisoryTextBlock" Style="{StaticResource TeacherDetailsValueTextStyle}"/>
                                                </Border>
                                            </StackPanel>
                                        </ScrollViewer>

                                        <Border Grid.Row="2"
                                                Padding="18,14"
                                                BorderBrush="{StaticResource DashboardBorderBrush}"
                                                BorderThickness="0,1,0,0"
                                                Background="#FCFDFE">
                                            <UniformGrid Columns="3">
                                                <Button Height="38"
                                                        Margin="0,0,6,0"
                                                        Style="{StaticResource DashboardPrimaryActionButtonStyle}"
                                                        Background="#137FEC"
                                                        Foreground="White"
                                                        Click="OpenAddTeacherButton_Click"
                                                        Content="New"/>
                                                <Button x:Name="EditSelectedTeacherButton"
                                                        Height="38"
                                                        Margin="6,0,6,0"
                                                        Style="{StaticResource DashboardPrimaryActionButtonStyle}"
                                                        Background="#EAF4FF"
                                                        Foreground="{StaticResource DashboardPrimaryBrush}"
                                                        Click="EditSelectedTeacherButton_Click"
                                                        Content="Edit"/>
                                                <Button x:Name="DeleteSelectedTeacherButton"
                                                        Height="38"
                                                        Margin="6,0,0,0"
                                                        Style="{StaticResource DashboardPrimaryActionButtonStyle}"
                                                        Background="#FFECEE"
                                                        Foreground="#D64545"
                                                        Click="DeleteSelectedTeacherButton_Click"
                                                        Content="Delete"/>
                                            </UniformGrid>
                                        </Border>
                                    </Grid>

                                    <Grid x:Name="TeacherFormPanel" Visibility="Collapsed">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Border Grid.Row="0"
                                                Padding="18,14"
                                                BorderBrush="{StaticResource DashboardBorderBrush}"
                                                BorderThickness="0,0,0,1"
                                                Background="#FCFDFE">
                                            <StackPanel>
                                                <TextBlock x:Name="TeacherFormTitleTextBlock"
                                                           Text="Add Teacher"
                                                           FontSize="20"
                                                           FontWeight="Bold"
                                                           Foreground="{StaticResource DashboardTextPrimaryBrush}"/>
                                                <TextBlock x:Name="TeacherFormSubtitleTextBlock"
                                                           Margin="0,3,0,0"
                                                           Text="Create a new teacher record."
                                                           FontSize="12"
                                                           Foreground="{StaticResource DashboardTextMutedBrush}"/>
                                            </StackPanel>
                                        </Border>

                                        <ScrollViewer x:Name="TeacherFormScrollViewer"
                                                      Grid.Row="1"
                                                      VerticalScrollBarVisibility="Auto"
                                                      PreviewMouseWheel="NestedPanelScrollViewer_PreviewMouseWheel">
                                            <StackPanel Margin="18,12,18,14">
                                                <TextBlock Style="{StaticResource TeacherFormLabelStyle}"
                                                           Margin="0,0,0,0"
                                                           Text="Teacher ID"/>
                                                <TextBox x:Name="TeacherFormTeacherIdTextBox" Style="{StaticResource TeacherFormTextInputStyle}"/>

                                                <Grid Margin="0,12,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="12"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Style="{StaticResource TeacherFormLabelStyle}" Margin="0" Text="First Name"/>
                                                        <TextBox x:Name="TeacherFormFirstNameTextBox" Style="{StaticResource TeacherFormTextInputStyle}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Style="{StaticResource TeacherFormLabelStyle}" Margin="0" Text="Last Name"/>
                                                        <TextBox x:Name="TeacherFormLastNameTextBox" Style="{StaticResource TeacherFormTextInputStyle}"/>
                                                    </StackPanel>
                                                </Grid>

                                                <TextBlock Style="{StaticResource TeacherFormLabelStyle}" Text="Middle Name"/>
                                                <TextBox x:Name="TeacherFormMiddleNameTextBox" Style="{StaticResource TeacherFormTextInputStyle}"/>

                                                <Grid Margin="0,12,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="12"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Style="{StaticResource TeacherFormLabelStyle}" Margin="0" Text="Department"/>
                                                        <TextBox x:Name="TeacherFormDepartmentTextBox" Style="{StaticResource TeacherFormTextInputStyle}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Style="{StaticResource TeacherFormLabelStyle}" Margin="0" Text="Position"/>
                                                        <TextBox x:Name="TeacherFormPositionTextBox" Style="{StaticResource TeacherFormTextInputStyle}"/>
                                                    </StackPanel>
                                                </Grid>

                                                <TextBlock Style="{StaticResource TeacherFormLabelStyle}" Text="Advisory"/>
                                                <TextBox x:Name="TeacherFormAdvisoryTextBox" Style="{StaticResource TeacherFormTextInputStyle}"/>

                                                <TextBlock Style="{StaticResource TeacherFormLabelStyle}" Text="Password"/>
                                                <TextBox x:Name="TeacherFormPasswordTextBox" Style="{StaticResource TeacherFormTextInputStyle}"/>
                                                <TextBlock Margin="0,4,0,0"
                                                           FontSize="11"
                                                           Foreground="{StaticResource DashboardTextMutedBrush}"
                                                           Text="Leave blank to use the default password when creating, or keep the current password while editing."
                                                           TextWrapping="Wrap"/>

                                                <TextBlock Style="{StaticResource TeacherFormLabelStyle}" Text="Photo"/>
                                                <Grid Margin="0,6,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="8"/>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="8"/>
                                                        <ColumnDefinition Width="72"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox x:Name="TeacherFormPhotoPathTextBox"
                                                             Grid.Column="0"
                                                             Style="{StaticResource TeacherFormTextInputStyle}"
                                                             Margin="0"
                                                             TextChanged="TeacherFormPhotoPathTextBox_TextChanged"/>
                                                    <Button Grid.Column="2"
                                                            Height="36"
                                                            Margin="0"
                                                            Style="{StaticResource DashboardPrimaryActionButtonStyle}"
                                                            Background="#EAF4FF"
                                                            Foreground="{StaticResource DashboardPrimaryBrush}"
                                                            Click="BrowseTeacherPhotoButton_Click"
                                                            Content="Browse"/>
                                                    <Button Grid.Column="4"
                                                            Height="36"
                                                            Margin="0"
                                                            Style="{StaticResource DashboardPrimaryActionButtonStyle}"
                                                            Background="#F3F6FA"
                                                            Foreground="{StaticResource DashboardTextMutedBrush}"
                                                            Click="ClearTeacherPhotoButton_Click"
                                                            Content="Clear"/>
                                                </Grid>

                                                <Border Margin="0,8,0,0"
                                                        Width="140"
                                                        Height="140"
                                                        HorizontalAlignment="Left"
                                                        BorderBrush="{StaticResource DashboardBorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="8"
                                                        Background="#F8FBFF">
                                                    <Image x:Name="TeacherFormPhotoPreviewImage"
                                                           Stretch="UniformToFill"/>
                                                </Border>
                                            </StackPanel>
                                        </ScrollViewer>

                                        <Border Grid.Row="2"
                                                Padding="18,14"
                                                BorderBrush="{StaticResource DashboardBorderBrush}"
                                                BorderThickness="0,1,0,0"
                                                Background="#FCFDFE">
                                            <UniformGrid Columns="2">
                                                <Button x:Name="SaveTeacherFormButton"
                                                        Height="38"
                                                        Margin="0,0,6,0"
                                                        Style="{StaticResource DashboardPrimaryActionButtonStyle}"
                                                        Background="#137FEC"
                                                        Foreground="White"
                                                        Click="SaveTeacherFormButton_Click"
                                                        Content="Add Teacher"/>
                                                <Button Height="38"
                                                        Margin="6,0,0,0"
                                                        Style="{StaticResource DashboardPrimaryActionButtonStyle}"
                                                        Background="#F3F6FA"
                                                        Foreground="{StaticResource DashboardTextMutedBrush}"
                                                        Click="CancelTeacherFormButton_Click"
                                                        Content="Cancel"/>
                                            </UniformGrid>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Border>

                            <Border Grid.Column="2"
                                    BorderBrush="{StaticResource DashboardBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Background="White"
                                    local:RoundedClipHelper.CornerRadius="10"
                                    ClipToBounds="True"
                                    SnapsToDevicePixels="True">
                                    <DataGrid x:Name="TeachersDataGrid"
                                          Style="{StaticResource DashboardManagementDataGridStyle}"
                                          ColumnHeaderStyle="{StaticResource TeacherDataGridHeaderStyle}"
                                          CellStyle="{StaticResource TeacherDataGridCellStyle}"
                                          RowStyle="{StaticResource TeacherDataGridRowStyle}"
                                          BorderThickness="0"
                                          ColumnWidth="*"
                                          local:RoundedClipHelper.CornerRadius="10"
                                          ClipToBounds="True"
                                          CanUserSortColumns="True"
                                          PreviewMouseWheel="TeachersDataGrid_PreviewMouseWheel"
                                          SelectionChanged="TeachersDataGrid_SelectionChanged"
                                          MinHeight="640">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Teacher ID" Binding="{Binding [Teacher ID]}" SortMemberPath="Teacher ID" Width="*" ElementStyle="{StaticResource TeacherDataGridTextStyle}"/>
                                        <DataGridTextColumn Header="Full Name" Binding="{Binding [Full Name]}" SortMemberPath="Full Name" Width="*" ElementStyle="{StaticResource TeacherDataGridTextStyle}"/>
                                        <DataGridTextColumn Header="Department" Binding="{Binding [Department]}" SortMemberPath="Department" Width="*" ElementStyle="{StaticResource TeacherDataGridTextStyle}"/>
                                        <DataGridTextColumn Header="Position" Binding="{Binding [Position]}" SortMemberPath="Position" Width="*" ElementStyle="{StaticResource TeacherDataGridTextStyle}"/>
                                        <DataGridTextColumn Header="Advisory" Binding="{Binding [Advisory]}" SortMemberPath="Advisory" Width="*" ElementStyle="{StaticResource TeacherDataGridTextStyle}"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

