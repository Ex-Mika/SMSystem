<UserControl x:Class="TeachersPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1200">
    <Grid Margin="20,18,20,22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Bar: Search + Filters -->
        <Border Grid.Row="0" Style="{StaticResource DashboardCardBorderStyle}" Margin="0,0,0,14">
            <Grid Margin="16,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Style="{StaticResource DashboardSearchTextBoxStyle}"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Tag="Search teachers..."
                         Margin="0,0,10,0"/>

                <ComboBox Grid.Column="1"
                          Style="{StaticResource DashboardFilterComboBoxStyle}"
                          ItemsSource="{Binding CourseOptions}"
                          SelectedItem="{Binding SelectedCourseFilter}"
                          Width="140"
                          Margin="0,0,10,0"/>

                <ComboBox Grid.Column="2"
                          Style="{StaticResource DashboardFilterComboBoxStyle}"
                          ItemsSource="{Binding DayOptions}"
                          SelectedItem="{Binding SelectedDayFilter}"
                          Width="130"
                          Margin="0,0,10,0"/>

                <ComboBox Grid.Column="3"
                          Style="{StaticResource DashboardFilterComboBoxStyle}"
                          ItemsSource="{Binding SectionOptions}"
                          SelectedItem="{Binding SelectedSectionFilter}"
                          Width="130"
                          Margin="0,0,10,0"/>

                <ComboBox Grid.Column="4"
                          Style="{StaticResource DashboardFilterComboBoxStyle}"
                          ItemsSource="{Binding RoomOptions}"
                          SelectedItem="{Binding SelectedRoomFilter}"
                          Width="120"
                          Margin="0,0,10,0"/>

                <Button Grid.Column="5"
                        Style="{StaticResource DashboardHeaderIconButtonStyle}"
                        Command="{Binding ClearFiltersCommand}"
                        ToolTip="Clear filters"
                        Margin="0,0,6,0">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE894;" FontSize="14"/>
                </Button>

                <Button Grid.Column="6"
                        Style="{StaticResource DashboardHeaderIconButtonStyle}"
                        Command="{Binding RefreshCommand}"
                        ToolTip="Refresh">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE72C;" FontSize="14"/>
                </Button>
            </Grid>
        </Border>

        <!-- Main Content: DataGrid + Profile + Schedule -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="340"/>
            </Grid.ColumnDefinitions>

            <!-- Left Column: DataGrid -->
            <Border Grid.Column="0" Style="{StaticResource DashboardCardBorderStyle}" Margin="0,0,14,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Teacher List -->
                    <Grid Grid.Row="0">
                        <DataGrid x:Name="TeachersGrid"
                                  ItemsSource="{Binding Teachers}"
                                  SelectedItem="{Binding SelectedTeacher}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  BorderThickness="0"
                                  Background="Transparent"
                                  RowBackground="Transparent"
                                  AlternatingRowBackground="#FAFBFD"
                                  HorizontalGridLinesBrush="{StaticResource DashboardBorderBrush}"
                                  Margin="0"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserResizeRows="False">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="{StaticResource DashboardSurfaceBrush}"/>
                                    <Setter Property="Foreground" Value="{StaticResource DashboardTextMutedBrush}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="Padding" Value="16,10"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource DashboardBorderBrush}"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Padding" Value="16,10"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Foreground" Value="{StaticResource DashboardTextPrimaryBrush}"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridCell">
                                                <Border Padding="{TemplateBinding Padding}"
                                                        Background="{TemplateBinding Background}">
                                                    <ContentPresenter VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="{StaticResource DashboardPrimarySoftBrush}"/>
                                            <Setter Property="Foreground" Value="{StaticResource DashboardTextPrimaryBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.CellStyle>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="{StaticResource DashboardPrimarySoftBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#F5F8FC"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Teacher ID" Binding="{Binding TeacherId}" Width="120"/>
                                <DataGridTextColumn Header="Full Name" Binding="{Binding FullName}" Width="*"/>
                                <DataGridTextColumn Header="Department" Binding="{Binding Department}" Width="140"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="110"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Empty State Overlay -->
                        <Border x:Name="EmptyOverlay" Background="{StaticResource DashboardSurfaceBrush}" IsHitTestVisible="False">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE716;"
                                           FontSize="40" HorizontalAlignment="Center"
                                           Foreground="{StaticResource DashboardTextMutedBrush}"
                                           Margin="0,0,0,12"/>
                                <TextBlock Text="No teachers yet"
                                           FontSize="16" FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           Foreground="{StaticResource DashboardTextPrimaryBrush}"/>
                                <TextBlock Text="Teachers will appear here once added."
                                           FontSize="13" HorizontalAlignment="Center"
                                           Foreground="{StaticResource DashboardTextMutedBrush}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Items.Count, ElementName=TeachersGrid}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                    </Grid>

                    <!-- Schedule Panel -->
                    <Border Grid.Row="1"
                            BorderBrush="{StaticResource DashboardBorderBrush}"
                            BorderThickness="0,1,0,0"
                            MinHeight="180">
                        <Grid>
                            <StackPanel Margin="16,12,16,0">
                                <TextBlock Text="Assigned Classes / Schedule"
                                           FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource DashboardTextPrimaryBrush}"
                                           Margin="0,0,0,8"/>
                            </StackPanel>

                            <DataGrid x:Name="ScheduleGrid"
                                      ItemsSource="{Binding AssignedClasses}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      BorderThickness="0"
                                      Background="Transparent"
                                      RowBackground="Transparent"
                                      HorizontalGridLinesBrush="{StaticResource DashboardBorderBrush}"
                                      Margin="0,36,0,0"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      CanUserResizeRows="False">
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="{StaticResource DashboardSurfaceBrush}"/>
                                        <Setter Property="Foreground" Value="{StaticResource DashboardTextMutedBrush}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="FontSize" Value="12"/>
                                        <Setter Property="Padding" Value="12,8"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource DashboardBorderBrush}"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Subject" Binding="{Binding Subject}" Width="*"/>
                                    <DataGridTextColumn Header="Section" Binding="{Binding Section}" Width="100"/>
                                    <DataGridTextColumn Header="Room" Binding="{Binding Room}" Width="80"/>
                                    <DataGridTextColumn Header="Day" Binding="{Binding Day}" Width="90"/>
                                    <DataGridTextColumn Header="Time" Binding="{Binding StartTime}" Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Schedule Empty State -->
                            <Border Background="{StaticResource DashboardSurfaceBrush}" IsHitTestVisible="False" Margin="0,36,0,0">
                                <TextBlock Text="No assigned classes yet."
                                           FontSize="13" FontStyle="Italic"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="{StaticResource DashboardTextMutedBrush}"/>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Items.Count, ElementName=ScheduleGrid}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Right Column: Teacher Profile Form -->
            <Border Grid.Column="1" Style="{StaticResource DashboardCardBorderStyle}">
                <StackPanel Margin="20,18,20,20">
                    <TextBlock Text="Teacher Profile"
                               FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource DashboardTextPrimaryBrush}"
                               Margin="0,0,0,14"/>

                    <!-- Photo Placeholder -->
                    <Border Width="80" Height="80" CornerRadius="40"
                            Background="{StaticResource DashboardPageBackgroundBrush}"
                            BorderBrush="{StaticResource DashboardBorderBrush}"
                            BorderThickness="1"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,14">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE716;"
                                   FontSize="30" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="{StaticResource DashboardTextMutedBrush}"/>
                    </Border>

                    <!-- Teacher ID -->
                    <TextBlock Text="Teacher ID"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource DashboardTextMutedBrush}"
                               Margin="0,0,0,6"/>
                    <TextBox Text="{Binding FormTeacherId, UpdateSourceTrigger=PropertyChanged}"
                             Padding="10,8" FontSize="13"
                             BorderBrush="{StaticResource DashboardBorderBrush}"
                             BorderThickness="1"
                             Margin="0,0,0,14">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>

                    <!-- Full Name -->
                    <TextBlock Text="Full Name"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource DashboardTextMutedBrush}"
                               Margin="0,0,0,6"/>
                    <TextBox Text="{Binding FormFullName, UpdateSourceTrigger=PropertyChanged}"
                             Padding="10,8" FontSize="13"
                             BorderBrush="{StaticResource DashboardBorderBrush}"
                             BorderThickness="1"
                             Margin="0,0,0,14">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>

                    <!-- Email -->
                    <TextBlock Text="Email"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource DashboardTextMutedBrush}"
                               Margin="0,0,0,6"/>
                    <TextBox Text="{Binding FormEmail, UpdateSourceTrigger=PropertyChanged}"
                             Padding="10,8" FontSize="13"
                             BorderBrush="{StaticResource DashboardBorderBrush}"
                             BorderThickness="1"
                             Margin="0,0,0,14">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>

                    <!-- Contact No -->
                    <TextBlock Text="Contact No"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource DashboardTextMutedBrush}"
                               Margin="0,0,0,6"/>
                    <TextBox Text="{Binding FormContactNo, UpdateSourceTrigger=PropertyChanged}"
                             Padding="10,8" FontSize="13"
                             BorderBrush="{StaticResource DashboardBorderBrush}"
                             BorderThickness="1"
                             Margin="0,0,0,14">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>

                    <!-- Department -->
                    <TextBlock Text="Department"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource DashboardTextMutedBrush}"
                               Margin="0,0,0,6"/>
                    <ComboBox SelectedItem="{Binding FormDepartment}"
                              Padding="10,8" FontSize="13"
                              BorderBrush="{StaticResource DashboardBorderBrush}"
                              BorderThickness="1"
                              Margin="0,0,0,14"/>

                    <!-- Status -->
                    <TextBlock Text="Status"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource DashboardTextMutedBrush}"
                               Margin="0,0,0,6"/>
                    <ComboBox SelectedItem="{Binding FormStatus}"
                              Padding="10,8" FontSize="13"
                              BorderBrush="{StaticResource DashboardBorderBrush}"
                              BorderThickness="1"
                              Margin="0,0,0,22">
                        <sys:String>Active</sys:String>
                        <sys:String>Inactive</sys:String>
                    </ComboBox>

                    <!-- Action Buttons -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <Button Grid.Row="0" Grid.Column="0"
                                Content="New" Command="{Binding NewCommand}"
                                Margin="0,0,4,8" Padding="0,9" FontSize="13"
                                FontWeight="SemiBold" Cursor="Hand"
                                Foreground="{StaticResource DashboardPrimaryBrush}"
                                BorderBrush="{StaticResource DashboardBorderBrush}"
                                BorderThickness="1" Background="{StaticResource DashboardSurfaceBrush}">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        <Button Grid.Row="0" Grid.Column="1"
                                Content="Edit" Command="{Binding EditCommand}"
                                Margin="4,0,0,8" Padding="0,9" FontSize="13"
                                FontWeight="SemiBold" Cursor="Hand"
                                Foreground="{StaticResource DashboardPrimaryBrush}"
                                BorderBrush="{StaticResource DashboardBorderBrush}"
                                BorderThickness="1" Background="{StaticResource DashboardSurfaceBrush}">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </Button.Resources>
                        </Button>

                        <Button Grid.Row="1" Grid.Column="0"
                                Content="Save" Command="{Binding SaveCommand}"
                                Margin="0,0,4,8" Padding="0,9" FontSize="13"
                                FontWeight="SemiBold" Cursor="Hand"
                                Foreground="White"
                                Background="{StaticResource DashboardPrimaryBrush}"
                                BorderThickness="0">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        <Button Grid.Row="1" Grid.Column="1"
                                Content="Cancel" Command="{Binding CancelCommand}"
                                Margin="4,0,0,8" Padding="0,9" FontSize="13"
                                FontWeight="SemiBold" Cursor="Hand"
                                Foreground="{StaticResource DashboardTextMutedBrush}"
                                BorderBrush="{StaticResource DashboardBorderBrush}"
                                BorderThickness="1" Background="{StaticResource DashboardSurfaceBrush}">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </Button.Resources>
                        </Button>

                        <Button Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                Content="Block / Unblock" Command="{Binding BlockCommand}"
                                Padding="0,9" FontSize="13"
                                FontWeight="SemiBold" Cursor="Hand"
                                Foreground="{StaticResource DashboardDangerBrush}"
                                BorderBrush="{StaticResource DashboardBorderBrush}"
                                BorderThickness="1" Background="{StaticResource DashboardSurfaceBrush}">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
