<UserControl x:Class="StudentsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1200">
    <Grid Margin="20,18,20,22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Bar: Search + Filters -->
        <Border Grid.Row="0" Style="{StaticResource DashboardCardBorderStyle}" Margin="0,0,0,14">
            <Grid Margin="16,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Style="{StaticResource DashboardSearchTextBoxStyle}"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Tag="Search students..."
                         Margin="0,0,10,0"/>

                <ComboBox Grid.Column="1"
                          Style="{StaticResource DashboardFilterComboBoxStyle}"
                          ItemsSource="{Binding CourseOptions}"
                          SelectedItem="{Binding SelectedCourseFilter}"
                          Width="160"
                          Margin="0,0,10,0"/>

                <ComboBox Grid.Column="2"
                          Style="{StaticResource DashboardFilterComboBoxStyle}"
                          ItemsSource="{Binding StatusOptions}"
                          SelectedItem="{Binding SelectedStatusFilter}"
                          Width="160"
                          Margin="0,0,10,0"/>

                <Button Grid.Column="3"
                        Style="{StaticResource DashboardHeaderIconButtonStyle}"
                        Command="{Binding ClearFiltersCommand}"
                        ToolTip="Clear filters"
                        Margin="0,0,6,0">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE894;" FontSize="14"/>
                </Button>

                <Button Grid.Column="4"
                        Style="{StaticResource DashboardHeaderIconButtonStyle}"
                        Command="{Binding RefreshCommand}"
                        ToolTip="Refresh">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE72C;" FontSize="14"/>
                </Button>
            </Grid>
        </Border>

        <!-- Main Content: DataGrid + Form -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <!-- Left Column: DataGrid -->
            <Border Grid.Column="0" Style="{StaticResource DashboardCardBorderStyle}" Margin="0,0,14,0">
                <Grid>
                    <DataGrid x:Name="StudentsGrid"
                              ItemsSource="{Binding Students}"
                              SelectedItem="{Binding SelectedStudent}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              BorderThickness="0"
                              Background="Transparent"
                              RowBackground="Transparent"
                              AlternatingRowBackground="#FAFBFD"
                              HorizontalGridLinesBrush="{StaticResource DashboardBorderBrush}"
                              Margin="0"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserResizeRows="False">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="{StaticResource DashboardSurfaceBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource DashboardTextMutedBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="Padding" Value="16,10"/>
                                <Setter Property="BorderBrush" Value="{StaticResource DashboardBorderBrush}"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding" Value="16,10"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Foreground" Value="{StaticResource DashboardTextPrimaryBrush}"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border Padding="{TemplateBinding Padding}"
                                                    Background="{TemplateBinding Background}">
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{StaticResource DashboardPrimarySoftBrush}"/>
                                        <Setter Property="Foreground" Value="{StaticResource DashboardTextPrimaryBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Cursor" Value="Hand"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{StaticResource DashboardPrimarySoftBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F5F8FC"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Student ID" Binding="{Binding StudentId}" Width="120"/>
                            <DataGridTextColumn Header="Full Name" Binding="{Binding FullName}" Width="*"/>
                            <DataGridTextColumn Header="Course" Binding="{Binding Course}" Width="110"/>
                            <DataGridTextColumn Header="Year Level" Binding="{Binding YearLevel}" Width="100"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="110"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Empty State Overlay -->
                    <Border x:Name="EmptyOverlay" Background="{StaticResource DashboardSurfaceBrush}" IsHitTestVisible="False">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE77B;"
                                       FontSize="40" HorizontalAlignment="Center"
                                       Foreground="{StaticResource DashboardTextMutedBrush}"
                                       Margin="0,0,0,12"/>
                            <TextBlock Text="No students yet"
                                       FontSize="16" FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       Foreground="{StaticResource DashboardTextPrimaryBrush}"/>
                            <TextBlock Text="Students will appear here once added."
                                       FontSize="13" HorizontalAlignment="Center"
                                       Foreground="{StaticResource DashboardTextMutedBrush}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Items.Count, ElementName=StudentsGrid}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                </Grid>
            </Border>

            <!-- Right Column: Student Profile Form -->
            <Border Grid.Column="1" Style="{StaticResource DashboardCardBorderStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="20,18,20,20">
                        <TextBlock Text="Student Profile"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource DashboardTextPrimaryBrush}"
                                   Margin="0,0,0,14"/>

                        <!-- Photo Placeholder -->
                        <Border Width="80" Height="80" CornerRadius="40"
                                Background="{StaticResource DashboardPageBackgroundBrush}"
                                BorderBrush="{StaticResource DashboardBorderBrush}"
                                BorderThickness="1"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,14">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE77B;"
                                       FontSize="30" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{StaticResource DashboardTextMutedBrush}"/>
                        </Border>

                        <!-- Student ID -->
                        <TextBlock Text="Student ID"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource DashboardTextMutedBrush}"
                                   Margin="0,0,0,6"/>
                        <TextBox Text="{Binding FormStudentId, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="10,8" FontSize="13"
                                 BorderBrush="{StaticResource DashboardBorderBrush}"
                                 BorderThickness="1"
                                 Margin="0,0,0,10">
                            <TextBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>

                        <!-- First Name + Middle Name -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                <TextBlock Text="First Name" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource DashboardTextMutedBrush}" Margin="0,0,0,6"/>
                                <TextBox Text="{Binding FormFirstName, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="10,8" FontSize="13"
                                         BorderBrush="{StaticResource DashboardBorderBrush}" BorderThickness="1">
                                    <TextBox.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="6"/>
                                        </Style>
                                    </TextBox.Resources>
                                </TextBox>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                <TextBlock Text="Middle Name" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource DashboardTextMutedBrush}" Margin="0,0,0,6"/>
                                <TextBox Text="{Binding FormMiddleName, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="10,8" FontSize="13"
                                         BorderBrush="{StaticResource DashboardBorderBrush}" BorderThickness="1">
                                    <TextBox.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="6"/>
                                        </Style>
                                    </TextBox.Resources>
                                </TextBox>
                            </StackPanel>
                        </Grid>

                        <!-- Last Name -->
                        <TextBlock Text="Last Name"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource DashboardTextMutedBrush}"
                                   Margin="0,0,0,6"/>
                        <TextBox Text="{Binding FormLastName, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="10,8" FontSize="13"
                                 BorderBrush="{StaticResource DashboardBorderBrush}"
                                 BorderThickness="1"
                                 Margin="0,0,0,10">
                            <TextBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>

                        <!-- Sex + Birthdate -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                <TextBlock Text="Sex" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource DashboardTextMutedBrush}" Margin="0,0,0,6"/>
                                <ComboBox SelectedItem="{Binding FormSex}"
                                          ItemsSource="{Binding SexOptions}"
                                          Padding="10,8" FontSize="13"
                                          BorderBrush="{StaticResource DashboardBorderBrush}" BorderThickness="1"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                <TextBlock Text="Birthdate" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource DashboardTextMutedBrush}" Margin="0,0,0,6"/>
                                <TextBox Text="{Binding FormBirthdate, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="10,8" FontSize="13"
                                         BorderBrush="{StaticResource DashboardBorderBrush}" BorderThickness="1">
                                    <TextBox.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="6"/>
                                        </Style>
                                    </TextBox.Resources>
                                </TextBox>
                            </StackPanel>
                        </Grid>

                        <!-- Address -->
                        <TextBlock Text="Address"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource DashboardTextMutedBrush}"
                                   Margin="0,0,0,6"/>
                        <TextBox Text="{Binding FormAddress, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="10,8" FontSize="13"
                                 BorderBrush="{StaticResource DashboardBorderBrush}"
                                 BorderThickness="1"
                                 Margin="0,0,0,10">
                            <TextBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>

                        <!-- Contact No -->
                        <TextBlock Text="Contact No"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource DashboardTextMutedBrush}"
                                   Margin="0,0,0,6"/>
                        <TextBox Text="{Binding FormContactNo, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="10,8" FontSize="13"
                                 BorderBrush="{StaticResource DashboardBorderBrush}"
                                 BorderThickness="1"
                                 Margin="0,0,0,10">
                            <TextBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>

                        <!-- Guardian Name + Guardian Contact -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                <TextBlock Text="Guardian Name" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource DashboardTextMutedBrush}" Margin="0,0,0,6"/>
                                <TextBox Text="{Binding FormGuardianName, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="10,8" FontSize="13"
                                         BorderBrush="{StaticResource DashboardBorderBrush}" BorderThickness="1">
                                    <TextBox.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="6"/>
                                        </Style>
                                    </TextBox.Resources>
                                </TextBox>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                <TextBlock Text="Guardian Contact" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource DashboardTextMutedBrush}" Margin="0,0,0,6"/>
                                <TextBox Text="{Binding FormGuardianContact, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="10,8" FontSize="13"
                                         BorderBrush="{StaticResource DashboardBorderBrush}" BorderThickness="1">
                                    <TextBox.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="6"/>
                                        </Style>
                                    </TextBox.Resources>
                                </TextBox>
                            </StackPanel>
                        </Grid>

                        <!-- Course + Year Level -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                <TextBlock Text="Course" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource DashboardTextMutedBrush}" Margin="0,0,0,6"/>
                                <ComboBox SelectedItem="{Binding FormCourse}"
                                          Padding="10,8" FontSize="13"
                                          BorderBrush="{StaticResource DashboardBorderBrush}" BorderThickness="1"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                <TextBlock Text="Year Level" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource DashboardTextMutedBrush}" Margin="0,0,0,6"/>
                                <ComboBox SelectedItem="{Binding FormYearLevel}"
                                          ItemsSource="{Binding YearLevelOptions}"
                                          Padding="10,8" FontSize="13"
                                          BorderBrush="{StaticResource DashboardBorderBrush}" BorderThickness="1"/>
                            </StackPanel>
                        </Grid>

                        <!-- Status -->
                        <TextBlock Text="Status"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource DashboardTextMutedBrush}"
                                   Margin="0,0,0,6"/>
                        <ComboBox SelectedItem="{Binding FormStatus}"
                                  Padding="10,8" FontSize="13"
                                  BorderBrush="{StaticResource DashboardBorderBrush}"
                                  BorderThickness="1"
                                  Margin="0,0,0,18">
                            <sys:String>Active</sys:String>
                            <sys:String>Graduated</sys:String>
                            <sys:String>Blocked</sys:String>
                        </ComboBox>

                        <!-- Enrollment Summary Placeholder -->
                        <Border Background="{StaticResource DashboardPageBackgroundBrush}"
                                CornerRadius="8"
                                Padding="14,10"
                                Margin="0,0,0,18">
                            <TextBlock Text="Enrollment Summary — will be available once enrollment module is implemented."
                                       FontSize="12" FontStyle="Italic"
                                       Foreground="{StaticResource DashboardTextMutedBrush}"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <!-- Action Buttons -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>

                            <Button Grid.Row="0" Grid.Column="0"
                                    Content="New" Command="{Binding NewCommand}"
                                    Margin="0,0,4,8" Padding="0,9" FontSize="13"
                                    FontWeight="SemiBold" Cursor="Hand"
                                    Foreground="{StaticResource DashboardPrimaryBrush}"
                                    BorderBrush="{StaticResource DashboardBorderBrush}"
                                    BorderThickness="1" Background="{StaticResource DashboardSurfaceBrush}">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            <Button Grid.Row="0" Grid.Column="1"
                                    Content="Edit" Command="{Binding EditCommand}"
                                    Margin="4,0,0,8" Padding="0,9" FontSize="13"
                                    FontWeight="SemiBold" Cursor="Hand"
                                    Foreground="{StaticResource DashboardPrimaryBrush}"
                                    BorderBrush="{StaticResource DashboardBorderBrush}"
                                    BorderThickness="1" Background="{StaticResource DashboardSurfaceBrush}">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </Button.Resources>
                            </Button>

                            <Button Grid.Row="1" Grid.Column="0"
                                    Content="Save" Command="{Binding SaveCommand}"
                                    Margin="0,0,4,8" Padding="0,9" FontSize="13"
                                    FontWeight="SemiBold" Cursor="Hand"
                                    Foreground="White"
                                    Background="{StaticResource DashboardPrimaryBrush}"
                                    BorderThickness="0">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            <Button Grid.Row="1" Grid.Column="1"
                                    Content="Cancel" Command="{Binding CancelCommand}"
                                    Margin="4,0,0,8" Padding="0,9" FontSize="13"
                                    FontWeight="SemiBold" Cursor="Hand"
                                    Foreground="{StaticResource DashboardTextMutedBrush}"
                                    BorderBrush="{StaticResource DashboardBorderBrush}"
                                    BorderThickness="1" Background="{StaticResource DashboardSurfaceBrush}">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </Button.Resources>
                            </Button>

                            <Button Grid.Row="2" Grid.Column="0"
                                    Content="Graduate" Command="{Binding GraduateCommand}"
                                    Margin="0,0,4,0" Padding="0,9" FontSize="13"
                                    FontWeight="SemiBold" Cursor="Hand"
                                    Foreground="{StaticResource DashboardPrimaryBrush}"
                                    BorderBrush="{StaticResource DashboardBorderBrush}"
                                    BorderThickness="1" Background="{StaticResource DashboardSurfaceBrush}">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            <Button Grid.Row="2" Grid.Column="1"
                                    Content="Block" Command="{Binding BlockCommand}"
                                    Margin="4,0,0,0" Padding="0,9" FontSize="13"
                                    FontWeight="SemiBold" Cursor="Hand"
                                    Foreground="{StaticResource DashboardDangerBrush}"
                                    BorderBrush="{StaticResource DashboardBorderBrush}"
                                    BorderThickness="1" Background="{StaticResource DashboardSurfaceBrush}">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
