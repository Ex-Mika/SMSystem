<Window x:Class="AdminDashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:local="clr-namespace:School_Management_System"
        mc:Ignorable="d"
        Title="EduManager Dashboard"
        Width="1540"
        Height="900"
        MinWidth="1220"
        MinHeight="760"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        StateChanged="AdminDashboardWindow_StateChanged"
        Background="{StaticResource DashboardPageBackgroundBrush}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    <Grid Background="{StaticResource DashboardPageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource DashboardTitleBarBorderStyle}"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="10,0,0,0"/>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0">
                    <Button Style="{StaticResource TitleBarButtonStyle}"
                            Click="MinimizeButton_Click"
                            ToolTip="Minimize">
                        <TextBlock Text="&#xE921;"
                                   FontSize="15"
                                   Style="{StaticResource LoginTitleBarGlyphStyle}"/>
                    </Button>
                    <Button Style="{StaticResource TitleBarButtonStyle}"
                            Click="MaximizeRestoreButton_Click"
                            ToolTip="Maximize/Restore">
                        <TextBlock x:Name="MaximizeRestoreIcon"
                                   Text="&#xE922;"
                                   FontSize="12"
                                   Style="{StaticResource LoginTitleBarGlyphStyle}"/>
                    </Button>
                    <Button Style="{StaticResource TitleBarCloseButtonStyle}"
                            Click="CloseButton_Click"
                            ToolTip="Close">
                        <TextBlock Text="&#xE8BB;"
                                   FontSize="11"
                                   Style="{StaticResource LoginTitleBarGlyphStyle}"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="272"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource DashboardSurfaceBrush}"
                    BorderBrush="{StaticResource DashboardBorderBrush}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            BorderBrush="{StaticResource DashboardBorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="22,20,20,18">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="44"
                                    Height="44"
                                    CornerRadius="22"
                                    Background="{StaticResource DashboardDeepAccentBrush}"
                                    VerticalAlignment="Center">
                                <Image Source="/Resources/Images/prmsu-logo.png"
                                       Width="28"
                                       Height="28"
                                       Stretch="Uniform"/>
                            </Border>
                            <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Admin"
                                           FontSize="21"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource DashboardTextPrimaryBrush}"/>
                                <TextBlock Text="Admin Panel"
                                           FontSize="12"
                                           Margin="0,2,0,0"
                                           Foreground="{StaticResource DashboardTextMutedBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="14,14,14,0">
                        <StackPanel>
                            <Button x:Name="DashboardNavButton"
                                    Style="{StaticResource DashboardSidebarNavSelectedButtonStyle}"
                                    Click="DashboardNavButton_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="DashboardNavIconBorder" Style="{StaticResource DashboardSidebarIconSelectedBadgeStyle}">
                                        <TextBlock x:Name="DashboardNavIconText" Style="{StaticResource DashboardSidebarIconGlyphSelectedStyle}" Text="&#xE80F;"/>
                                    </Border>
                                    <TextBlock x:Name="DashboardNavText"
                                               Grid.Column="1"
                                               Style="{StaticResource DashboardSidebarNavTextSelectedStyle}"
                                               Text="Dashboard"/>
                                </Grid>
                            </Button>

                            <Button x:Name="StudentsNavButton"
                                    Style="{StaticResource DashboardSidebarNavButtonStyle}"
                                    Margin="0,6,0,0"
                                    Click="StudentsNavButton_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="StudentsNavIconBorder" Style="{StaticResource DashboardSidebarIconBadgeStyle}">
                                        <TextBlock x:Name="StudentsNavIconText" Style="{StaticResource DashboardSidebarIconGlyphStyle}" Text="&#xE77B;"/>
                                    </Border>
                                    <TextBlock x:Name="StudentsNavText" Grid.Column="1" Style="{StaticResource DashboardSidebarNavTextStyle}" Text="Students"/>
                                </Grid>
                            </Button>

                            <Button x:Name="TeachersNavButton"
                                    Style="{StaticResource DashboardSidebarNavButtonStyle}"
                                    Margin="0,6,0,0"
                                    Click="TeachersNavButton_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="TeachersNavIconBorder" Style="{StaticResource DashboardSidebarIconBadgeStyle}">
                                        <TextBlock x:Name="TeachersNavIconText" Style="{StaticResource DashboardSidebarIconGlyphStyle}" Text="&#xE716;"/>
                                    </Border>
                                    <TextBlock x:Name="TeachersNavText" Grid.Column="1" Style="{StaticResource DashboardSidebarNavTextStyle}" Text="Teachers"/>
                                </Grid>
                            </Button>

                            <Button x:Name="AdministratorsNavButton"
                                    Style="{StaticResource DashboardSidebarNavButtonStyle}"
                                    Margin="0,6,0,0"
                                    Click="AdministratorsNavButton_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="AdministratorsNavIconBorder" Style="{StaticResource DashboardSidebarIconBadgeStyle}">
                                        <TextBlock x:Name="AdministratorsNavIconText" Style="{StaticResource DashboardSidebarIconGlyphStyle}" Text="&#xE716;"/>
                                    </Border>
                                    <TextBlock x:Name="AdministratorsNavText" Grid.Column="1" Style="{StaticResource DashboardSidebarNavTextStyle}" Text="Administrators"/>
                                </Grid>
                            </Button>

                            <Button x:Name="CoursesNavButton"
                                     Style="{StaticResource DashboardSidebarNavButtonStyle}"
                                     Margin="0,6,0,0"
                                     Click="CoursesNavButton_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="CoursesNavIconBorder" Style="{StaticResource DashboardSidebarIconBadgeStyle}">
                                        <TextBlock x:Name="CoursesNavIconText" Style="{StaticResource DashboardSidebarIconGlyphStyle}" Text="&#xE8A5;"/>
                                    </Border>
                                    <TextBlock x:Name="CoursesNavText" Grid.Column="1" Style="{StaticResource DashboardSidebarNavTextStyle}" Text="Courses"/>
                                </Grid>
                            </Button>

                            <Button x:Name="DepartmentsNavButton"
                                     Style="{StaticResource DashboardSidebarNavButtonStyle}"
                                     Margin="0,6,0,0"
                                     Click="DepartmentsNavButton_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="DepartmentsNavIconBorder" Style="{StaticResource DashboardSidebarIconBadgeStyle}">
                                        <TextBlock x:Name="DepartmentsNavIconText" Style="{StaticResource DashboardSidebarIconGlyphStyle}" Text="&#xE8C7;"/>
                                    </Border>
                                    <TextBlock x:Name="DepartmentsNavText" Grid.Column="1" Style="{StaticResource DashboardSidebarNavTextStyle}" Text="Departments"/>
                                </Grid>
                            </Button>

                            <Button x:Name="SubjectsNavButton"
                                    Style="{StaticResource DashboardSidebarNavButtonStyle}"
                                    Margin="0,6,0,0"
                                    Click="SubjectsNavButton_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="SubjectsNavIconBorder" Style="{StaticResource DashboardSidebarIconBadgeStyle}">
                                        <TextBlock x:Name="SubjectsNavIconText" Style="{StaticResource DashboardSidebarIconGlyphStyle}" Text="&#xE8EF;"/>
                                    </Border>
                                    <TextBlock x:Name="SubjectsNavText" Grid.Column="1" Style="{StaticResource DashboardSidebarNavTextStyle}" Text="Subjects"/>
                                </Grid>
                            </Button>

                            <Button x:Name="ReportsNavButton"
                                    Style="{StaticResource DashboardSidebarNavButtonStyle}"
                                    Margin="0,6,0,0"
                                    Click="ReportsNavButton_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="ReportsNavIconBorder" Style="{StaticResource DashboardSidebarIconBadgeStyle}">
                                        <TextBlock x:Name="ReportsNavIconText" Style="{StaticResource DashboardSidebarIconGlyphStyle}" Text="&#xE9D2;"/>
                                    </Border>
                                    <TextBlock x:Name="ReportsNavText" Grid.Column="1" Style="{StaticResource DashboardSidebarNavTextStyle}" Text="Reports"/>
                                </Grid>
                            </Button>

                            <Button x:Name="SchedulingNavButton"
                                    Style="{StaticResource DashboardSidebarNavButtonStyle}"
                                    Margin="0,6,0,0"
                                    Click="SchedulingNavButton_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="SchedulingNavIconBorder" Style="{StaticResource DashboardSidebarIconBadgeStyle}">
                                        <TextBlock x:Name="SchedulingNavIconText" Style="{StaticResource DashboardSidebarIconGlyphStyle}" Text="&#xE823;"/>
                                    </Border>
                                    <TextBlock x:Name="SchedulingNavText" Grid.Column="1" Style="{StaticResource DashboardSidebarNavTextStyle}" Text="Scheduling"/>
                                </Grid>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="2"
                            BorderBrush="{StaticResource DashboardBorderBrush}"
                            BorderThickness="0,1,0,0"
                            Padding="14,10,14,14">
                        <StackPanel>
                            <Button Style="{StaticResource DashboardSidebarNavButtonStyle}"
                                    Click="SignOutButton_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Style="{StaticResource DashboardSidebarIconBadgeStyle}">
                                        <TextBlock Style="{StaticResource DashboardSidebarIconGlyphStyle}" Text="&#xF3B1;"/>
                                    </Border>
                                    <TextBlock Grid.Column="1" Style="{StaticResource DashboardSidebarNavTextStyle}" Text="Sign Out"/>
                                </Grid>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{StaticResource DashboardSurfaceBrush}" BorderBrush="{StaticResource DashboardBorderBrush}" BorderThickness="0,0,0,1" Padding="18,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock x:Name="ContentTitleTextBlock" Text="Overview" FontSize="28" FontWeight="Bold" Foreground="{StaticResource DashboardTextPrimaryBrush}"/>
                            <Grid Width="420" Height="36" Margin="20,0,0,0">
                                <TextBox x:Name="SearchActionsTextBox"
                                         Style="{StaticResource DashboardSearchTextBoxStyle}"
                                         TextChanged="SearchActionsTextBox_TextChanged"/>
                                <TextBlock FontFamily="Segoe MDL2 Assets"
                                           Text="&#xE721;"
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource DashboardTextMutedBrush}"
                                           IsHitTestVisible="False"/>
                                <TextBlock x:Name="SearchPlaceholderTextBlock"
                                           Text="Search students, staff, or actions..."
                                           Margin="36,0,10,0"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource DashboardTextMutedBrush}"
                                           FontSize="13"
                                           IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding Text, ElementName=SearchActionsTextBox}" Value=""/>
                                                        <Condition Binding="{Binding IsKeyboardFocused, ElementName=SearchActionsTextBox}" Value="False"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button x:Name="HeaderSectionActionButton"
                                    MinWidth="122"
                                    Height="36"
                                    Margin="0,0,12,0"
                                    Padding="16,0"
                                    Style="{StaticResource DashboardPrimaryActionButtonStyle}"
                                    Background="{StaticResource DashboardPrimaryBrush}" Foreground="{StaticResource DashboardOnPrimaryBrush}"
                                    Visibility="Collapsed"
                                    Click="HeaderSectionActionButton_Click"
                                    Content="Add Student"/>
                            <Border Width="1" Height="26" Background="{StaticResource DashboardBorderBrush}" Margin="0,0,12,0"/>
                            <Border x:Name="HeaderAdminAvatarBorder"
                                    Width="36"
                                    Height="36"
                                    CornerRadius="18"
                                    Background="{StaticResource DashboardAvatarSurfaceBrush}"
                                    BorderBrush="{StaticResource DashboardBorderBrush}"
                                    BorderThickness="1"
                                    ClipToBounds="True">
                                <Grid>
                                    <Image x:Name="HeaderAdminProfileImage"
                                           Stretch="UniformToFill"
                                           Visibility="Collapsed"/>
                                    <TextBlock x:Name="HeaderAdminInitialTextBlock"
                                               Text="A"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="12"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource DashboardAvatarForegroundBrush}"/>
                                </Grid>
                            </Border>
                            <StackPanel Margin="8,0,0,0">
                                <TextBlock x:Name="HeaderAdminNameTextBlock"
                                           Text="Administrator"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource DashboardTextPrimaryBrush}"/>
                                <TextBlock x:Name="HeaderAdminRoleTextBlock"
                                           Text="Administrator"
                                           FontSize="11"
                                           Foreground="{StaticResource DashboardTextMutedBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="1">
                    <local:AdminOverviewView x:Name="DashboardContentView"/>
                    <local:AdminStudentsView x:Name="StudentsContentView" Visibility="Collapsed"/>
                    <local:AdminTeachersView x:Name="TeachersContentView" Visibility="Collapsed"/>
                    <local:AdminAdministratorsView x:Name="AdministratorsContentView" Visibility="Collapsed"/>
                    <local:AdminCoursesView x:Name="CoursesContentView" Visibility="Collapsed"/>
                    <local:AdminDepartmentsView x:Name="DepartmentsContentView" Visibility="Collapsed"/>
                    <local:AdminSubjectsView x:Name="SubjectsContentView" Visibility="Collapsed"/>
                    <local:AdminReportsView x:Name="ReportsContentView" Visibility="Collapsed"/>
                    <local:AdminSchedulingView x:Name="SchedulingContentView" Visibility="Collapsed"/>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
