<Window x:Class="AdminDashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="EduManager Dashboard"
        Width="1540"
        Height="900"
        MinWidth="1220"
        MinHeight="760"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        StateChanged="AdminDashboardWindow_StateChanged"
        Background="{StaticResource DashboardPageBackgroundBrush}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    <Grid Background="{StaticResource DashboardPageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource DashboardTitleBarBorderStyle}"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="10,0,0,0">


                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0">
                    <Button Style="{StaticResource TitleBarButtonStyle}"
                            Click="MinimizeButton_Click"
                            ToolTip="Minimize">
                        <TextBlock Text="&#xE921;"
                                   FontSize="15"
                                   Style="{StaticResource LoginTitleBarGlyphStyle}"/>
                    </Button>
                    <Button Style="{StaticResource TitleBarButtonStyle}"
                            Click="MaximizeRestoreButton_Click"
                            ToolTip="Maximize/Restore">
                        <TextBlock x:Name="MaximizeRestoreIcon"
                                   Text="&#xE922;"
                                   FontSize="12"
                                   Style="{StaticResource LoginTitleBarGlyphStyle}"/>
                    </Button>
                    <Button Style="{StaticResource TitleBarCloseButtonStyle}"
                            Click="CloseButton_Click"
                            ToolTip="Close">
                        <TextBlock Text="&#xE8BB;"
                                   FontSize="11"
                                   Style="{StaticResource LoginTitleBarGlyphStyle}"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="272"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource DashboardSurfaceBrush}"
                    BorderBrush="{StaticResource DashboardBorderBrush}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            BorderBrush="{StaticResource DashboardBorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="22,20,20,18">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="44"
                                    Height="44"
                                    CornerRadius="22"
                                    Background="#032538"
                                    VerticalAlignment="Center">
                                <Image Source="/Resources/Images/prmsu-logo.png"
                                       Width="28"
                                       Height="28"
                                       Stretch="Uniform"/>
                            </Border>
                            <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Admin"
                                           FontSize="21"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource DashboardTextPrimaryBrush}"/>
                                <TextBlock Text="Admin Panel"
                                           FontSize="12"
                                           Margin="0,2,0,0"
                                           Foreground="{StaticResource DashboardTextMutedBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="14,14,14,0">
                        <StackPanel>
                            <Button x:Name="NavDashboardButton"
                                    Style="{StaticResource DashboardSidebarNavSelectedButtonStyle}"
                                    Click="NavDashboard_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid Width="24" Height="24" VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource DashboardSidebarIconGlyphSelectedStyle}" Text="&#xE80F;"/>
                                    </Grid>
                                    <TextBlock Grid.Column="1"
                                               Style="{StaticResource DashboardSidebarNavTextSelectedStyle}"
                                               Text="Dashboard"/>
                                </Grid>
                            </Button>

                            <Button x:Name="NavCoursesButton"
                                    Style="{StaticResource DashboardSidebarNavButtonStyle}"
                                    Margin="0,6,0,0"
                                    Click="NavCourses_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Style="{StaticResource DashboardSidebarIconBadgeStyle}">
                                        <TextBlock Style="{StaticResource DashboardSidebarIconGlyphStyle}" Text="&#xE7BE;"/>
                                    </Border>
                                    <TextBlock Grid.Column="1" Style="{StaticResource DashboardSidebarNavTextStyle}" Text="Courses"/>
                                </Grid>
                            </Button>

                            <Button x:Name="NavSubjectsButton"
                                    Style="{StaticResource DashboardSidebarNavButtonStyle}"
                                    Margin="0,6,0,0"
                                    Click="NavSubjects_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Style="{StaticResource DashboardSidebarIconBadgeStyle}">
                                        <TextBlock Style="{StaticResource DashboardSidebarIconGlyphStyle}" Text="&#xE8A5;"/>
                                    </Border>
                                    <TextBlock Grid.Column="1" Style="{StaticResource DashboardSidebarNavTextStyle}" Text="Subjects"/>
                                </Grid>
                            </Button>

                            <Button x:Name="NavSectionsButton"
                                    Style="{StaticResource DashboardSidebarNavButtonStyle}"
                                    Margin="0,6,0,0"
                                    Click="NavSections_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Style="{StaticResource DashboardSidebarIconBadgeStyle}">
                                        <TextBlock Style="{StaticResource DashboardSidebarIconGlyphStyle}" Text="&#xE8F1;"/>
                                    </Border>
                                    <TextBlock Grid.Column="1" Style="{StaticResource DashboardSidebarNavTextStyle}" Text="Sections"/>
                                </Grid>
                            </Button>

                            <Button x:Name="NavRoomsButton"
                                    Style="{StaticResource DashboardSidebarNavButtonStyle}"
                                    Margin="0,6,0,0"
                                    Click="NavRooms_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Style="{StaticResource DashboardSidebarIconBadgeStyle}">
                                        <TextBlock Style="{StaticResource DashboardSidebarIconGlyphStyle}" Text="&#xE707;"/>
                                    </Border>
                                    <TextBlock Grid.Column="1" Style="{StaticResource DashboardSidebarNavTextStyle}" Text="Rooms"/>
                                </Grid>
                            </Button>

                            <Button x:Name="NavStudentsButton"
                                    Style="{StaticResource DashboardSidebarNavButtonStyle}"
                                    Margin="0,6,0,0"
                                    Click="NavStudents_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Style="{StaticResource DashboardSidebarIconBadgeStyle}">
                                        <TextBlock Style="{StaticResource DashboardSidebarIconGlyphStyle}" Text="&#xE77B;"/>
                                    </Border>
                                    <TextBlock Grid.Column="1" Style="{StaticResource DashboardSidebarNavTextStyle}" Text="Students"/>
                                </Grid>
                            </Button>

                            <Button x:Name="NavTeachersButton"
                                    Style="{StaticResource DashboardSidebarNavButtonStyle}"
                                    Margin="0,6,0,0"
                                    Click="NavTeachers_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Style="{StaticResource DashboardSidebarIconBadgeStyle}">
                                        <TextBlock Style="{StaticResource DashboardSidebarIconGlyphStyle}" Text="&#xE716;"/>
                                    </Border>
                                    <TextBlock Grid.Column="1" Style="{StaticResource DashboardSidebarNavTextStyle}" Text="Teachers"/>
                                </Grid>
                            </Button>

                            <Button x:Name="NavSchedulingButton"
                                    Style="{StaticResource DashboardSidebarNavButtonStyle}"
                                    Margin="0,6,0,0"
                                    Click="NavScheduling_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Style="{StaticResource DashboardSidebarIconBadgeStyle}">
                                        <TextBlock Style="{StaticResource DashboardSidebarIconGlyphStyle}" Text="&#xE787;"/>
                                    </Border>
                                    <TextBlock Grid.Column="1" Style="{StaticResource DashboardSidebarNavTextStyle}" Text="Scheduling"/>
                                </Grid>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{StaticResource DashboardSurfaceBrush}" BorderBrush="{StaticResource DashboardBorderBrush}" BorderThickness="0,0,0,1" Padding="18,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock x:Name="PageTitleText" Text="Overview" FontSize="28" FontWeight="Bold" Foreground="{StaticResource DashboardTextPrimaryBrush}"/>
                            <Grid Width="420" Height="36" Margin="20,0,0,0">
                                <TextBox x:Name="SearchActionsTextBox"
                                         Style="{StaticResource DashboardSearchTextBoxStyle}"/>
                                <TextBlock FontFamily="Segoe MDL2 Assets"
                                           Text="&#xE721;"
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource DashboardTextMutedBrush}"
                                           IsHitTestVisible="False"/>
                                <TextBlock Text="Search students, staff, or actions..."
                                           Margin="36,0,10,0"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource DashboardTextMutedBrush}"
                                           FontSize="13"
                                           IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding Text, ElementName=SearchActionsTextBox}" Value=""/>
                                                        <Condition Binding="{Binding IsKeyboardFocused, ElementName=SearchActionsTextBox}" Value="False"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="36" Height="36" CornerRadius="18"
                                    Background="{StaticResource DashboardPrimarySoftBrush}"
                                    BorderBrush="{StaticResource DashboardBorderBrush}" BorderThickness="1">
                                <TextBlock Text="AM" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="12" FontWeight="Bold"
                                           Foreground="{StaticResource DashboardPrimaryBrush}"/>
                            </Border>
                            <StackPanel Margin="8,0,0,0">
                                <TextBlock Text="Alex Morgan" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource DashboardTextPrimaryBrush}"/>
                                <TextBlock Text="Administrator" FontSize="11" Foreground="{StaticResource DashboardTextMutedBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <ContentControl x:Name="MainContentHost" Grid.Row="1"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
