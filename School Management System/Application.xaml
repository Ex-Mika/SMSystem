             xmlns:local="clr-namespace:School_Management_System"
             StartupUri="Views/LoginWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml"/>
                <ResourceDictionary Source="Resources/Styles/Controls.xaml"/>
                <ResourceDictionary Source="Resources/Styles/LoginWindow.xaml"/>
                <ResourceDictionary Source="Resources/Styles/AdminDashboardWindow.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
